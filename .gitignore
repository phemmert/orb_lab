# =====================================================================
# ORB Lab .gitignore
# =====================================================================

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# Environment variables (may contain API keys!)
.env

# Optuna databases (large, machine-specific)
*.db
*.db-journal

# Data cache (large parquet files - regenerated by backtester)
data/cache/
*.parquet

# Jupyter notebook checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Backup files
*.backup_*
*.bak
*.tmp
*.swp
*~

# Batch logs (regenerated each run)
results/batch_logs/

# OS files
Thumbs.db
.DS_Store
desktop.ini

# IDE
.vscode/
.idea/
*.code-workspace

# Sample data files
data/sample_*.csv

# NOTE: results/*.json files ARE tracked (small, needed for presets)
# NOTE: src/*.py files ARE tracked (core code)
# NOTE: *.bat files ARE tracked (startup scripts)
# NOTE: notebooks/*.ipynb ARE tracked (but not checkpoints)
