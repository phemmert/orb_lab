var float pmVwapVolSum = 0.0
var float pmSessionVWAP = na
var float pmPrevDayClose = na
var float pmGapSize = na
var float pmGapNormalized = na
var string pmGapRegime = "flat"
var float pmFinalScore = 0.0
var string pmBiasZone = "neutral"
var bool pmQualifiedLong = false
var bool pmQualifiedShort = false
var bool pmIsPowerBar = false
var bool pmIsPowerBarBull = false
var bool pmIsPowerBarBear = false

// ========================
// === CORE FUNCTIONS ===
// ========================

jma(src, length) =>
    momentum = ta.change(src)
    volatility = ta.atr(length)
    ratio = volatility != 0 ? momentum / volatility : 0
    smoothed = ta.ema(src + ratio * volatility, length)
    smoothed

ma(source, length, type) =>
    switch type
        "SMA" => ta.sma(source, length)
        "EMA" => ta.ema(source, length)
        "HMA" => ta.hma(source, length)
        "JMA" => jma(source, length)
        => ta.sma(source, length)

f_getSessionTime() =>
    time(timeframe.period, sessionTime, "America/New_York")

calcPositionSize(entryPrice, stopPrice) =>
    riskAmount = riskType == "Fixed" ? fixedRiskAmount : strategy.equity * (riskPercent / 100)
    riskPerShare = math.abs(entryPrice - stopPrice)
    posSize = riskPerShare > 0 ? riskAmount / riskPerShare : 0
    math.round(posSize * 100) / 100

calculateQQE(rsiLength, smoothingFactor, qqeFactor, source) =>
    wildersLength = rsiLength * 2 - 1
    rsi = ta.rsi(source, rsiLength)
    smoothedRsi = ta.ema(rsi, smoothingFactor)
    atrRsi = math.abs(smoothedRsi[1] - smoothedRsi)
    smoothedAtrRsi = ta.ema(atrRsi, wildersLength)
    dynamicAtrRsi = smoothedAtrRsi * qqeFactor

    var float longBand = 0.0
    var float shortBand = 0.0
    var int trendDirection = 0

    atrDelta = dynamicAtrRsi
    newShortBand = smoothedRsi + atrDelta
    newLongBand = smoothedRsi - atrDelta
    longBand := smoothedRsi[1] > longBand[1] and smoothedRsi > longBand[1] ? math.max(longBand[1], newLongBand) : newLongBand
    shortBand := smoothedRsi[1] < shortBand[1] and smoothedRsi < shortBand[1] ? math.min(shortBand[1], newShortBand) : newShortBand
    longBandCross = ta.cross(longBand[1], smoothedRsi)
    
    if ta.cross(smoothedRsi, shortBand[1])
        trendDirection := 1
    else if longBandCross
        trendDirection := -1
    else
        trendDirection := trendDirection[1]

    qqeTrendLine = trendDirection == 1 ? longBand : shortBand
    [qqeTrendLine, smoothedRsi, trendDirection]

findSwingLowRegularHours(int lookback) =>
    float swingLow = na
    int validBars = 0
    regularHours = time(timeframe.period, "0930-1600:1234567", "America/New_York")
    for i = 1 to lookback * 3
        if not na(regularHours[i])
            if na(swingLow) or low[i] < swingLow
                swingLow := low[i]
            validBars += 1
            if validBars >= lookback
                break
    if na(swingLow)
        swingLow := low[1]
    swingLow

findSwingHighRegularHours(int lookback) =>
    float swingHigh = na
    int validBars = 0
    regularHours = time(timeframe.period, "0930-1600:1234567", "America/New_York")
    for i = 1 to lookback * 3
        if not na(regularHours[i])
            if na(swingHigh) or high[i] > swingHigh
                swingHigh := high[i]
            validBars += 1
            if validBars >= lookback
                break
    if na(swingHigh)
        swingHigh := high[1]
    swingHigh

calculateStopLoss(bool isLong, float entryPrice, string stopTypeInput = "") =>
    string stopTypeToUse = stopTypeInput == "" ? stopLossType : stopTypeInput
    float atrStop = isLong ? entryPrice - (atr * atrMultiplier) : entryPrice + (atr * atrMultiplier)
    
    float swingLow = findSwingLowRegularHours(swingLookback)
    float swingHigh = findSwingHighRegularHours(swingLookback)
    float swingStop = isLong ? swingLow - (atr * swingBuffer) : swingHigh + (atr * swingBuffer)
    
    float vwapStop = isLong ? vwapValue - (atr * vwapStopDistance) : vwapValue + (atr * vwapStopDistance)
    float manualStop = isLong ? entryPrice - manualStopPoints : entryPrice + manualStopPoints
    
    if isLong
        swingStop := math.min(swingStop, entryPrice - 0.01)
        vwapStop := math.min(vwapStop, entryPrice - 0.01)
    else
        swingStop := math.max(swingStop, entryPrice + 0.01)
        vwapStop := math.max(vwapStop, entryPrice + 0.01)
    
    float selectedStop = switch stopTypeToUse
        "ATR" => atrStop
        "Swing" => swingStop
        "VWAP" => vwapStop
        "Manual" => manualStop
        "Hybrid" => 
            if isLong
                hybridExcludeVwap ? math.max(atrStop, swingStop) : math.max(atrStop, math.max(swingStop, vwapStop))
            else
                hybridExcludeVwap ? math.min(atrStop, swingStop) : math.min(atrStop, math.min(swingStop, vwapStop))
        => atrStop
    
    string stopTypeLabel = stopLossType
    if stopLossType == "Hybrid"
        if selectedStop == atrStop
            stopTypeLabel := "Hybrid-ATR"
        else if selectedStop == swingStop
            stopTypeLabel := "Hybrid-Swing" 
        else if selectedStop == vwapStop
            stopTypeLabel := "Hybrid-VWAP"
    
    [selectedStop, stopTypeLabel]

evaluateBestStop(bool isLong, float entryPrice, float atrVal, float rrDesired) =>
    [atrStop, atrType] = calculateStopLoss(isLong, entryPrice, "ATR")
    [swingStop, swingType] = calculateStopLoss(isLong, entryPrice, "Swing")
    [vwapStop, vwapType] = calculateStopLoss(isLong, entryPrice, "VWAP")
    [hybridStop, hybridType] = calculateStopLoss(isLong, entryPrice, "Hybrid")
    
    float atrRisk = math.abs(entryPrice - atrStop)
    float swingRisk = math.abs(entryPrice - swingStop)
    float vwapRisk = math.abs(entryPrice - vwapStop)
    float hybridRisk = math.abs(entryPrice - hybridStop)
    
    float atrTarget = isLong ? entryPrice + (atrRisk * rrDesired) : entryPrice - (atrRisk * rrDesired)
    float swingTarget = isLong ? entryPrice + (swingRisk * rrDesired) : entryPrice - (swingRisk * rrDesired)
    float vwapTarget = isLong ? entryPrice + (vwapRisk * rrDesired) : entryPrice - (vwapRisk * rrDesired)
    float hybridTarget = isLong ? entryPrice + (hybridRisk * rrDesired) : entryPrice - (hybridRisk * rrDesired)
    
    float atrTargetATRs = atrRisk > 0 ? math.abs(atrTarget - entryPrice) / atrVal : 0
    float swingTargetATRs = swingRisk > 0 ? math.abs(swingTarget - entryPrice) / atrVal : 0
    float vwapTargetATRs = vwapRisk > 0 ? math.abs(vwapTarget - entryPrice) / atrVal : 0
    float hybridTargetATRs = hybridRisk > 0 ? math.abs(hybridTarget - entryPrice) / atrVal : 0
    
    float atrBestRR = atrTargetATRs <= maxTargetATR ? rrDesired : (maxTargetATR * atrVal) / atrRisk
    float swingBestRR = swingTargetATRs <= maxTargetATR ? rrDesired : (maxTargetATR * atrVal) / swingRisk
    float vwapBestRR = vwapTargetATRs <= maxTargetATR ? rrDesired : (maxTargetATR * atrVal) / vwapRisk
    float hybridBestRR = hybridTargetATRs <= maxTargetATR ? rrDesired : (maxTargetATR * atrVal) / hybridRisk
    
    float bestRR = math.max(math.max(atrBestRR, swingBestRR), math.max(vwapBestRR, hybridBestRR))
    
    float selectedStop = hybridStop
    string selectedType = hybridType
    float selectedRR = hybridBestRR
    
    if bestRR == atrBestRR
        selectedStop := atrStop
        selectedType := "ATR"
        selectedRR := atrBestRR
    else if bestRR == swingBestRR
        selectedStop := swingStop
        selectedType := "Swing"
        selectedRR := swingBestRR
    else if bestRR == vwapBestRR
        selectedStop := vwapStop
        selectedType := "VWAP"
        selectedRR := vwapBestRR
    else
        selectedStop := hybridStop
        selectedType := hybridType
        selectedRR := hybridBestRR
    
    [selectedStop, selectedType, selectedRR, atrBestRR, swingBestRR, vwapBestRR, hybridBestRR]

// ===============================
// === CALCULATIONS AND LOGIC ===
// ===============================

inSession = not na(f_getSessionTime())

isNewSession = inSession and not inSession[1]

validTradingDay = true
if useDateFilter
    validTradingDay := time >= fromDate and time <= toDate

atr := ta.atr(atrPeriod)

// === TIME DETECTION FOR PM MODULE ===
etHour = hour(time, "America/New_York")
etMinute = minute(time, "America/New_York")
etMins = etHour * 60 + etMinute
PM_START = 4 * 60           // 4:00 AM
PM_END = 9 * 60 + 29        // 9:29 AM
RTH_START = 9 * 60 + 30     // 9:30 AM
SIGNAL_END = 10 * 60 + 30   // 10:30 AM
isPMsession = etMins >= PM_START and etMins <= PM_END
isRTHsession = etMins >= RTH_START and etMins < 16 * 60
isSignalWindow = etMins >= RTH_START and etMins < SIGNAL_END
pmNewDay = ta.change(dayofweek) != 0
pmRthJustOpened = isRTHsession and not isRTHsession[1]

// ========================================
// === PM MODULE CALCULATIONS ===
// ========================================
if enablePMmodule
    // Reset on new day
    if pmNewDay
        pmHigh := na
        pmLow := na
        pmHighLocked := na
        pmLowLocked := na
        pmMidLocked := na
        pmLevelsLocked := false
        pmGapRegime := "flat"
        pmGapSize := na
        pmGapNormalized := na
    
    // Track PM high/low during pre-market
    if isPMsession
        pmHigh := na(pmHigh) ? high : math.max(pmHigh, high)
        pmLow := na(pmLow) ? low : math.min(pmLow, low)
    
    // Lock levels at RTH open
    if pmRthJustOpened and not pmLevelsLocked and not na(pmHigh) and not na(pmLow)
        pmHighLocked := pmHigh
        pmLowLocked := pmLow
        pmMidLocked := (pmHigh + pmLow) / 2
        pmLevelsLocked := true
    
    // Session VWAP calculation
    if pmRthJustOpened
        pmVwapSum := 0.0
        pmVwapVolSum := 0.0
    
    if isRTHsession
        typicalPrice = (high + low + close) / 3
        pmVwapSum := pmVwapSum + (typicalPrice * volume)
        pmVwapVolSum := pmVwapVolSum + volume
        pmSessionVWAP := pmVwapVolSum > 0 ? pmVwapSum / pmVwapVolSum : na
    
    // Gap detection at RTH open
    if isRTHsession and not isRTHsession[1]
        pmPrevDayClose := close[1]
    
    if pmRthJustOpened and not na(pmPrevDayClose) and not na(atr[1]) and atr[1] > 0
        pmGapSize := open - pmPrevDayClose
        pmGapNormalized := pmGapSize / atr[1]
        if math.abs(pmGapNormalized) < gapThreshATR
            pmGapRegime := "flat"
        else if pmGapNormalized > 0
            pmGapRegime := "gap_up"
        else
            pmGapRegime := "gap_down"

// PM Valid check (used throughout)
pmValid = enablePMmodule and pmLevelsLocked and not na(pmHighLocked) and not na(pmLowLocked)
pmRange = pmValid ? pmHighLocked - pmLowLocked : na

// ========================================
// === POWER BAR DETECTION ===
// ========================================
atrSMA = ta.sma(atr, 20)
pbVolEMA = ta.ema(volume, 20)
pbVolRatio = pbVolEMA > 0 ? volume / pbVolEMA : 0
pbAtrRatio = atrSMA > 0 ? atr / atrSMA : 1
pbCandleRange = high - low
pbCandleBody = math.abs(close - open)
pbBodyPct = pbCandleRange > 0 ? (pbCandleBody / pbCandleRange) * 100 : 0

// Gate conditions
pbPassesATRgate = pbCandleRange >= (atr * pbSensATR)
pbPassesBodyGate = pbBodyPct >= pbMinBodyPct
pbPassesVolumeGate = pbVolRatio >= pbMinVolRatio
pbIsBullish = close > open
pbIsBearish = close < open

// Power Bar detection
if enablePMmodule and pbEnabled
    pmIsPowerBar := barstate.isconfirmed and pbPassesATRgate and pbPassesBodyGate and pbPassesVolumeGate
    pmIsPowerBarBull := pmIsPowerBar and pbIsBullish
    pmIsPowerBarBear := pmIsPowerBar and pbIsBearish
else
    pmIsPowerBar := false
    pmIsPowerBarBull := false
    pmIsPowerBarBear := false

// Power Bar coloring
barcolor(enablePMmodule and pmIsPowerBarBull ? pbBullColor : enablePMmodule and pmIsPowerBarBear ? pbBearColor : na)

// ========================================
// === PM SCORING ENGINE ===
// ========================================
if enablePMmodule and pmValid
    // === 1. POWER SCORE: Volume × ATR co-scaling ===
    bodyQuality = (pbBodyPct - pbMinBodyPct) / (100 - pbMinBodyPct)
    bodyScorePM = math.max(0, math.min(100, bodyQuality * 60))
    volExpansion = math.max(0.5, math.min(2.0, pbVolRatio))
    atrExpansion = math.max(0.5, math.min(2.0, pbAtrRatio))
    ignitionMultiplier = (volExpansion * atrExpansion)
    float pmPowerScore = math.min(100, bodyScorePM * ignitionMultiplier)
    atrExcess = (pbCandleRange / (atr * pbSensATR)) - 1
    atrBonus = math.min(20, atrExcess * 40)
    pmPowerScore := math.min(100, pmPowerScore + atrBonus)
    
    // === 2. BIAS SCORE: Position relative to PM mid ===
    priceVsMid = close - pmMidLocked
    distFromMid = pmRange > 0 ? math.abs(priceVsMid) / (pmRange / 2) : 0
    float pmBiasScore = 50.0
    float pmBiasMultiplier = 1.0
    
    // === 2. BIAS SCORE: Position relative to PM mid (direction-agnostic) ===
    if close > pmMidLocked
        pmBiasZone := "long_bias"
        pmBiasScore := math.min(100, 60 + distFromMid * 40)
        pmBiasMultiplier := 1.0 + (distFromMid * 0.2)
    else if close < pmMidLocked
        pmBiasZone := "short_bias"
        pmBiasScore := math.min(100, 60 + distFromMid * 40)
        pmBiasMultiplier := 1.0 + (distFromMid * 0.2)
    else
        pmBiasZone := "neutral"
        pmBiasScore := 50
        pmBiasMultiplier := 1.0
    
    // === 3. PROXIMITY SCORE: Distance to entry/target levels ===
    distToPMH = math.abs(close - pmHighLocked)
    distToPML = math.abs(close - pmLowLocked)
    float pmProxScore = 50.0
    
    if pbIsBullish and atr > 0
        entryProx = math.max(0, 100 - (distToPML / atr) * 50)
        targetRoom = (pmHighLocked - close) / atr
        targetScore = math.min(50, targetRoom * 25)
        pmProxScore := math.max(0, math.min(100, entryProx * 0.6 + targetScore * 0.4))
    else if pbIsBearish and atr > 0
        entryProx = math.max(0, 100 - (distToPMH / atr) * 50)
        targetRoom = (close - pmLowLocked) / atr
        targetScore = math.min(50, targetRoom * 25)
        pmProxScore := math.max(0, math.min(100, entryProx * 0.6 + targetScore * 0.4))
    
    // === 4. TIME SCORE: Logistic decay from open ===
    float pmTimeScore = 0.0
    if isSignalWindow
        minutesFromOpen = etMins - RTH_START
        pmTimeScore := 100 / (1 + math.exp((minutesFromOpen - 15) / 8))
    
    // === 5. GAP SCORE: Directional alignment ===
    float pmGapScoreVal = 50.0
    if not na(pmGapNormalized)
        gapMagnitude = math.abs(pmGapNormalized)
        if pbIsBullish
            pmGapScoreVal := pmGapNormalized > 0 ? math.min(100, 50 + gapMagnitude * 35) : math.max(0, 50 - gapMagnitude * 35)
        else if pbIsBearish
            pmGapScoreVal := pmGapNormalized < 0 ? math.min(100, 50 + gapMagnitude * 35) : math.max(0, 50 - gapMagnitude * 35)
    
    // === 6. VWAP SCORE: Structural alignment ===
    float pmVwapScoreVal = 50.0
    if usePMvwap and not na(pmSessionVWAP) and atr > 0
        vwapDist = close - pmSessionVWAP
        vwapDistATR = vwapDist / atr
        if pbIsBullish
            pmVwapScoreVal := vwapDist > 0 ? math.min(100, 60 + math.abs(vwapDistATR) * 20) : math.max(20, 50 - math.abs(vwapDistATR) * 25)
        else if pbIsBearish
            pmVwapScoreVal := vwapDist < 0 ? math.min(100, 60 + math.abs(vwapDistATR) * 20) : math.max(20, 50 - math.abs(vwapDistATR) * 25)
    
    // === COMPOSITE SCORE (weighted) ===
    rawPMscore = (pmPowerScore * 0.30) + (pmBiasScore * 0.25) + (pmProxScore * 0.15) + (pmTimeScore * 0.10) + (pmGapScoreVal * 0.10) + (pmVwapScoreVal * 0.10)
    rawPMscore := rawPMscore * pmBiasMultiplier
    pmFinalScore := math.round(math.max(0, math.min(100, rawPMscore)))
    
    // === QUALIFICATION FOR PM GRADE BOOST ===
    // For ORB breakouts we only care that:
    //  - PM module is valid
    //  - we're in the signal window
    //  - PM bias aligns with trade direction
    pmQualifiedLong := pmValid and isSignalWindow and pmBiasZone == "long_bias"
    pmQualifiedShort := pmValid and isSignalWindow and pmBiasZone == "short_bias"
else
    pmFinalScore := 0
    pmBiasZone := "disabled"
    pmQualifiedLong := false
    pmQualifiedShort := false

// === ADAPTIVE VOLATILITY ENGINE ===
bool newDay = ta.change(time("D")) != 0
bool isORBwindow = not na(time(timeframe.period, "0930-1000"))

float orbATR_fast = ta.atr(fastAtrLength)
float orbATR_slow = ta.sma(orbATR_fast, 10)
orbATR_slow := na(orbATR_slow) ? orbATR_fast : orbATR_slow

var float orbSessionBaseline = na
if newDay
    orbSessionBaseline := na
if isORBwindow
    orbSessionBaseline := na(orbSessionBaseline) ? orbATR_slow : 0.9 * orbSessionBaseline + 0.1 * orbATR_slow

float sessionVF = not na(orbSessionBaseline) and orbSessionBaseline > 0 ? orbATR_fast / orbSessionBaseline : 1.0

float dailyATR = request.security(syminfo.tickerid, "D", ta.atr(14))
float dailyATRslow = request.security(syminfo.tickerid, "D", ta.sma(ta.atr(14), 20))
float htfVF = not na(dailyATRslow) and dailyATRslow > 0 ? dailyATR / dailyATRslow : 1.0

float volFactor = sessionVF * htfVF

string volState = "NORMAL"
if volFactor < lowVolThresholdEff
    volState := "LOW"
else if volFactor >= extremeVolThresholdEff
    volState := "EXTREME"
else if volFactor >= highVolThresholdEff
    volState := "HIGH"

ema9 = ta.ema(close, emaPeriod)
ema20 = ta.ema(close, ema20Period)

vwapValue := ta.vwap(hlc3)

plot(plotEma and not skipVisuals ? ema9 : na, title="9 EMA", color=emaColor, linewidth=emaWidth, style=plot.style_line)
plot(useEmaCrossExit920 and not useEmaCrossExit and not skipVisuals ? ema20 : na, title="20 EMA", color=color.new(emaColor, 50), linewidth=emaWidth-1, style=plot.style_line)

// =============================================
// === POSITION TRACKING (SIMPLIFIED) ===
// =============================================

if strategy.position_size > 0
    inLongTrade := true
    inShortTrade := false
else if strategy.position_size < 0
    inLongTrade := false
    inShortTrade := true
else
    inLongTrade := false
    inShortTrade := false

exitedLong = strategy.position_size[1] > 0 and strategy.position_size == 0
exitedShort = strategy.position_size[1] < 0 and strategy.position_size == 0

inAnyPosition := strategy.position_size != 0

// =============================================
// === SIMPLIFIED FILL TRACKING ===
// === (NO stop recalculation - just track entry price)
// =============================================

if inLongTrade and strategy.position_size > strategy.position_size[1]
    longEntryPrice := strategy.position_avg_price
    longEntryQuantity := strategy.position_size
    // NO recalculation - use the stop that was set at signal time
    longStopMovedToBreakEven := false
    longTrailingStopActivated := false
    longTrailingStopLevel := na

if inShortTrade and strategy.position_size < strategy.position_size[1]
    shortEntryPrice := strategy.position_avg_price
    shortEntryQuantity := math.abs(strategy.position_size)
    // NO recalculation - use the stop that was set at signal time
    shortStopMovedToBreakEven := false
    shortTrailingStopActivated := false
    shortTrailingStopLevel := na

// ===============================
// === SESSION MANAGEMENT ===
// ===============================

if isNewSession
    sessionHigh := high
    sessionLow := low
    sessionStartBar := bar_index
    sessionStartTime := timestamp("America/New_York", year(timenow), month(timenow), dayofmonth(timenow), hour(timenow), minute(timenow))
    highestLongScore := 0
    highestShortScore := 0
    bullQQEIncreasingCount := 0
    bearQQEIncreasingCount := 0
    prevBullSignalStrength := 0.0
    prevBearSignalStrength := 0.0
    barsAfterSession := 0
    lastTriggerBar := 0
    barsSinceLastTrigger := minBarsBetweenTriggers
    retroORBCalculated := false
    
    hasBrokenOutHigh := false
    hasBrokenOutLow := false
    
    lastAlertBar := -1
    alertCooldownActive := false
    
    if not na(highLine)
        line.delete(highLine)
    if not na(lowLine)
        line.delete(lowLine)
        
    if array.size(triggerLabels) > 0
        for i = 0 to array.size(triggerLabels) - 1
            lbl = array.get(triggerLabels, i)
            label.delete(lbl)
        array.clear(triggerLabels)
        
    if not na(longStopLine)
        line.delete(longStopLine)
        longStopLine := na
    if not na(longProfitTargetLine)
        line.delete(longProfitTargetLine)
        longProfitTargetLine := na
    if not na(longTrailingStopLine)
        line.delete(longTrailingStopLine)
        longTrailingStopLine := na
    if not na(shortStopLine)
        line.delete(shortStopLine)
        shortStopLine := na
    if not na(shortProfitTargetLine)
        line.delete(shortProfitTargetLine)
        shortProfitTargetLine := na
    if not na(shortTrailingStopLine)
        line.delete(shortTrailingStopLine)
        shortTrailingStopLine := na
        
    if strategy.position_size == 0
        inLongTrade := false
        inShortTrade := false
        longEntryPrice := na
        shortEntryPrice := na
        longInitialStop := na
        shortInitialStop := na
        longStopMovedToBreakEven := false
        shortStopMovedToBreakEven := false
        longBarsUnderEma := 0
        shortBarsOverEma := 0
        longTrailingStopActivated := false
        shortTrailingStopActivated := false
        longTrailingStopLevel := na
        shortTrailingStopLevel := na
        longEntryQuantity := 0.0
        shortEntryQuantity := 0.0
        longProfitTargetPrice := na
        shortProfitTargetPrice := na

    if not skipVisuals    
        sessionBox := box.new(sessionStartBar, sessionHigh, bar_index, sessionLow, border_width=0, bgcolor=color.new(color.yellow, 80))
        highLine := line.new(sessionStartBar, sessionHigh, bar_index, sessionHigh, color=color.green, style=line.style_solid, width=2)
        lowLine := line.new(sessionStartBar, sessionLow, bar_index, sessionLow, color=color.red, style=line.style_solid, width=2)

if inSession and not isNewSession
    sessionHigh := math.max(sessionHigh, high)
    sessionLow := math.min(sessionLow, low)

// Retroactive ORB calculation
if not inSession and na(sessionHigh) and na(sessionLow) and not retroORBCalculated
    currentDay = dayofmonth(time)
    currentMonth = month(time)
    currentYear = year(time)
    
    float foundHigh = na
    float foundLow = na
    int foundStartBar = na
    
    for i = 1 to 100
        if bar_index - i < 0
            break
        barTime = time[i]
        barDay = dayofmonth(barTime)
        barMonth = month(barTime)
        barYear = year(barTime)
        
        if barDay == currentDay and barMonth == currentMonth and barYear == currentYear
            barHour = hour(barTime, "America/New_York")
            barMinute = minute(barTime, "America/New_York")
            barTimeMinutes = barHour * 60 + barMinute
            isORBBar = barTimeMinutes >= 570 and barTimeMinutes < 575
            
            if isORBBar
                if na(foundHigh)
                    foundHigh := high[i]
                    foundLow := low[i]
                    foundStartBar := bar_index - i
                else
                    foundHigh := math.max(foundHigh, high[i])
                    foundLow := math.min(foundLow, low[i])
    
    if not na(foundHigh) and not na(foundLow)
        sessionHigh := foundHigh
        sessionLow := foundLow
        sessionStartBar := foundStartBar
        retroORBCalculated := true
        lastTriggerBar := 0
        barsSinceLastTrigger := minBarsBetweenTriggers
        
        if not skipVisuals
            if not na(highLine)
                line.delete(highLine)
            if not na(lowLine)
                line.delete(lowLine)
            highLine := line.new(sessionStartBar, sessionHigh, bar_index, sessionHigh, extend=extend.right, color=color.new(color.green, 0), style=line.style_solid, width=2)
            lowLine := line.new(sessionStartBar, sessionLow, bar_index, sessionLow, extend=extend.right, color=color.new(color.red, 0), style=line.style_solid, width=2)

if not skipVisuals and not na(sessionBox) and (inSession or bar_index <= sessionStartBar + extendLines)
    box.set_top(sessionBox, sessionHigh)
    box.set_bottom(sessionBox, sessionLow)
    box.set_right(sessionBox, bar_index)
    
    if not na(highLine)
        line.set_y1(highLine, sessionHigh)
        line.set_y2(highLine, sessionHigh)
        line.set_x2(highLine, bar_index)
    if not na(lowLine)
        line.set_y1(lowLine, sessionLow)
        line.set_y2(lowLine, sessionLow)
        line.set_x2(lowLine, bar_index)

barsSinceLastTrigger := barsSinceLastTrigger + 1

if enableAlertCooldown and lastAlertBar >= 0
    alertCooldownActive := (bar_index - lastAlertBar) < alertCooldownBars
else
    alertCooldownActive := false

// ==============================
// === INDICATOR CALCULATIONS ===
// ==============================

bool orbComplete = not inSession and not na(sessionHigh) and not na(sessionLow)

if requireOpenInRange
    baseBreakoutHigh := orbComplete and open <= sessionHigh and open >= sessionLow and close > sessionHigh
    baseBreakoutLow := orbComplete and open <= sessionHigh and open >= sessionLow and close < sessionLow
else
    baseBreakoutHigh := orbComplete and close > sessionHigh
    baseBreakoutLow := orbComplete and close < sessionLow

breakoutThreshold = atr * breakoutThresholdMultiplier
sufficientBreakoutHigh = close > sessionHigh + breakoutThreshold
sufficientBreakoutLow = close < sessionLow - breakoutThreshold

candleBody = math.abs(close - open)
candleRange = high - low
bodyStrengthRatio = candleRange > 0 ? candleBody / candleRange : 0
strongCandleBody = bodyStrengthRatio >= minBodyStrengthRatio

if orbComplete
    if hasBrokenOutHigh and close <= sessionHigh
        hasBrokenOutHigh := false
    if hasBrokenOutLow and close >= sessionLow
        hasBrokenOutLow := false

if exitedLong and close <= sessionHigh
    hasBrokenOutHigh := false

if exitedShort and close >= sessionLow
    hasBrokenOutLow := false

// SSL HYBRID ANALYSIS
sslBaseline = ta.hma(close, sslBaselineLengthEff)
sslUp = ma(high, sslLengthEff, sslType)
sslDown = ma(low, sslLengthEff, sslType)

var int sslDirection = 0
sslDirection := close > sslUp ? 1 : close < sslDown ? -1 : sslDirection

sslBullConfirmation := close > sslBaseline
sslBearConfirmation := close < sslBaseline

// SSL Gap Widening Detection (Acceleration Filter)
float sslGapBull = close - sslBaseline
float sslGapBullPrev = close[1] - sslBaseline[1]
float sslGapBear = sslBaseline - close
float sslGapBearPrev = sslBaseline[1] - close[1]

// Is gap widening?
bool sslAccelBull = nz(sslGapBull) > nz(sslGapBullPrev)
bool sslAccelBear = nz(sslGapBear) > nz(sslGapBearPrev)

// SSL Score with Acceleration Filter
var float sslScoreBull = 0.0
var float sslScoreBear = 0.0
sslScoreBull := 0.0
sslScoreBear := 0.0

if useSSLMomentumFilter
    if sslBullConfirmation and sslAccelBull
        sslScoreBull := 1.0
    if sslBearConfirmation and sslAccelBear
        sslScoreBear := 1.0
else
    sslScoreBull := sslBullConfirmation ? 1.0 : 0.0
    sslScoreBear := sslBearConfirmation ? 1.0 : 0.0

var int sslExitDirection = 0
sslExitDirection := close > sslUp ? 1 : close < sslDown ? -1 : sslExitDirection
sslExitLine = sslExitDirection < 0 ? sslUp : sslDown

// WAE CALCULATION
fastMA = ta.ema(close, waeFastEMAEff)
slowMA = ta.ema(close, waeSlowEMAEff)
macd = fastMA - slowMA
macdPrev = fastMA[1] - slowMA[1]
t1 = (macd - macdPrev) * waeSensitivityEff

basis = ta.sma(close, waeBBLengthEff)
dev = waeBBMultiplier * ta.stdev(close, waeBBLengthEff)
bbUpper = basis + dev
bbLower = basis - dev
explosionLine = bbUpper - bbLower

trendUp = t1 >= 0 ? t1 : 0
trendDown = t1 < 0 ? -1 * t1 : 0

waeBullConfirmation := trendUp > explosionLine
waeBearConfirmation := trendDown > explosionLine

// WAE Acceleration Detection
bool waeAccelBull = trendUp > nz(trendUp[1]) and trendUp > explosionLine
bool waeAccelBear = trendDown > nz(trendDown[1]) and trendDown > explosionLine

// WAE Score with Acceleration Filter
var float waeScoreBull = 0.0
var float waeScoreBear = 0.0
waeScoreBull := 0.0
waeScoreBear := 0.0

if useWAEAcceleration
    if waeBullConfirmation and waeAccelBull
        waeScoreBull := 1.0
    if waeBearConfirmation and waeAccelBear
        waeScoreBear := 1.0
else
    waeScoreBull := waeBullConfirmation ? 1.0 : 0.0
    waeScoreBear := waeBearConfirmation ? 1.0 : 0.0

// QQE CALCULATION
[primaryQQETrendLine, primaryRSI, primaryTrend] = calculateQQE(qqeRSI1LengthEff, qqeRSI1SmoothingEff, qqeFactorPrimary, close)
[secondaryQQETrendLine, secondaryRSI, secondaryTrend] = calculateQQE(qqeRSI2LengthEff, qqeRSI2SmoothingEff, qqeFactorSecondary, close)

bollingerBasis = ta.sma(primaryQQETrendLine - 50, qqeBBLengthEff)
bollingerDeviation = bollingerMultiplier * ta.stdev(primaryQQETrendLine - 50, qqeBBLengthEff)
bollingerUpper = bollingerBasis + bollingerDeviation
bollingerLower = bollingerBasis - bollingerDeviation

rawQQEBullCondition = secondaryRSI - 50 > thresholdSecondary and primaryRSI - 50 > bollingerUpper
rawQQEBearCondition = secondaryRSI - 50 < -thresholdSecondary and primaryRSI - 50 < bollingerLower

bullSignalStrength = math.min(secondaryRSI - 50 - thresholdSecondary, primaryRSI - 50 - bollingerUpper)
bearSignalStrength = math.min(-thresholdSecondary - (secondaryRSI - 50), bollingerLower - (primaryRSI - 50))

if rawQQEBullCondition
    if bullSignalStrength > prevBullSignalStrength
        bullQQEIncreasingCount := bullQQEIncreasingCount + 1
    else
        bullQQEIncreasingCount := 0
else
    bullQQEIncreasingCount := 0

if rawQQEBearCondition
    if bearSignalStrength > prevBearSignalStrength
        bearQQEIncreasingCount := bearQQEIncreasingCount + 1
    else
        bearQQEIncreasingCount := 0
else
    bearQQEIncreasingCount := 0

prevBullSignalStrength := rawQQEBullCondition ? bullSignalStrength : 0.0
prevBearSignalStrength := rawQQEBearCondition ? bearSignalStrength : 0.0

qqeBullSignal := bullQQEIncreasingCount >= consecutiveIncreasingBars - 1 and rawQQEBullCondition
qqeBearSignal := bearQQEIncreasingCount >= consecutiveIncreasingBars - 1 and rawQQEBearCondition

// QQE Momentum Direction Detection (NA-safe)
// For longs: momentum must be rising (RSI increasing)
// For shorts: momentum must be falling (RSI decreasing)
bool qqeMomentumRising = nz(primaryRSI) > nz(primaryRSI[1])
bool qqeMomentumFalling = nz(primaryRSI) < nz(primaryRSI[1])

// QQE Score with Momentum Direction Filter
var float qqeScoreBull = 0.0
var float qqeScoreBear = 0.0
qqeScoreBull := 0.0
qqeScoreBear := 0.0

if useQQEMomentumFilter
    // Bullish: must be in bullish state AND momentum rising
    if qqeBullSignal and qqeMomentumRising
        qqeScoreBull := 1.0
    // Bearish: must be in bearish state AND momentum falling
    if qqeBearSignal and qqeMomentumFalling
        qqeScoreBear := 1.0
else
    // Original behavior if filter is off
    qqeScoreBull := qqeBullSignal ? 1.0 : 0.0
    qqeScoreBear := qqeBearSignal ? 1.0 : 0.0

// VOLUME ANALYSIS
volAvg = ta.sma(volume, volLookback)
volRatio = volAvg > 0 ? volume / volAvg : 0

volScore := 0.0
if volRatio >= 1.5
    volScore := 1.0
else if volRatio >= 1.0
    volScore := 0.5
else if volRatio >= 0.5
    volScore := 0.25
else
    volScore := 0.0

volBullConfirmation := volScore >= 0.25
volBearConfirmation := volScore >= 0.25

// CONFLUENCE SCORING (using acceleration-filtered scores)
longScore := (baseBreakoutHigh ? 1 : 0) + 
             (enableSSL ? int(sslScoreBull) : 0) + 
             (enableWAE ? int(waeScoreBull) : 0) + 
             (enableQQE ? int(qqeScoreBull) : 0) + 
             (enableVolume ? int(math.round(volScore)) : 0)

shortScore := (baseBreakoutLow ? 1 : 0) + 
              (enableSSL ? int(sslScoreBear) : 0) + 
              (enableWAE ? int(waeScoreBear) : 0) + 
              (enableQQE ? int(qqeScoreBear) : 0) + 
              (enableVolume ? int(math.round(volScore)) : 0)

hasLongConfluence = longScore >= minConfluenceScore
hasShortConfluence = shortScore >= minConfluenceScore

meetsLongConditions = baseBreakoutHigh and (not enableConfluenceScore or hasLongConfluence)
meetsShortConditions = baseBreakoutLow and (not enableConfluenceScore or hasShortConfluence)

canTriggerAgain = allowRepeatedTriggers and barsSinceLastTrigger >= minBarsBetweenTriggers

breakoutConditionHigh = meetsLongConditions and canTriggerAgain and not hasBrokenOutHigh and sufficientBreakoutHigh and strongCandleBody
breakoutConditionLow = meetsShortConditions and canTriggerAgain and not hasBrokenOutLow and sufficientBreakoutLow and strongCandleBody

if breakoutConditionHigh and barstate.isconfirmed
    hasBrokenOutHigh := true
if breakoutConditionLow and barstate.isconfirmed
    hasBrokenOutLow := true

// ============================
// === TRADE MANAGEMENT ===
// ============================

if inLongTrade and not longStopMovedToBreakEven and not na(longInitialStop)
    strategy.exit("Long SL", "Long", stop=longInitialStop, comment="Stop Loss")

if inShortTrade and not shortStopMovedToBreakEven and not na(shortInitialStop)
    strategy.exit("Short SL", "Short", stop=shortInitialStop, comment="Stop Loss")

// ================================================
// === ENTRY SIGNAL LOGIC ===
// ================================================

regularHours = time(timeframe.period, "0930-1600:1234567", "America/New_York")
inRegularHours = not na(regularHours)

bool canTakeTrades = not inAnyPosition and validTradingDay and inRegularHours
bool withinTradingHours = true
if limitTradingTime
    firstHourWindow = time(timeframe.period, "0930-1030:1234567", "America/New_York")
    withinTradingHours := not na(firstHourWindow)

// Raw breakout logic
bool rawLongSignal = canTakeTrades and withinTradingHours and breakoutConditionHigh and enableLongEntries
bool rawShortSignal = canTakeTrades and withinTradingHours and breakoutConditionLow and enableShortEntries

// CONFIRMED signal
longSignal := rawLongSignal and barstate.isconfirmed
shortSignal := rawShortSignal and barstate.isconfirmed

// First occurrence
bool newLongSignal = longSignal and not longSignal[1]
bool newShortSignal = shortSignal and not shortSignal[1]

// Apply cooldown
if enableAlertCooldown
    newLongSignal := newLongSignal and not alertCooldownActive
    newShortSignal := newShortSignal and not alertCooldownActive

// ================================================
// === LONG ENTRY BLOCK (v66 SURGICAL FIX) ===
// ================================================

if barstate.isconfirmed and newLongSignal
    frozenLongScore := longScore
    
    float stopPrice = na
    string stopType = stopLossType
    float finalRR = profitTargetRR
    
    float rrDesired = profitTargetRR
    if useAdaptiveVolatility
        if volState == "LOW"
            rrDesired := profitTargetRR + 0.5
        else if volState == "HIGH"
            rrDesired := math.max(profitTargetRR - 0.5, 1.2)
        else if volState == "EXTREME"
            rrDesired := math.max(profitTargetRR - 0.8, 1.0)
    
    [selStop, selType, selRR, atrRR, swingRR, vwapRR, hybridRR] = evaluateBestStop(true, close, atr, rrDesired)
    
    if autoSelectStop
        stopPrice := selStop
        stopType := selType
        finalRR := selRR
    else
        if stopLossType == "ATR"
            stopPrice := close - (atr * atrMultiplier)
            stopType := "ATR"
            finalRR := atrRR
        else if stopLossType == "Swing"
            float swingLow = findSwingLowRegularHours(swingLookback)
            stopPrice := swingLow - (atr * swingBuffer)
            stopPrice := math.min(stopPrice, close - 0.01)
            stopType := "Swing"
            finalRR := swingRR
        else if stopLossType == "VWAP"
            stopPrice := vwapValue - (atr * vwapStopDistance)
            stopPrice := math.min(stopPrice, close - 0.01)
            stopType := "VWAP"
            finalRR := vwapRR
        else if stopLossType == "Hybrid"
            float atrStopL = close - (atr * atrMultiplier)
            float swingLowH = findSwingLowRegularHours(swingLookback)
            float swingStopL = swingLowH - (atr * swingBuffer)
            swingStopL := math.min(swingStopL, close - 0.01)
            float vwapStopL = vwapValue - (atr * vwapStopDistance)
            vwapStopL := math.min(vwapStopL, close - 0.01)
            stopPrice := hybridExcludeVwap ? math.max(atrStopL, swingStopL) : math.max(atrStopL, math.max(swingStopL, vwapStopL))
            stopType := "Hybrid"
            finalRR := hybridRR
        else
            stopPrice := close - manualStopPoints
            stopType := "Manual"
            float riskAmt = math.abs(close - stopPrice)
            float targetATRs = riskAmt > 0 ? (riskAmt * rrDesired) / atr : 0
            finalRR := targetATRs <= maxTargetATR ? rrDesired : (maxTargetATR * atr) / riskAmt
    
    float frozenStop = stopPrice
    float frozenRR = finalRR
    
    // === THE GATE ===
    bool tradeFeasibleLong = finalRR >= minAcceptableRR
    
    if tradeFeasibleLong
        float entryPrice = close
        float posSize = calcPositionSize(entryPrice, stopPrice)
        float riskPerShare = math.abs(entryPrice - stopPrice)
        float targetPrice = entryPrice + (riskPerShare * finalRR)
        
        string tradeGrade = finalRR >= 2.5 ? "A" : finalRR >= 2.0 ? "B" : finalRR >= 1.5 ? "C" : "D"

        bool pmBoostApplied = false
        if enablePMmodule and pmFinalScore >= minPMscore and pmQualifiedLong
            if tradeGrade == "B"
                tradeGrade := "A"
                pmBoostApplied := true
            else if tradeGrade == "C"
                tradeGrade := "B"
                pmBoostApplied := true
        color gradeColor = f_trafficLightColor(frozenLongScore, tradeGrade, volState)
        
        float swingLowVal = findSwingLowRegularHours(swingLookback)
        
        tradeCounter += 1
        string tradeId = syminfo.ticker + "_" + str.tostring(tradeCounter)
        
        longPlannedEntry := entryPrice
        longPlannedStop := stopPrice
        longProfitTargetPrice := targetPrice
        longInitialStop := stopPrice
        lastRRUsed := finalRR
        lastVolState := volState
        lastStopTypeUsed := stopType
        entryBar := bar_index
        
        string symtf = syminfo.ticker + " " + timeframe.period
        string alertMsg = "ORB|" + symtf + " | LONG"
        alertMsg += " | EstEntry=" + str.tostring(entryPrice, "#.##")
        alertMsg += " | EstStop=" + str.tostring(stopPrice, "#.##")
        alertMsg += " | Target=" + str.tostring(targetPrice, "#.##")
        alertMsg += " | Shares=" + str.tostring(posSize, "#")
        alertMsg += " | StopType=" + stopType
        alertMsg += " | ATR=" + str.tostring(atr, "#.####")
        alertMsg += " | ATRMult=" + str.tostring(atrMultiplier, "#.#")
        alertMsg += " | SwingLevel=" + str.tostring(swingLowVal, "#.##")
        alertMsg += " | SwingBuffer=" + str.tostring(swingBuffer, "#.##")
        alertMsg += " | VWAP=" + str.tostring(vwapValue, "#.##")
        alertMsg += " | VWAPDist=" + str.tostring(vwapStopDistance, "#.#")
        alertMsg += " | ManualPts=" + str.tostring(manualStopPoints, "#.##")
        alertMsg += " | HybridExclVWAP=" + str.tostring(hybridExcludeVwap ? 1 : 0)
        alertMsg += " | TradeID=" + tradeId
        alertMsg += " | RRUsed=" + str.tostring(finalRR, "#.##")
        alertMsg += " | MinRR=" + str.tostring(minAcceptableRR, "#.#")
        alertMsg += " | VolState=" + volState
        alertMsg += " | UScore=" + str.tostring(math.round(frozenLongScore * 25), "#")
        alertMsg += " | UGrade=" + tradeGrade
        alertMsg += " | PMscore=" + str.tostring(pmFinalScore, "#")
        alertMsg += " | PMboost=" + (pmBoostApplied ? "Y" : "N")
        alertMsg += " | CandleTime=" + str.format("{0,date,yyyy-MM-dd HH:mm}", time_close)
        
        if showEntryLabels and not skipVisuals
            string labelText = "▲ LONG @ " + str.tostring(entryPrice, "#.##") + " [" + volState + "]"
            labelText += "\n" + str.tostring(int(posSize)) + " shares | " + stopType + " Stop: " + str.tostring(stopPrice, "#.##")
            labelText += "\n" + str.tostring(finalRR, "#.##") + ":1 (" + tradeGrade + ") [min:" + str.tostring(minAcceptableRR, "#.#") + "]"
            if pmBoostApplied
                labelText += " [PM+" + str.tostring(pmFinalScore, "#") + "]"
            color textCol = gradeColor == color.new(#00FF00, 0) ? color.black : color.white
            label.new(bar_index, high + (atr * 1.5), labelText, color=gradeColor, style=label.style_label_down, textcolor=textCol, size=size.normal)
        
        alert(alertMsg, alert.freq_once_per_bar_close)
        strategy.entry("Long", strategy.long, qty=posSize, comment="ORB Long")
        
        if showRiskLines and not skipVisuals
            longStopLine := line.new(bar_index, frozenStop, bar_index + lineExtendRight, frozenStop, color=color.red, style=line.style_dashed, width=2)
            longProfitTargetLine := line.new(bar_index, targetPrice, bar_index + lineExtendRight, targetPrice, color=color.green, style=line.style_dashed, width=2)
        
        longStopMovedToBreakEven := false
        longTrailingStopActivated := false
        longTrailingStopLevel := na
        longBarsUnderEma := 0
        lastTriggerBar := bar_index
        barsSinceLastTrigger := 0
        lastAlertBar := bar_index
    
    else
        if showEntryLabels and not skipVisuals
            label.new(bar_index, high + (atr * 1.5), "SKIP: " + str.tostring(finalRR, "#.##") + ":1 < " + str.tostring(minAcceptableRR, "#.#") + " min", color=color.gray, style=label.style_label_down, textcolor=color.white, size=size.small)

// ================================================
// === SHORT ENTRY BLOCK (v66 SURGICAL FIX) ===
// ================================================

if barstate.isconfirmed and newShortSignal
    frozenShortScore := shortScore
    
    float stopPrice = na
    string stopType = stopLossType
    float finalRR = profitTargetRR
    
    float rrDesired = profitTargetRR
    if useAdaptiveVolatility
        if volState == "LOW"
            rrDesired := profitTargetRR + 0.5
        else if volState == "HIGH"
            rrDesired := math.max(profitTargetRR - 0.5, 1.2)
        else if volState == "EXTREME"
            rrDesired := math.max(profitTargetRR - 0.8, 1.0)
    
    [selStop, selType, selRR, atrRR, swingRR, vwapRR, hybridRR] = evaluateBestStop(false, close, atr, rrDesired)
    
    if autoSelectStop
        stopPrice := selStop
        stopType := selType
        finalRR := selRR
    else
        if stopLossType == "ATR"
            stopPrice := close + (atr * atrMultiplier)
            stopType := "ATR"
            finalRR := atrRR
        else if stopLossType == "Swing"
            float swingHigh = findSwingHighRegularHours(swingLookback)
            stopPrice := swingHigh + (atr * swingBuffer)
            stopPrice := math.max(stopPrice, close + 0.01)
            stopType := "Swing"
            finalRR := swingRR
        else if stopLossType == "VWAP"
            stopPrice := vwapValue + (atr * vwapStopDistance)
            stopPrice := math.max(stopPrice, close + 0.01)
            stopType := "VWAP"
            finalRR := vwapRR
        else if stopLossType == "Hybrid"
            float atrStopS = close + (atr * atrMultiplier)
            float swingHighH = findSwingHighRegularHours(swingLookback)
            float swingStopS = swingHighH + (atr * swingBuffer)
            swingStopS := math.max(swingStopS, close + 0.01)
            float vwapStopS = vwapValue + (atr * vwapStopDistance)
            vwapStopS := math.max(vwapStopS, close + 0.01)
            stopPrice := hybridExcludeVwap ? math.min(atrStopS, swingStopS) : math.min(atrStopS, math.min(swingStopS, vwapStopS))
            stopType := "Hybrid"
            finalRR := hybridRR
        else
            stopPrice := close + manualStopPoints
            stopType := "Manual"
            float riskAmt = math.abs(close - stopPrice)
            float targetATRs = riskAmt > 0 ? (riskAmt * rrDesired) / atr : 0
            finalRR := targetATRs <= maxTargetATR ? rrDesired : (maxTargetATR * atr) / riskAmt
    
    float frozenStop = stopPrice
    float frozenRR = finalRR
    
    // === THE GATE ===
    bool tradeFeasibleShort = finalRR >= minAcceptableRR
    
    if tradeFeasibleShort
        float entryPrice = close
        float posSize = calcPositionSize(entryPrice, stopPrice)
        float riskPerShare = math.abs(entryPrice - stopPrice)
        float targetPrice = entryPrice - (riskPerShare * finalRR)

        string tradeGrade = finalRR >= 2.5 ? "A" : finalRR >= 2.0 ? "B" : finalRR >= 1.5 ? "C" : "D"

        bool pmBoostApplied = false
        if enablePMmodule and pmFinalScore >= minPMscore and pmQualifiedShort
            if tradeGrade == "B"
                tradeGrade := "A"
                pmBoostApplied := true
            else if tradeGrade == "C"
                tradeGrade := "B"
                pmBoostApplied := true
        color gradeColor = f_trafficLightColor(frozenShortScore, tradeGrade, volState)

        float swingHighVal = findSwingHighRegularHours(swingLookback)

        tradeCounter += 1
        string tradeId = syminfo.ticker + "_" + str.tostring(tradeCounter)

        shortPlannedEntry := entryPrice
        shortPlannedStop := stopPrice
        shortProfitTargetPrice := targetPrice
        shortInitialStop := stopPrice
        lastRRUsed := finalRR
        lastVolState := volState
        lastStopTypeUsed := stopType
        entryBar := bar_index

        string symtf = syminfo.ticker + " " + timeframe.period
        string alertMsg = "ORB|" + symtf + " | SHORT"
        alertMsg += " | EstEntry=" + str.tostring(entryPrice, "#.##")
        alertMsg += " | EstStop=" + str.tostring(stopPrice, "#.##")
        alertMsg += " | Target=" + str.tostring(targetPrice, "#.##")
        alertMsg += " | Shares=" + str.tostring(posSize, "#")
        alertMsg += " | StopType=" + stopType
        alertMsg += " | ATR=" + str.tostring(atr, "#.####")
        alertMsg += " | ATRMult=" + str.tostring(atrMultiplier, "#.#")
        alertMsg += " | SwingLevel=" + str.tostring(swingHighVal, "#.##")
        alertMsg += " | SwingBuffer=" + str.tostring(swingBuffer, "#.##")
        alertMsg += " | VWAP=" + str.tostring(vwapValue, "#.##")
        alertMsg += " | VWAPDist=" + str.tostring(vwapStopDistance, "#.#")
        alertMsg += " | ManualPts=" + str.tostring(manualStopPoints, "#.##")
        alertMsg += " | HybridExclVWAP=" + str.tostring(hybridExcludeVwap ? 1 : 0)
        alertMsg += " | TradeID=" + tradeId
        alertMsg += " | RRUsed=" + str.tostring(finalRR, "#.##")
        alertMsg += " | MinRR=" + str.tostring(minAcceptableRR, "#.#")
        alertMsg += " | VolState=" + volState
        alertMsg += " | UScore=" + str.tostring(math.round(frozenShortScore * 25), "#")
        alertMsg += " | UGrade=" + tradeGrade
        alertMsg += " | PMscore=" + str.tostring(pmFinalScore, "#")
        alertMsg += " | PMboost=" + (pmBoostApplied ? "Y" : "N")
        alertMsg += " | CandleTime=" + str.format("{0,date,yyyy-MM-dd HH:mm}", time_close)

        if showEntryLabels and not skipVisuals
            string labelText = "▼ SHORT @ " + str.tostring(entryPrice, "#.##") + " [" + volState + "]"
            labelText += "\n" + str.tostring(int(posSize)) + " shares | " + stopType + " Stop: " + str.tostring(stopPrice, "#.##")
            labelText += "\n" + str.tostring(finalRR, "#.##") + ":1 (" + tradeGrade + ") [min:" + str.tostring(minAcceptableRR, "#.#") + "]"
            if pmBoostApplied
                labelText += " [PM+" + str.tostring(pmFinalScore, "#") + "]"
            color textCol = gradeColor == color.new(#00FF00, 0) ? color.black : color.white
            label.new(bar_index, low - (atr * 1.5), labelText, color=gradeColor, style=label.style_label_up, textcolor=textCol, size=size.normal)

        alert(alertMsg, alert.freq_once_per_bar_close)
        strategy.entry("Short", strategy.short, qty=posSize, comment="ORB Short")
        
        if showRiskLines and not skipVisuals
            shortStopLine := line.new(bar_index, frozenStop, bar_index + lineExtendRight, frozenStop, color=color.red, style=line.style_dashed, width=2)
            shortProfitTargetLine := line.new(bar_index, targetPrice, bar_index + lineExtendRight, targetPrice, color=color.green, style=line.style_dashed, width=2)
        
        shortStopMovedToBreakEven := false
        shortTrailingStopActivated := false
        shortTrailingStopLevel := na
        shortBarsOverEma := 0
        lastTriggerBar := bar_index
        barsSinceLastTrigger := 0
        lastAlertBar := bar_index
    
    else
        if showEntryLabels and not skipVisuals
            label.new(bar_index, low - (atr * 1.5), "SKIP: " + str.tostring(finalRR, "#.##") + ":1 < " + str.tostring(minAcceptableRR, "#.#") + " min", color=color.gray, style=label.style_label_up, textcolor=color.white, size=size.small)

// ============================
// === BREAK EVEN / EXITS ===
// ============================

if inLongTrade and not longStopMovedToBreakEven and not na(longEntryPrice) and not na(longInitialStop) and useBreakEven
    float breakEvenTarget = longEntryPrice + (math.abs(longEntryPrice - longInitialStop) * breakEvenRR)
    if close >= breakEvenTarget
        longStopMovedToBreakEven := true
        if showEntryLabels and not skipVisuals
            label.new(bar_index, high, "BE", color=color.new(color.purple, 50), style=label.style_label_down, textcolor=color.white, size=size.small)
        strategy.exit("Long BE", "Long", stop=longEntryPrice, comment="Break Even")

if inShortTrade and not shortStopMovedToBreakEven and not na(shortEntryPrice) and not na(shortInitialStop) and useBreakEven
    float breakEvenTarget = shortEntryPrice - (math.abs(shortEntryPrice - shortInitialStop) * breakEvenRR)
    if close <= breakEvenTarget
        shortStopMovedToBreakEven := true
        if showEntryLabels and not skipVisuals
            label.new(bar_index, low, "BE", color=color.new(color.purple, 50), style=label.style_label_up, textcolor=color.white, size=size.small)
        strategy.exit("Short BE", "Short", stop=shortEntryPrice, comment="Break Even")

// EMA Exit
if inLongTrade and longStopMovedToBreakEven and useEmaCrossExit and close > longEntryPrice
    if close < ema9
        longBarsUnderEma := longBarsUnderEma + 1
    else
        longBarsUnderEma := 0
    if longBarsUnderEma >= emaConfirmationBars
        strategy.close("Long", comment="EMA Exit")

if inShortTrade and shortStopMovedToBreakEven and useEmaCrossExit and close < shortEntryPrice
    if close > ema9
        shortBarsOverEma := shortBarsOverEma + 1
    else
        shortBarsOverEma := 0
    if shortBarsOverEma >= emaConfirmationBars
        strategy.close("Short", comment="EMA Exit")

// 9/20 EMA Cross Exit (alternative)
if inLongTrade and not useEmaCrossExit and useEmaCrossExit920
    if ema9 < ema20
        strategy.close("Long", comment="9/20 EMA Cross")

if inShortTrade and not useEmaCrossExit and useEmaCrossExit920
    if ema9 > ema20
        strategy.close("Short", comment="9/20 EMA Cross")

// ===========================
// === PLOTTING ===
// ===========================

// ===========================
// === PM MODULE PLOTTING ===
// ===========================

// PM Levels (only during RTH)
plot(enablePMmodule and showPMlevels and pmValid and isRTHsession ? pmHighLocked : na, 
     "PM High", color=pmhColor, linewidth=2, style=plot.style_linebr)
plot(enablePMmodule and showPMlevels and pmValid and isRTHsession ? pmLowLocked : na, 
     "PM Low", color=pmlColor, linewidth=2, style=plot.style_linebr)
plot(enablePMmodule and showPMlevels and pmValid and isRTHsession ? pmMidLocked : na, 
     "PM Mid", color=pmMidColor, linewidth=1, style=plot.style_linebr)

// PM Zone fill
pmhPlot = plot(enablePMmodule and showPMzone and pmValid and isRTHsession ? pmHighLocked : na, 
               display=display.none, editable=false)
pmlPlot = plot(enablePMmodule and showPMzone and pmValid and isRTHsession ? pmLowLocked : na, 
               display=display.none, editable=false)
fill(pmhPlot, pmlPlot, color=color.new(color.blue, pmZoneOpacity), title="PM Zone")

// Session VWAP
plot(enablePMmodule and showPMvwap and usePMvwap and isRTHsession ? pmSessionVWAP : na, 
     "Session VWAP", color=pmVwapColor, linewidth=2)

// Gap label at RTH open
if enablePMmodule and showGapLabel and pmRthJustOpened and pmGapRegime != "flat" and not skipVisuals
    gapColor = pmGapRegime == "gap_up" ? color.green : color.red
    gapText = pmGapRegime == "gap_up" ? "GAP ▲" : "GAP ▼"
    if not na(pmGapNormalized)
        gapText := gapText + " " + str.tostring(math.abs(pmGapNormalized), "#.#") + "x ATR"
    label.new(bar_index, pmGapRegime == "gap_up" ? low - atr * 0.5 : high + atr * 0.5, gapText,
              color=color.new(gapColor, 20), textcolor=color.white,
              style=pmGapRegime == "gap_up" ? label.style_label_up : label.style_label_down,
              size=size.small)
plot(enableSSL ? sslBaseline : na, "SSL Baseline", 
     color=close > sslBaseline ? sslBaselineColor : sslBaselineBearColor, 
     linewidth=sslBaselineWidth)

// ===========================
// === CONFLUENCE STATUS TABLE (Bottom Right) ===
// ===========================

// ===========================
// === PM STRUCTURE TABLE (Bottom Center) ===
// ===========================
var table pmTable = table.new(position.bottom_center, 2, 10, bgcolor=color.new(#1E1E1E, 10), border_width=1, border_color=color.new(color.gray, 60))

if enablePMmodule and showPMtable and not skipVisuals and barstate.islast
    row = 0
    // Header
    table.cell(pmTable, 0, row, "PM MODULE", text_color=color.white, text_size=size.normal, bgcolor=color.new(#9C27B0, 50))
    table.cell(pmTable, 1, row, pmValid ? "ACTIVE" : "WAITING", text_color=pmValid ? color.lime : color.yellow, text_size=size.normal, bgcolor=color.new(#9C27B0, 50))
    row += 1
    
    if pmValid
        // PMH
        table.cell(pmTable, 0, row, "PMH", text_color=pmhColor, text_size=size.normal)
        table.cell(pmTable, 1, row, str.tostring(pmHighLocked, format.mintick), text_color=color.white, text_size=size.normal)
        row += 1
        
        // PML
        table.cell(pmTable, 0, row, "PML", text_color=pmlColor, text_size=size.normal)
        table.cell(pmTable, 1, row, str.tostring(pmLowLocked, format.mintick), text_color=color.white, text_size=size.normal)
        row += 1
        
        // Mid
        table.cell(pmTable, 0, row, "Mid", text_color=pmMidColor, text_size=size.normal)
        table.cell(pmTable, 1, row, str.tostring(pmMidLocked, format.mintick), text_color=color.white, text_size=size.normal)
        row += 1
        
        // Gap
        gapClr = pmGapRegime == "gap_up" ? color.lime : pmGapRegime == "gap_down" ? color.red : color.gray
        gapDisplay = switch pmGapRegime
            "gap_up"   => "Gap Up"
            "gap_down" => "Gap Down"
            "flat"     => "Flat"
            => pmGapRegime
        if not na(pmGapNormalized) and pmGapRegime != "flat"
            gapDisplay := gapDisplay + " " + str.tostring(math.abs(pmGapNormalized), "#.#") + "x"
        table.cell(pmTable, 0, row, "Gap", text_color=color.gray, text_size=size.normal)
        table.cell(pmTable, 1, row, gapDisplay, text_color=gapClr, text_size=size.normal)
        row += 1
        
        // Bias Zone
        biasClr = pmBiasZone == "long_bias" ? color.lime : pmBiasZone == "short_bias" ? color.red : color.gray
        table.cell(pmTable, 0, row, "Bias", text_color=color.gray, text_size=size.normal)
        biasDisplay = switch pmBiasZone
            "long_bias"  => "Long Bias"
            "short_bias" => "Short Bias"
            => pmBiasZone
        table.cell(pmTable, 1, row, biasDisplay, text_color=biasClr, text_size=size.normal)
        row += 1
        
        // PM Score
        scoreClr = pmFinalScore >= 70 ? color.lime : pmFinalScore >= 50 ? color.yellow : color.gray
        table.cell(pmTable, 0, row, "Score", text_color=color.gray, text_size=size.normal)
        table.cell(pmTable, 1, row, str.tostring(pmFinalScore, "#"), text_color=scoreClr, text_size=size.normal)
        row += 1
        
        // Power Bar status
        pbStatus = pmIsPowerBarBull ? "BULL PB" : pmIsPowerBarBear ? "BEAR PB" : "—"
        pbClr = pmIsPowerBarBull ? color.lime : pmIsPowerBarBear ? color.red : color.gray
        table.cell(pmTable, 0, row, "PwrBar", text_color=color.gray, text_size=size.normal)
        table.cell(pmTable, 1, row, pbStatus, text_color=pbClr, text_size=size.normal)
        row += 1
        
        // Qualified status
        qualStatus = pmQualifiedLong ? "LONG ✓" : pmQualifiedShort ? "SHORT ✓" : "—"
        qualClr = pmQualifiedLong ? color.lime : pmQualifiedShort ? color.red : color.gray
        table.cell(pmTable, 0, row, "Qual", text_color=color.gray, text_size=size.normal)
        table.cell(pmTable, 1, row, qualStatus, text_color=qualClr, text_size=size.normal)
    else
        // Waiting for PM lock
        table.cell(pmTable, 0, row, "Status", text_color=color.gray, text_size=size.normal)
        statusText = isPMsession ? "Tracking PM" : "Await RTH"
        table.cell(pmTable, 1, row, statusText, text_color=color.yellow, text_size=size.normal)
        row += 1
        
        if not na(pmHigh) and not na(pmLow)
            table.cell(pmTable, 0, row, "PM H/L", text_color=color.gray, text_size=size.normal)
            table.cell(pmTable, 1, row, str.tostring(pmHigh, "#.##") + "/" + str.tostring(pmLow, "#.##"), text_color=color.yellow, text_size=size.normal)

var table infoTable = table.new(position.bottom_right, 5, 6, bgcolor=color.new(color.black, 70), border_width=1, border_color=color.gray)

if not skipVisuals
    if not na(infoTable)
        // Headers
        table.cell(infoTable, 0, 0, "Factor", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
        table.cell(infoTable, 1, 0, "Long", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
        table.cell(infoTable, 2, 0, "Short", bgcolor=color.gray, text_color=color.white, text_size=size.normal)

        // ORB Break
        table.cell(infoTable, 0, 1, "ORB Break", bgcolor=color.new(color.black, 70), text_color=color.white, text_size=size.normal)
        table.cell(infoTable, 1, 1, baseBreakoutHigh ? "✓" : "✗", bgcolor=color.new(color.black, 70), text_color=baseBreakoutHigh ? color.green : color.red, text_size=size.normal)
        table.cell(infoTable, 2, 1, baseBreakoutLow ? "✓" : "✗", bgcolor=color.new(color.black, 70), text_color=baseBreakoutLow ? color.green : color.red, text_size=size.normal)

        // SSL (shows ✓ for accelerating, ◐ for state only, ✗ for neither)
        table.cell(infoTable, 0, 2, "SSL", bgcolor=color.new(color.black, 70), text_color=color.white, text_size=size.normal)
        string sslBullDisplay = sslScoreBull >= 1.0 ? "✓" : (sslBullConfirmation ? "◐" : "✗")
        color sslBullColor = sslScoreBull >= 1.0 ? color.green : (sslBullConfirmation ? color.yellow : color.red)
        table.cell(infoTable, 1, 2, enableSSL ? sslBullDisplay : "–", bgcolor=color.new(color.black, 70), text_color=sslBullColor, text_size=size.normal)
        string sslBearDisplay = sslScoreBear >= 1.0 ? "✓" : (sslBearConfirmation ? "◐" : "✗")
        color sslBearColor = sslScoreBear >= 1.0 ? color.green : (sslBearConfirmation ? color.yellow : color.red)
        table.cell(infoTable, 2, 2, enableSSL ? sslBearDisplay : "–", bgcolor=color.new(color.black, 70), text_color=sslBearColor, text_size=size.normal)

        // WAE (shows ✓ for accelerating, ◐ for state only, ✗ for neither)
        table.cell(infoTable, 0, 3, "WAE", bgcolor=color.new(color.black, 70), text_color=color.white, text_size=size.normal)
        string waeBullDisplay = waeScoreBull >= 1.0 ? "✓" : (waeBullConfirmation ? "◐" : "✗")
        color waeBullColor = waeScoreBull >= 1.0 ? color.green : (waeBullConfirmation ? color.yellow : color.red)
        table.cell(infoTable, 1, 3, enableWAE ? waeBullDisplay : "–", bgcolor=color.new(color.black, 70), text_color=waeBullColor, text_size=size.normal)
        string waeBearDisplay = waeScoreBear >= 1.0 ? "✓" : (waeBearConfirmation ? "◐" : "✗")
        color waeBearColor = waeScoreBear >= 1.0 ? color.green : (waeBearConfirmation ? color.yellow : color.red)
        table.cell(infoTable, 2, 3, enableWAE ? waeBearDisplay : "–", bgcolor=color.new(color.black, 70), text_color=waeBearColor, text_size=size.normal)

        // QQE (shows ✓ for momentum aligned, ◐ for signal only, ✗ for neither)
        table.cell(infoTable, 0, 4, "QQE", bgcolor=color.new(color.black, 70), text_color=color.white, text_size=size.normal)
        string qqeBullDisplay = qqeScoreBull >= 1.0 ? "✓" : (qqeBullSignal ? "◐" : "✗")
        color qqeBullColor = qqeScoreBull >= 1.0 ? color.green : (qqeBullSignal ? color.yellow : color.red)
        table.cell(infoTable, 1, 4, enableQQE ? qqeBullDisplay : "–", bgcolor=color.new(color.black, 70), text_color=qqeBullColor, text_size=size.normal)
        string qqeBearDisplay = qqeScoreBear >= 1.0 ? "✓" : (qqeBearSignal ? "◐" : "✗")
        color qqeBearColor = qqeScoreBear >= 1.0 ? color.green : (qqeBearSignal ? color.yellow : color.red)
        table.cell(infoTable, 2, 4, enableQQE ? qqeBearDisplay : "–", bgcolor=color.new(color.black, 70), text_color=qqeBearColor, text_size=size.normal)

        // Volume
        table.cell(infoTable, 0, 5, "Volume", bgcolor=color.new(color.black, 70), text_color=color.white, text_size=size.normal)
        string volDisplay = volScore >= 1.0 ? "Strong" : volScore >= 0.5 ? "Avg" : volScore >= 0.25 ? "Weak" : "Low"
        color volColor = volScore >= 1.0 ? color.green : volScore >= 0.5 ? color.yellow : color.red
        table.cell(infoTable, 1, 5, enableVolume ? volDisplay : "–", bgcolor=color.new(color.black, 70), text_color=volColor, text_size=size.normal)
        table.cell(infoTable, 2, 5, enableVolume ? volDisplay : "–", bgcolor=color.new(color.black, 70), text_color=volColor, text_size=size.normal)

        // Score column
        table.cell(infoTable, 3, 0, "Score", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
        table.cell(infoTable, 4, 0, str.tostring(minConfluenceScore) + " min", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
        
        int displayScore = math.max(longScore, shortScore)
        string scoreText = str.tostring(displayScore) + "/5"
        table.cell(infoTable, 3, 1, scoreText, bgcolor=color.new(color.black, 70), text_color=color.green, text_size=size.normal)

        // Volatility info
        string vfText = str.tostring(volFactor, "#.##")
        color vfColor = volState == "LOW" ? color.blue : volState == "NORMAL" ? color.green : volState == "HIGH" ? color.orange : color.red
        table.cell(infoTable, 4, 3, "VF: " + vfText + " [" + volState + "]", bgcolor=color.new(color.black, 70), text_color=vfColor, text_size=size.normal)
        
        // ATR
        table.cell(infoTable, 3, 2, "", bgcolor=color.new(color.black, 70), text_color=color.white, text_size=size.normal)
        table.cell(infoTable, 4, 2, "ATR: " + str.tostring(atr, "#.##"), bgcolor=color.new(color.black, 70), text_color=color.white, text_size=size.normal)

        // Empty cells
        table.cell(infoTable, 3, 3, "", bgcolor=color.new(color.black, 70), text_color=color.white, text_size=size.normal)
        table.cell(infoTable, 3, 4, "", bgcolor=color.new(color.black, 70), text_color=color.white, text_size=size.normal)
        table.cell(infoTable, 4, 4, "", bgcolor=color.new(color.black, 70), text_color=color.white, text_size=size.normal)
        
        // Position status
        table.cell(infoTable, 3, 5, strategy.position_size != 0 ? "IN POSITION" : "NO POSITION", 
             bgcolor=color.new(color.black, 70), text_color=strategy.position_size != 0 ? color.yellow : color.gray, text_size=size.normal)
        table.cell(infoTable, 4, 5, strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "—", 
             bgcolor=color.new(color.black, 70), text_color=strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray, text_size=size.normal)

// ===========================
// === DEBUG TABLE (Top Right) ===
// ===========================

var table killSwitchTable = table.new(position.top_right, 2, 12, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)

if showDebugTable and not skipVisuals
    table.cell(killSwitchTable, 0, 0, "🔧 DEBUG", bgcolor=color.new(color.purple, 50), text_color=color.white, text_size=size.small)
    table.cell(killSwitchTable, 1, 0, "STATUS", bgcolor=color.new(color.purple, 50), text_color=color.white, text_size=size.small)

    table.cell(killSwitchTable, 0, 1, "orbComplete", text_color=color.aqua)
    table.cell(killSwitchTable, 1, 1, orbComplete ? "✓" : "✗", text_color=orbComplete ? color.green : color.red)

    table.cell(killSwitchTable, 0, 2, "inSession", text_color=color.aqua)
    table.cell(killSwitchTable, 1, 2, inSession ? "IN ORB" : "DONE", text_color=inSession ? color.yellow : color.green)

    table.cell(killSwitchTable, 0, 3, "canTriggerAgain", text_color=color.aqua)
    table.cell(killSwitchTable, 1, 3, canTriggerAgain ? "✓" : "✗", text_color=canTriggerAgain ? color.green : color.red)

    table.cell(killSwitchTable, 0, 4, "hasBrokenOutHigh", text_color=color.aqua)
    table.cell(killSwitchTable, 1, 4, hasBrokenOutHigh ? "LATCH" : "CLR", text_color=hasBrokenOutHigh ? color.red : color.green)

    table.cell(killSwitchTable, 0, 5, "hasBrokenOutLow", text_color=color.aqua)
    table.cell(killSwitchTable, 1, 5, hasBrokenOutLow ? "LATCH" : "CLR", text_color=hasBrokenOutLow ? color.red : color.green)

    table.cell(killSwitchTable, 0, 6, "meetsLongCond", text_color=color.aqua)
    table.cell(killSwitchTable, 1, 6, meetsLongConditions ? "✓" : "✗", text_color=meetsLongConditions ? color.green : color.orange)

    table.cell(killSwitchTable, 0, 7, "meetsShortCond", text_color=color.aqua)
    table.cell(killSwitchTable, 1, 7, meetsShortConditions ? "✓" : "✗", text_color=meetsShortConditions ? color.green : color.orange)

    table.cell(killSwitchTable, 0, 8, "inAnyPosition", text_color=color.aqua)
    table.cell(killSwitchTable, 1, 8, inAnyPosition ? "YES" : "NO", text_color=inAnyPosition ? color.red : color.green)

    table.cell(killSwitchTable, 0, 9, "withinTradingHrs", text_color=color.aqua)
    table.cell(killSwitchTable, 1, 9, withinTradingHours ? "✓" : "✗", text_color=withinTradingHours ? color.green : color.red)

    table.cell(killSwitchTable, 0, 10, "volState", text_color=color.aqua)
    vfColor = volState == "LOW" ? color.blue : volState == "NORMAL" ? color.green : volState == "HIGH" ? color.orange : color.red
    table.cell(killSwitchTable, 1, 10, volState, text_color=vfColor)

    table.cell(killSwitchTable, 0, 11, "minRR", text_color=color.aqua)
    table.cell(killSwitchTable, 1, 11, str.tostring(minAcceptableRR, "#.#"), text_color=color.white)

// ========================================
// PRESET STATUS TABLE (WHAT'S ACTUALLY IN USE)
// ========================================
if showPresetStatus and not skipVisuals
    var table presetTable = table.new(position.middle_right, 2, 8, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)

    // Show PRESET or MANUAL status
    string presetStatusText = hasPreset ? "PRESET" : "MANUAL"
    color presetStatusColor = hasPreset ? color.green : color.orange

    table.cell(presetTable, 0, 0, "PRESET STATUS", bgcolor=color.gray, text_color=color.white, text_size=size.normal, text_halign=text.align_center)
    table.cell(presetTable, 1, 0, autoSymbol + " [" + presetStatusText + "]", bgcolor=presetStatusColor, text_color=color.white, text_size=size.normal, text_halign=text.align_center)
    
    table.cell(presetTable, 0, 1, "SSL Base:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 1, str.tostring(sslBaselineLengthEff), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 2, "SSL Len:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 2, str.tostring(sslLengthEff), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 3, "Exit Len:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 3, str.tostring(exitLengthEff), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 4, "WAE Sens:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 4, str.tostring(waeSensitivityEff), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 5, "Vol Low:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 5, str.tostring(lowVolThresholdEff, "#.##"), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 6, "Vol High:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 6, str.tostring(highVolThresholdEff, "#.##"), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 7, "Mode:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 7, presetComparisonMode ? "COMPARISON" : "PRESET", text_color=presetComparisonMode ? color.orange : color.green, text_size=size.small)
