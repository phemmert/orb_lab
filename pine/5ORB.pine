f_trafficLightColor(int qScore, string rrGrade, string vState) =>
    if qScore >= 4 and (rrGrade == "A" or rrGrade == "B") and (vState == "NORMAL" or vState == "HIGH" or vState == "EXTREME")
        color.new(#00FF00, 0)
    else if qScore >= 3 and (rrGrade == "A" or rrGrade == "B")
        color.new(color.green, 0)
    else if qScore >= 3 and rrGrade == "C" and (vState == "HIGH" or vState == "EXTREME")
        color.new(color.green, 0)
    else if qScore >= minConfluenceScore
        color.new(color.orange, 0)
    else
        color.new(color.red, 0)

