//@version=5
// Version: 65 - SIMPLIFIED ENTRY FLOW
// CHANGES:
// 1. REMOVED: Triangles/visual flags
// 2. REMOVED: Fill-time stop recalculation (stop calculated ONCE at signal)
// 3. REMOVED: C-grade LOW vol filter (only R:R filter remains)
// 4. FIXED: Label + Alert ALWAYS fire together (or neither fires with SKIP label)
// 5. CLEANED: LONG and SHORT blocks are now IDENTICAL structure
strategy("5 ORB Simplified", overlay=true, initial_capital=50000, default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=0)

// ========================================
// PRE-MARKET STRUCTURE MODULE
// ========================================
var grpPMmodule = "══════ Pre-Market Structure ══════"
enablePMmodule      = input.bool(true, "Enable PM Structure Module", group=grpPMmodule, tooltip="Master toggle for pre-market structure analysis")
showPMlevels        = input.bool(true, "Show PM Levels on Chart", group=grpPMmodule)
showPMzone          = input.bool(true, "Show PM Range Zone", group=grpPMmodule)
pmZoneOpacity       = input.int(92, "Zone Transparency", minval=80, maxval=98, group=grpPMmodule)
showPMtable         = input.bool(true, "Show PM Info Table (Bottom Center)", group=grpPMmodule)

var grpPB = "Power Bar Detection"
pbEnabled           = input.bool(true, "Enable Power Bar Detection", group=grpPB)
pbSensATR           = input.float(1.25, "ATR Sensitivity (gate)", minval=0.5, maxval=3.0, step=0.25, group=grpPB)
pbMinBodyPct        = input.float(60, "Min Body % (ranking)", minval=40, maxval=90, step=5, group=grpPB)
pbMinVolRatio       = input.float(0.8, "Min Volume Ratio", minval=0.3, maxval=2.0, step=0.1, group=grpPB)

var grpGap = "Gap Regime"
showGapLabel        = input.bool(true, "Show Gap Label at Open", group=grpGap)
gapThreshATR        = input.float(0.5, "Significant Gap (ATR units)", minval=0.1, maxval=2.0, step=0.1, group=grpGap)

var grpPMvwap = "Session VWAP (PM Module)"
usePMvwap           = input.bool(true, "Enable VWAP Scoring", group=grpPMvwap)
showPMvwap          = input.bool(true, "Show Session VWAP Line", group=grpPMvwap)
pmVwapColor         = input.color(color.new(#9C27B0, 30), "VWAP Color", group=grpPMvwap)

var grpPMscore = "PM Scoring Weights"
minPMscore          = input.int(40, "Min PM Score for Grade Boost", minval=0, maxval=80, group=grpPMscore)

var grpPMcolors = "PM Level Colors"
pmhColor            = input.color(color.new(#2196F3, 0), "PM High", group=grpPMcolors)
pmlColor            = input.color(color.new(#F44336, 0), "PM Low", group=grpPMcolors)
pmMidColor          = input.color(color.new(#9E9E9E, 50), "PM Mid", group=grpPMcolors)
pbBullColor         = input.color(color.new(#00E676, 0), "Bullish Power Bar", group=grpPMcolors)
pbBearColor         = input.color(color.new(#FF5252, 0), "Bearish Power Bar", group=grpPMcolors)


// ========================
// === STRATEGY INPUTS ===
// ========================
// ========================================
// SYMBOL PRESET SETTINGS
// ========================================
var grpPresets = "Symbol Presets"
useSymbolPresets = input.bool(true, "Use Symbol Presets", group=grpPresets, tooltip="If ON: Parameters change based on the symbol")
presetComparisonMode = input.bool(false, "⚡ Comparison Mode (Show Defaults)", group=grpPresets, tooltip="Toggle ON to see chart with INPUT defaults instead of presets")
showPresetStatus = input.bool(true, "Show Preset Status Table", group=grpPresets, tooltip="Display table showing active preset values")
// === Strategy Settings ===
var grpStrat = "Strategy Settings"
enableLongEntries = input.bool(true, title="Enable Long Entries", group=grpStrat)
enableShortEntries = input.bool(true, title="Enable Short Entries", group=grpStrat)
backtestMode = input.bool(false, title="Enable Backtest Mode (Disable Visuals)", group=grpStrat, tooltip="Disables all visual elements for faster backtesting. Only entries/exits will execute.")
showDebugTable = input.bool(true, title="🔧 Show Debug Table (Kill Switch Status)", group=grpStrat, tooltip="Shows which conditions are blocking entries")

// Date range filter
useDateFilter = input.bool(false, title="Use Date Range Filter", group=grpStrat)
fromDate = input.time(timestamp("2020-01-01"), "From Date", group=grpStrat)
toDate = input.time(timestamp("2025-12-31"), "To Date", group=grpStrat)

// === ORB Configuration ===
var grp1 = "ORB Settings"
sessionTime = input.session("0930-0935:1234567", title="Session Time", group=grp1, confirm=true)
extendLines = input.int(60, title="Extend Lines (Minutes)", minval=0, group=grp1)
limitTradingTime = input.bool(true, title="Limit Trading to First Hour (9:30-10:30 AM)", group=grp1, tooltip="When ON: Only trades 9:30-10:30 AM. When OFF: Trades all day 9:30-4:00 PM")

// Repeat Trigger Settings
allowRepeatedTriggers = input.bool(true, title="Allow Repeated Triggers", group=grp1, tooltip="ENABLED for backtesting - disable for live alerts")
minBarsBetweenTriggers = input.int(5, title="Min Bars Between Triggers", minval=1, maxval=50, group=grp1, tooltip="Reduced for backtesting")

// === Alert Control Settings ===
var grpAlerts = "Alert Control Settings"
enableAlertCooldown = input.bool(false, title="Enable Alert Cooldown", group=grpAlerts, tooltip="Prevents rapid-fire alerts - DISABLED for backtesting")
alertCooldownBars = input.int(5, title="Alert Cooldown (Bars)", minval=1, maxval=20, group=grpAlerts)


// === Exit Strategy ===
var grpExits = "Exit Strategy Sequence"
useBreakEven = input.bool(true, title="1. Move to Break Even when target reached", group=grpExits)
breakEvenRR = input.float(0.5, title="   Break Even at R:R", minval=0.1, maxval=2.0, step=0.1, group=grpExits, tooltip="Moves stop to entry price when profit reaches this multiple of initial risk (e.g., 0.5 = half of risk)")

useEmaCrossExit = input.bool(true, title="2. Use EMA Exit after Break Even", group=grpExits, tooltip="When enabled, will exit on EMA cross after break-even is achieved")
emaPeriod = input.int(9, title="   EMA Period", minval=5, maxval=50, group=grpExits)
emaConfirmationBars = input.int(1, title="   Confirmation Bars", minval=0, maxval=5, group=grpExits, tooltip="Number of bars below/above EMA to confirm exit")
emaBodyPercentage = input.float(60.0, title="   Body % Beyond EMA", minval=10.0, maxval=100.0, step=5.0, group=grpExits, tooltip="Percentage of candle body that must be beyond EMA to trigger exit (e.g., 60 = 60% of body beyond EMA)")

// New EMA Cross Exit
useEmaCrossExit920 = input.bool(false, title="Use 9/20 EMA Cross Exit (Alternative)", group=grpExits, tooltip="Exit on 9/20 EMA cross. Only active if 'Use EMA Exit after Break Even' is OFF")
ema20Period = input.int(20, title="   Slow EMA Period", minval=10, maxval=50, group=grpExits)

useTrailingStop = input.bool(true, title="3. Use Trailing Stop at Profit Target", group=grpExits)
profitTargetRR = input.float(2.0, title="   Profit Target R:R", minval=0.5, maxval=10.0, step=0.1, group=grpExits, tooltip="Profit target level and trailing stop activation.")
trailingStopDistance = input.float(1.2, title="   Trailing Stop Distance (ATR Mult)", minval=0.1, maxval=5.0, step=0.05, group=grpExits)

// Advanced Trailing Settings
var grpTrail = "Advanced Trailing Settings"
aggressiveTrailing = input.bool(true, title="Use Aggressive Trailing Near EMA", tooltip="Tightens trailing stop when price approaches EMA", group=grpTrail)
emaTightenZone = input.float(0.3, title="EMA Zone for Tighter Trail (% of ATR)", minval=0.1, maxval=2.0, step=0.05, group=grpTrail)
tightenedTrailDistance = input.float(0.3, title="Tightened Trail Distance (ATR Mult)", minval=0.1, maxval=2.0, step=0.05, group=grpTrail)

// === Breakout Filter Settings ===
var grpBreakout = "Breakout Filter Settings"
requireOpenInRange = input.bool(false, title="Require Open Within Range", group=grpBreakout, tooltip="When enabled, candle must open within the ORB range. When disabled, only close outside range is required.")
breakoutThresholdMultiplier = input.float(0.1, title="Breakout Threshold Multiplier (ATR)", minval=0.0, maxval=1.0, step=0.01, group=grpBreakout, tooltip="Restored to original 0.1 for backtesting")
minBodyStrengthRatio = input.float(0.5, title="Minimum Body Strength Ratio", minval=0.1, maxval=1.0, step=0.1, group=grpBreakout, tooltip="Restored to original 0.5 for backtesting")
min_range = input.float(1.0, title="Minimum ORB Range ($)", minval=0, step=0.1, group=grpBreakout)
max_range = input.float(10.0, title="Maximum ORB Range ($)", minval=0, step=0.1, group=grpBreakout)

// === Confluence Settings ===
var grp3 = "Confluence Settings"
enableConfluenceScore = input.bool(true, title="Enable Confluence Scoring", group=grp3)
minConfluenceScore = input.int(3, title="Minimum Confluence Score", minval=1, maxval=5, group=grp3, tooltip="Max possible: 5 points (ORB + SSL + WAE + QQE + Volume)")

// === SSL HYBRID SETTINGS ===
var grp4 = "SSL Hybrid Settings"
enableSSL = input.bool(true, title="Enable SSL Confirmation", group=grp4)
sslBaselineLength = input.int(45, "Baseline Length", minval=10, maxval=200, group=grp4)
sslType = input.string("JMA", "SSL Type", options=["SMA", "EMA", "HMA", "JMA"], group=grp4)
sslLength = input.int(5, "SSL Length", minval=1, maxval=50, group=grp4)
exitLength = input.int(5, "Exit Length", minval=1, maxval=50, group=grp4, tooltip="SSL Exit channel length (typically same as SSL Length)")
sslBaselineColor = input.color(color.new(color.green, 50), title="SSL Baseline Bull Color", group=grp4)
sslBaselineBearColor = input.color(color.new(color.red, 50), title="SSL Baseline Bear Color", group=grp4)
sslBaselineWidth = input.int(2, title="SSL Baseline Width", minval=1, maxval=4, group=grp4)
showSSLExitLine = input.bool(false, title="Show SSL Exit Lines", group=grp4)
sslExitColor = input.color(color.new(color.yellow, 50), title="SSL Exit Line Color", group=grp4)
sslExitLineWidth = input.int(1, title="SSL Exit Line Width", minval=1, maxval=4, group=grp4)
useSSLMomentumFilter = input.bool(true, "Require SSL Gap Widening", group=grp4, tooltip="Price must accelerate away from baseline. Prevents weak SSL crosses.")

// === WAE SETTINGS ===
var grp4b = "Waddah Attar Explosion Settings"
enableWAE = input.bool(true, title="Enable WAE Confirmation", group=grp4b)
waeSensitivity = input.int(190, "Sensitivity", minval=100, maxval=300, group=grp4b)
waeFastEMA = input.int(20, "Fast EMA", minval=5, maxval=50, group=grp4b)
waeSlowEMA = input.int(40, "Slow EMA", minval=20, maxval=100, group=grp4b)
waeBBLength = input.int(20, "BB Length", minval=10, maxval=50, group=grp4b)
waeBBMultiplier = input.float(2.0, "BB StDev Multiplier", minval=1.0, maxval=3.0, step=0.5, group=grp4b)
useWAEAcceleration = input.bool(true, "Require WAE Acceleration", group=grp4b, tooltip="WAE bars must be growing (accelerating), not dying. Filters out weak/fading momentum.")

// === QQE Settings ===
var grp5 = "QQE Settings"
enableQQE = input.bool(true, title="Enable QQE Confirmation", group=grp5)
qqeRSI1Length = input.int(6, title="Primary RSI Length", minval=2, maxval=30, group=grp5)
qqeRSI1Smoothing = input.int(5, title="Primary RSI Smoothing", minval=2, maxval=30, group=grp5)
qqeFactorPrimary = input.float(3.0, title="Primary QQE Factor", minval=0.5, maxval=10.0, step=0.1, group=grp5)
thresholdPrimary = input.float(3.0, title="Primary Threshold", minval=0.5, maxval=10.0, step=0.1, group=grp5)

qqeRSI2Length = input.int(6, title="Secondary RSI Length", minval=2, maxval=30, group=grp5)
qqeRSI2Smoothing = input.int(5, title="Secondary RSI Smoothing", minval=2, maxval=30, group=grp5)
qqeFactorSecondary = input.float(1.61, title="Secondary QQE Factor", minval=0.5, maxval=10.0, step=0.01, group=grp5)
thresholdSecondary = input.float(3.0, title="Secondary Threshold", minval=0.5, maxval=10.0, step=0.1, group=grp5, tooltip="Restored to original 3.0 for backtesting")

qqeBBLength = input.int(50, title="Bollinger Length", minval=10, maxval=200, group=grp5)
bollingerMultiplier = input.float(0.35, title="Bollinger Multiplier", minval=0.1, maxval=5.0, step=0.05, group=grp5)
consecutiveIncreasingBars = input.int(3, title="QQE Consecutive Increasing Bars", minval=1, maxval=10, group=grp5)
useQQEMomentumFilter = input.bool(true, "Require QQE Momentum Direction", group=grp5, tooltip="Only accept QQE signals when momentum is accelerating in trade direction. Filters out curling/dying momentum.")

// === Volume Settings ===
var grp6 = "Volume Analysis"
enableVolume = input.bool(true, title="Enable Volume Analysis", group=grp6)
volLookback = input.int(5, title="Volume Lookback Period", minval=3, maxval=20, group=grp6)

// === Risk Management ===
var grp8 = "Risk Management"
riskType = input.string("Fixed", "Risk Type", options=["Fixed", "Percentage"], group=grp8)
fixedRiskAmount = input.float(200, "Fixed Risk Amount ($)", minval=50, maxval=5000, step=50, group=grp8)
riskPercent = input.float(1.0, "Risk Percent (%)", minval=0.1, maxval=10.0, step=0.1, group=grp8)
atrPeriod = input.int(14, "ATR Period", minval=1, maxval=100, group=grp8)
atrMultiplier = input.float(2.0, "ATR Stop Loss Multiplier", minval=0.5, maxval=10.0, step=0.1, group=grp8)
showRiskLines = input.bool(true, "Show Risk/Reward Lines", group=grp8)
lineExtendRight = input.int(20, "Extend Lines (Bars Right)", minval=0, maxval=100, group=grp8)

// === Stop Loss Selection Settings ===
var grpStopSelection = "Stop Loss Selection"
stopLossType = input.string("ATR", "Stop Loss Type", options=["ATR", "Swing", "VWAP", "Hybrid", "Manual"], group=grpStopSelection, tooltip="ATR: ATR-based stop\nSwing: Recent swing high/low\nVWAP: VWAP-based stop\nHybrid: Most conservative of all three\nManual: Fixed points from entry")
swingLookback = input.int(5, "Swing Lookback Bars", minval=3, maxval=30, group=grpStopSelection, tooltip="Number of bars to look back for swing highs/lows (only regular trading hours)")
swingBuffer = input.float(0.02, "Swing Buffer (ATR multiplier)", minval=0.0, maxval=1.0, step=0.05, group=grpStopSelection, tooltip="Additional buffer beyond swing point")
vwapStopDistance = input.float(0.3, "VWAP Stop Distance (ATR multiplier)", minval=0.1, maxval=2.0, step=0.05, group=grpStopSelection, tooltip="Distance from VWAP for stop placement")
manualStopPoints = input.float(1.0, "Manual Stop Distance (points)", minval=0.1, maxval=10.0, step=0.1, group=grpStopSelection, tooltip="Fixed point distance from entry")
hybridExcludeVwap = input.bool(false, "Exclude VWAP from Hybrid", group=grpStopSelection, tooltip="When true, hybrid only considers ATR and Swing stops")

// === Adaptive Volatility Settings ===
var grpAdaptiveVol = "Adaptive Volatility Engine"
useAdaptiveVolatility = input.bool(true, title="Enable Adaptive Volatility", group=grpAdaptiveVol, tooltip="Dynamically adjusts R:R and stop selection based on market regime")
fastAtrLength = input.int(5, title="Fast ATR Length", minval=3, maxval=14, group=grpAdaptiveVol)
volLookbackBars = input.int(12, title="Volatility Lookback Bars", minval=5, maxval=30, group=grpAdaptiveVol)
lowVolThreshold = input.float(0.8, title="Low Volatility Threshold", minval=0.3, maxval=1.0, step=0.1, group=grpAdaptiveVol)
highVolThreshold = input.float(1.3, title="High Volatility Threshold", minval=1.0, maxval=2.0, step=0.1, group=grpAdaptiveVol)
extremeVolThreshold = input.float(2.0, title="Extreme Volatility Threshold", minval=1.5, maxval=3.0, step=0.1, group=grpAdaptiveVol)
maxTargetATR = input.float(3.0, title="Max Target Distance (ATR)", minval=1.0, maxval=5.0, step=0.25, group=grpAdaptiveVol, tooltip="Targets beyond this ATR distance are considered unfeasible")
minAcceptableRR = input.float(1.5, title="Minimum Acceptable R:R", minval=1.0, maxval=2.0, step=0.1, group=grpAdaptiveVol, tooltip="Trades below this R:R will be skipped")
autoSelectStop = input.bool(true, title="Auto-Select Best Stop", group=grpAdaptiveVol, tooltip="Automatically selects stop type with best achievable R:R")
showStopOptionsTable = input.bool(true, title="Show Stop Options Table", group=grpAdaptiveVol, tooltip="Display comparison of all stop types and their R:R")

// === EMA Display Settings ===
var grp9 = "EMA Display Settings"
plotEma = input.bool(true, title="Plot EMA on Chart", group=grp9)
emaColor = input.color(color.fuchsia, title="EMA Color", group=grp9)
emaWidth = input.int(2, title="EMA Line Width", minval=1, maxval=4, group=grp9)

// === Signal Visualization ===
var grpVis = "Signal Visualization"
showEntryLabels = input.bool(true, title="Show Entry/Exit Labels", group=grpVis)
highlightEntryBars = input.bool(true, title="Highlight Entry Bars", group=grpVis)

// ========================================
// SYMBOL PRESET SYSTEM - Using defaults for simplicity
// ========================================

autoSymbol = syminfo.ticker
presetSymbol = autoSymbol
var string presetSymbolSimple = ""
if barstate.isfirst
    presetSymbolSimple := presetSymbol

// Map declarations for preset parameters
var map<string, float>  mapVFLow       = map.new<string, float>()
var map<string, float>  mapVFHigh      = map.new<string, float>()
var map<string, float>  mapVFExtreme   = map.new<string, float>()
var map<string, float>  mapBELow       = map.new<string, float>()
var map<string, float>  mapBENormal    = map.new<string, float>()
var map<string, float>  mapBEHigh      = map.new<string, float>()
var map<string, int>    mapWAEsens     = map.new<string, int>()
var map<string, float>  mapVolThresh   = map.new<string, float>()
var map<string, bool>   mapSSLexit     = map.new<string, bool>()
var map<string, float>  mapVWAPweight  = map.new<string, float>()
var map<string, float>  mapHODweight   = map.new<string, float>()
var map<string, float>  mapCamWeight   = map.new<string, float>()
var map<string, float>  mapWeeklyWeight = map.new<string, float>()
var map<string, float>  mapProxTouch   = map.new<string, float>()
var map<string, float>  mapProxNear    = map.new<string, float>()
var map<string, float>  mapORBextension = map.new<string, float>()
var map<string, float>  mapFirstHourMult = map.new<string, float>()
var map<string, float>  mapPowerHourMult = map.new<string, float>()

// ===== PRESET_BLOCK_START_7X9Q2 =====
