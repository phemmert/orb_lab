// ========================================
// SIMPLE LABEL CLEANUP SYSTEM
// ========================================

// Track labels in simple arrays
var array<label> allLabels = array.new<label>()

// Simple function to add and manage labels
addManagedLabel(x, y, labelText, color, style, textcolor, size) =>
    // Label creation is mandatory for trade tracking
    newLabel = label.new(x, y, labelText, color=color, style=style, textcolor=textcolor, size=size)
    array.push(allLabels, newLabel)
    
    // Auto-cleanup: remove old labels beyond our limit
    if maxHistoricalLabels > 0
        while array.size(allLabels) > maxHistoricalLabels
            oldLabel = array.shift(allLabels)
            if not na(oldLabel)
                label.delete(oldLabel)
    
    // Auto-delete labels older than specified bars
    if autoDeleteLabels
        for i = array.size(allLabels) - 1 to 0
            lbl = array.get(allLabels, i)
            if not na(lbl)
                labelAge = bar_index - label.get_x(lbl)
                if labelAge > labelDeleteAfterBars
                    label.delete(lbl)
                    array.remove(allLabels, i)
    
    newLabel


// ========================================
// HELPER FUNCTIONS
// ========================================

// SMOOTHING FUNCTIONS

// Double EMA (DEMA)
dema(src, length) =>
    ema1 = ta.ema(src, length)
    ema2 = ta.ema(ema1, length)
    2 * ema1 - ema2

// Triple EMA (TEMA)
tema(src, length) =>
    ema1 = ta.ema(src, length)
    ema2 = ta.ema(ema1, length)
    ema3 = ta.ema(ema2, length)
    3 * (ema1 - ema2) + ema3

// Ehlers Super Smoother Filter
superSmoother(src, length) =>
    cutoff = 1.414 * 3.14159 / length
    a1 = math.exp(-cutoff)
    b1 = 2 * a1 * math.cos(1.414 * 3.14159 / length)
    c2 = b1
    c3 = -a1 * a1
    c1 = 1 - c2 - c3
    var float ss = na
    ss := c1 * (src + nz(src[1])) / 2 + c2 * nz(ss[1]) + c3 * nz(ss[2])
    ss

// Gaussian Filter
gaussian(src, length, sigma) =>
    weights = array.new_float(0)
    sumWeights = 0.0
    for i = 0 to length - 1
        weight = math.exp(-0.5 * math.pow((i - length / 2) / (sigma * length / 4), 2))
        array.push(weights, weight)
        sumWeights += weight
    
    sum = 0.0
    for i = 0 to length - 1
        if i < bar_index
            sum += src[i] * array.get(weights, i) / sumWeights
    sum

// Enhanced JMA function
jma(src, length) =>
    momentum = ta.change(src)
    volatility = ta.atr(length)
    ratio = volatility != 0 ? momentum / volatility : 0
    smoothed = ta.ema(src + ratio * volatility, length)
    smoothed

// Main MA function - PROPER SERIES-SAFE VERSION
ma(src, length, type) =>
    _len = int(math.max(length, 1))   // force simple for MA types that require it
    
    switch type
        "SMA"  => ta.sma(src, _len)       // MUST be simple
        "EMA"  => ta.ema(src, length)     // EMA supports series (use original)
        "HMA"  => ta.hma(src, _len)       // MUST be simple
        "WMA"  => ta.wma(src, _len)       // MUST be simple
        "JMA"  => jma(src, length)        // your function accepts series
        "DEMA" => dema(src, length)       // accepts series
        "TEMA" => tema(src, length)       // accepts series
        => ta.sma(src, _len)              // default fallback

// Apply smoothing to a series
applySmoother(src, enabled, method, factor) =>
    if not enabled
        src
    else
        smoothingLength = math.round(factor * 2)
        switch method
            "Super Smoother" => superSmoother(src, smoothingLength)
            "Jurik Filter" => jma(src, smoothingLength)
            "EMA Post-Smooth" => ta.ema(src, smoothingLength)
            "Gaussian" => gaussian(src, smoothingLength, factor)
            => src

getLabelSize() =>
    switch labelSize
        "Tiny" => size.tiny
        "Small" => size.small
        "Normal" => size.normal
        "Large" => size.large
        "Huge" => size.huge
        => size.normal    // Default to normal

getLabelOffset() =>
    atr = ta.atr(14)
    atr * (labelOffset / 10.0)

// Function to find swing low during regular trading hours only
findSwingLowRegularHours(lookback) =>
    float swingLow = na
    int validBars = 0
    
    // Define regular trading hours (9:30 AM - 4:00 PM ET)
    regularHours = time(timeframe.period, "0930-1600:1234567", "America/New_York")
    
    // Look back through bars to find lowest low during regular hours
    for i = 1 to lookback * 3  // Look at more bars to ensure we get enough regular hour bars
        if not na(regularHours[i])  // Only consider bars during regular trading hours
            if na(swingLow) or low[i] < swingLow
                swingLow := low[i]
            validBars += 1
            if validBars >= lookback  // Once we have enough regular hour bars, stop
                break
    
    // Fallback if not enough regular hour bars found
    if na(swingLow)
        swingLow := low[1]
    
    swingLow

// Function to find swing high during regular trading hours only
findSwingHighRegularHours(lookback) =>
    float swingHigh = na
    int validBars = 0
    
    // Define regular trading hours (9:30 AM - 4:00 PM ET)
    regularHours = time(timeframe.period, "0930-1600:1234567", "America/New_York")
    
    // Look back through bars to find highest high during regular hours
    for i = 1 to lookback * 3  // Look at more bars to ensure we get enough regular hour bars
        if not na(regularHours[i])  // Only consider bars during regular trading hours
            if na(swingHigh) or high[i] > swingHigh
                swingHigh := high[i]
            validBars += 1
            if validBars >= lookback  // Once we have enough regular hour bars, stop
                break
    
    // Fallback if not enough regular hour bars found
    if na(swingHigh)
        swingHigh := high[1]
    
    swingHigh

calculateStopLoss(isLong, entryPrice, atrValue, vwapVal, stopTypeInput) =>
    // Minimum stop distance - 15% of ATR
    float minStopDist = atrValue * 0.15
    
    // ATR stop (always valid)
    atrStop = isLong ? entryPrice - (atrValue * atrStopMultiplierEff) : entryPrice + (atrValue * atrStopMultiplierEff)
    
    // Swing stop - validate minimum distance
    swingLow = findSwingLowRegularHours(swingLookback)
    swingHigh = findSwingHighRegularHours(swingLookback)
    float swingStopCalc = isLong ? swingLow - (atrValue * swingBufferEff) : swingHigh + (atrValue * swingBufferEff)
    bool swingValid = isLong ? (swingStopCalc < entryPrice - minStopDist) : (swingStopCalc > entryPrice + minStopDist)
    float swingStop = swingValid ? swingStopCalc : atrStop
    
    // VWAP stop - validate side AND minimum distance
    bool vwapSideValid = isLong ? (vwapVal < entryPrice) : (vwapVal > entryPrice)
    float vwapStopCalc = isLong ? vwapVal - (atrValue * vwapStopDistanceEff) : vwapVal + (atrValue * vwapStopDistanceEff)
    bool vwapDistValid = isLong ? (vwapStopCalc < entryPrice - minStopDist) : (vwapStopCalc > entryPrice + minStopDist)
    float vwapStop = (vwapSideValid and vwapDistValid) ? vwapStopCalc : na

    // Manual stop - fixed point distance from entry
    float manualStop = isLong ? entryPrice - manualStopPoints : entryPrice + manualStopPoints

    // Use the stop type passed in for this trade
    _typeToUse = stopTypeInput

    // Select stop based on type - with validity fallbacks
    selectedStop = switch _typeToUse
        "ATR" => atrStop
        "Swing" => swingValid ? swingStop : atrStop
        "VWAP" => na(vwapStop) ? atrStop : vwapStop
        "Manual" => manualStop
        "Hybrid" => isLong ? (hybridExcludeVwap ? math.max(atrStop, swingValid ? swingStop : atrStop) : math.max(atrStop, math.max(swingValid ? swingStop : atrStop, na(vwapStop) ? atrStop : vwapStop))) : (hybridExcludeVwap ? math.min(atrStop, swingValid ? swingStop : atrStop) : math.min(atrStop, math.min(swingValid ? swingStop : atrStop, na(vwapStop) ? atrStop : vwapStop)))
        => atrStop

    // Determine stop type label for display using ternaries
    stopTypeLabel = _typeToUse == "Swing" and not swingValid ? "ATR-Fallback" : (_typeToUse == "VWAP" and na(vwapStop) ? "ATR-Fallback" : (_typeToUse == "Hybrid" ? (selectedStop == atrStop ? "Hybrid-ATR" : (selectedStop == swingStop ? "Hybrid-Swing" : "Hybrid-VWAP")) : _typeToUse))

    [selectedStop, stopTypeLabel]

// ══════════════════════════════════════════════════════════════════════════════
// MULTI-STOP EVALUATOR - Returns best stop based on R:R
// ══════════════════════════════════════════════════════════════════════════════
evaluateBestStop(bool isLong, float entryPrice, float atrValue, float vwapVal, float rrTarget, float maxTargetATRs, float minRR) =>
    // Calculate all four stop types
    [atrStop, atrType] = calculateStopLoss(isLong, entryPrice, atrValue, vwapVal, "ATR")
    [swingStop, swingType] = calculateStopLoss(isLong, entryPrice, atrValue, vwapVal, "Swing")
    [vwapStop, vwapType] = calculateStopLoss(isLong, entryPrice, atrValue, vwapVal, "VWAP")
    [hybridStop, hybridType] = calculateStopLoss(isLong, entryPrice, atrValue, vwapVal, "Hybrid")
    
    // ═══════════════════════════════════════════════════════════════════════
    // STOP VALIDITY CHECKS - Reject stops that are invalid or micro-sized
    // ═══════════════════════════════════════════════════════════════════════
    float minStopDist = atrValue * 0.15  // Minimum 15% of ATR
    
    bool atrValid = isLong ? (atrStop < entryPrice - minStopDist) : (atrStop > entryPrice + minStopDist)
    bool swingValid = isLong ? (swingStop < entryPrice - minStopDist) : (swingStop > entryPrice + minStopDist)
    bool vwapSideOK = isLong ? (vwapVal < entryPrice) : (vwapVal > entryPrice)
    bool vwapValid = vwapSideOK and not na(vwapStop) and (isLong ? (vwapStop < entryPrice - minStopDist) : (vwapStop > entryPrice + minStopDist))
    bool hybridValid = isLong ? (hybridStop < entryPrice - minStopDist) : (hybridStop > entryPrice + minStopDist)
    
    // Calculate risk per share for each (only for valid stops)
    float atrRisk = atrValid ? math.abs(entryPrice - atrStop) : na
    float swingRisk = swingValid ? math.abs(entryPrice - swingStop) : na
    float vwapRisk = vwapValid ? math.abs(entryPrice - vwapStop) : na
    float hybridRisk = hybridValid ? math.abs(entryPrice - hybridStop) : na
    
    // Calculate target for each based on desired R:R
    float atrTarget = isLong ? entryPrice + (nz(atrRisk) * rrTarget) : entryPrice - (nz(atrRisk) * rrTarget)
    float swingTarget = isLong ? entryPrice + (nz(swingRisk) * rrTarget) : entryPrice - (nz(swingRisk) * rrTarget)
    float vwapTarget = isLong ? entryPrice + (nz(vwapRisk) * rrTarget) : entryPrice - (nz(vwapRisk) * rrTarget)
    float hybridTarget = isLong ? entryPrice + (nz(hybridRisk) * rrTarget) : entryPrice - (nz(hybridRisk) * rrTarget)
    
    // Calculate target distance in ATRs
    float atrTargetATRs = atrValid ? math.abs(atrTarget - entryPrice) / atrValue : 999
    float swingTargetATRs = swingValid ? math.abs(swingTarget - entryPrice) / atrValue : 999
    float vwapTargetATRs = vwapValid ? math.abs(vwapTarget - entryPrice) / atrValue : 999
    float hybridTargetATRs = hybridValid ? math.abs(hybridTarget - entryPrice) / atrValue : 999
    
    // Calculate achievable R:R for each (capped at maxTargetATRs) - invalid stops get -1
    float atrBestRR = atrValid ? (atrTargetATRs <= maxTargetATRs ? rrTarget : (atrRisk > 0 ? (maxTargetATRs * atrValue) / atrRisk : 0)) : -1
    float swingBestRR = swingValid ? (swingTargetATRs <= maxTargetATRs ? rrTarget : (swingRisk > 0 ? (maxTargetATRs * atrValue) / swingRisk : 0)) : -1
    float vwapBestRR = vwapValid ? (vwapTargetATRs <= maxTargetATRs ? rrTarget : (vwapRisk > 0 ? (maxTargetATRs * atrValue) / vwapRisk : 0)) : -1
    float hybridBestRR = hybridValid ? (hybridTargetATRs <= maxTargetATRs ? rrTarget : (hybridRisk > 0 ? (maxTargetATRs * atrValue) / hybridRisk : 0)) : -1
    
    // Find the best R:R among VALID methods only
    float bestRR = math.max(math.max(atrBestRR, swingBestRR), math.max(vwapBestRR, hybridBestRR))
    
    // Determine which stop type won (default to ATR)
    float selectedStop = atrStop
    string selectedType = atrType
    float selectedRR = atrBestRR > 0 ? atrBestRR : rrTarget
    
    if bestRR == swingBestRR and swingValid and swingBestRR >= minRR
        selectedStop := swingStop
        selectedType := swingType
        selectedRR := swingBestRR
    else if bestRR == vwapBestRR and vwapValid and vwapBestRR >= minRR
        selectedStop := vwapStop
        selectedType := vwapType
        selectedRR := vwapBestRR
    else if bestRR == hybridBestRR and hybridValid and hybridBestRR >= minRR
        selectedStop := hybridStop
        selectedType := hybridType
        selectedRR := hybridBestRR
    else if atrValid and atrBestRR >= minRR
        selectedStop := atrStop
        selectedType := atrType
        selectedRR := atrBestRR
    
    // Return: stop price, stop type name, best achievable R:R, and all four R:Rs for display
    // Invalid stops return -1 for R:R so table can show "invalid"
    [selectedStop, selectedType, selectedRR, atrBestRR > 0 ? atrBestRR : rrTarget, swingBestRR, vwapBestRR, hybridBestRR]

// ========================================
// TRAFFIC LIGHT COLOR FUNCTION
// ========================================
f_trafficLightColor(float qScore, string rrGrade, string vState) =>
    // Bright Green: All systems go - high confluence, good R:R, active tape
    if qScore >= 3 and (rrGrade == "A" or rrGrade == "B") and (vState == "NORMAL" or vState == "HIGH" or vState == "EXTREME")
        color.new(#00FF00, 0)  // Bright green
    // Green: Good R:R in quiet tape, OR C-grade in hot tape
    else if qScore >= 3 and (rrGrade == "A" or rrGrade == "B")
        color.new(color.green, 0)  // A/B grade in LOW vol still acceptable
    else if qScore >= 3 and rrGrade == "C" and (vState == "HIGH" or vState == "EXTREME")
        color.new(color.green, 0)  // C grade needs hot tape to compensate
    // Orange: C-grade in quiet/normal tape - marginal
    else if qScore >= minConfluenceScore
        color.new(color.orange, 0)
    // Red: Below minimum
    else
        color.new(color.red, 0)

// ========================================
// CALCULATIONS
// ========================================

// Market hours and quality filters
inMarketHours = not useMarketHours or (time(timeframe.period, marketSession, "America/New_York") != 0)
inEntryWindow = time(timeframe.period, earliestEntryTime, "America/New_York") != 0

// Market close detection (4:00 PM ET) - Exit all positions by close
currentHour = hour(time, "America/New_York")
currentMinute = minute(time, "America/New_York")
isMarketClose = (currentHour == 16 and currentMinute == 0) or (currentHour == 15 and currentMinute >= 55)

// ========================================
// INITIAL BALANCE CALCULATION
// ========================================
// Reset at market open
if hour(time, "America/New_York") == 9 and minute(time, "America/New_York") == 30
    ibHigh := high
    ibLow := low
    ibFormed := false
    tradingDayStart := time
    // Delete old IB lines
    if not na(ibHighLine)
        line.delete(ibHighLine)
    if not na(ibLowLine)
        line.delete(ibLowLine)

// Track IB formation (using preset period)
if not ibFormed and not na(tradingDayStart)
    minutesSinceOpen = (time - tradingDayStart) / 60000
    if minutesSinceOpen <= ibPeriodMinutesEff
        ibHigh := math.max(ibHigh, high)
        ibLow := math.min(ibLow, low)
    else if minutesSinceOpen > ibPeriodMinutesEff
        ibFormed := true

// Draw and update IB lines
if ibFormed and showIBLevels
    // Convert line style string to Pine Script line style
    lineStyleToUse = switch ibLineStyle
        "Solid" => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_dashed
    
    // Delete old lines and create new ones extending from IB completion
    if na(ibHighLine)
        ibHighLine := line.new(bar_index - 30, ibHigh, bar_index + 100, ibHigh, color=ibHighColor, width=ibLineWidth, style=lineStyleToUse)
        ibLowLine := line.new(bar_index - 30, ibLow, bar_index + 100, ibLow, color=ibLowColor, width=ibLineWidth, style=lineStyleToUse)
    else
        // Keep extending the lines to the right
        line.set_x2(ibHighLine, bar_index + 100)
        line.set_x2(ibLowLine, bar_index + 100)


// Update IB lines position
if ibFormed and showIBLevels
    if not na(ibHighLine)
        line.set_x2(ibHighLine, bar_index + 100)
    if not na(ibLowLine)
        line.set_x2(ibLowLine, bar_index + 100)


// Lunch hour filter
lunchSession = time(timeframe.period, "1130-1330", "America/New_York")
inLunchHour = avoidLunchHour and (lunchSession != 0)

// ATR CALCULATION (RTH-ONLY — synced with ORB v69)
// Uses Regular Trading Hours data only, even on ETH charts
// Prevents pre-market gaps from inflating stop calculations
rthTicker = ticker.new(syminfo.prefix, syminfo.ticker, session.regular)
float rthATR = request.security(rthTicker, timeframe.period, ta.rma(ta.tr(true), 14), barmerge.gaps_off, barmerge.lookahead_off)

// Persist last valid RTH ATR during pre-market
var float lastValidRthATR = na
if not na(rthATR)
    lastValidRthATR := rthATR

// Use RTH ATR when available, otherwise last known RTH, otherwise fallback to standard
float standardATR = ta.atr(14)
atr = not na(rthATR) ? rthATR : (not na(lastValidRthATR) ? lastValidRthATR : standardATR)

// Check if volatility is increasing relative to recent bars
recentRange = ta.highest(high, 5) - ta.lowest(low, 5)  // Last 5 bars range
priorRange = ta.highest(high[5], 5) - ta.lowest(low[5], 5)  // Previous 5 bars before that

// Normalize by price
recentRangePct = recentRange / close
priorRangePct = priorRange / close[5]

// Volatility is accelerating if recent range exceeds prior range
volatilityAccelerating = recentRangePct > priorRangePct * 1.2  // 20% increase shows acceleration

// Also keep a minimum threshold as fallback
atrPct = atr / close
atrPctAvg = ta.sma(atrPct, 20)
minAcceptableVolatility = atrPct >= atrPctAvg * 0.8  // 80% of average is acceptable

// Final condition: Either accelerating OR meets minimum threshold
volatilityCondition = not useVolatilityFilter or volatilityAccelerating or minAcceptableVolatility

// ========================================
// ADAPTIVE VOLATILITY ENGINE (Dual-Timeframe — synced with ORB v70)
// Session-level: first 30-min baseline vs current fast ATR
// Daily-level: today's daily ATR vs 20-day average
// Combined: sessionVF × htfVF = volFactor
// ========================================
var float volFactor = na
var string volState = "NORMAL"

// === Session-Level Component ===
bool volNewDay = ta.change(time("D")) != 0
bool isFirstHalfHour = not na(time(timeframe.period, "0930-1000", "America/New_York"))

float orbATR_fast = ta.atr(fastAtrLength)
float orbATR_slow = ta.sma(orbATR_fast, 10)
orbATR_slow := na(orbATR_slow) ? orbATR_fast : orbATR_slow

var float sessionBaseline = na
if volNewDay
    sessionBaseline := na
if isFirstHalfHour
    sessionBaseline := na(sessionBaseline) ? orbATR_slow : 0.9 * sessionBaseline + 0.1 * orbATR_slow

float sessionVF = not na(sessionBaseline) and sessionBaseline > 0 ? orbATR_fast / sessionBaseline : 1.0

// === Daily-Level Component ===
float dailyATR = request.security(syminfo.tickerid, "D", ta.atr(14))
float dailyATRslow = request.security(syminfo.tickerid, "D", ta.sma(ta.atr(14), 20))
float htfVF = not na(dailyATRslow) and dailyATRslow > 0 ? dailyATR / dailyATRslow : 1.0

// === Combined Factor ===
volFactor := sessionVF * htfVF
// Get dynamic thresholds for this symbol
lowVolThresholdEff = hasPreset and mapVFLow.contains(presetSymbolSimple) ? mapVFLow.get(presetSymbolSimple) : lowVolThreshold
highVolThresholdEff = hasPreset and mapVFHigh.contains(presetSymbolSimple) ? mapVFHigh.get(presetSymbolSimple) : highVolThreshold
extremeVolThresholdEff = hasPreset and mapVFExtreme.contains(presetSymbolSimple) ? mapVFExtreme.get(presetSymbolSimple) : extremeVolThreshold

// Classify volatility regime
if not na(volFactor)
    if volFactor < lowVolThresholdEff      // Changed
        volState := "LOW"
    else if volFactor < highVolThresholdEff   // Changed
        volState := "NORMAL"
    else if volFactor < extremeVolThresholdEff  // Changed
        volState := "HIGH"
    else
        volState := "EXTREME"
// Calculate IB buffer based on selected type
ibBufferHigh = 0.0
ibBufferLow = 0.0

if ibBufferType == "Fixed"
    ibBufferHigh := ibBufferFixed
    ibBufferLow := ibBufferFixed
else if ibBufferType == "ATR"
    ibBufferHigh := atr * ibBufferATR
    ibBufferLow := atr * ibBufferATR
else if ibBufferType == "Percentage"
    ibBufferHigh := ibHigh * (ibBufferPercent / 100)
    ibBufferLow := ibLow * (ibBufferPercent / 100)

// IB Breakout Conditions with buffer
ibBreakUp = false
ibBreakDown = false

if ibFormed
    // Reset flags when price returns inside IB (exactly like ORB does it)
    if hasIBBreakUp and close <= ibHigh
        hasIBBreakUp := false
    if hasIBBreakDown and close >= ibLow
        hasIBBreakDown := false
    
    // Only signal if we haven't already broken out
    ibBreakUp := close > (ibHigh + ibBufferHigh) and not hasIBBreakUp
    ibBreakDown := close < (ibLow - ibBufferLow) and not hasIBBreakDown
    
    // Set flags on breakout
    if ibBreakUp
        hasIBBreakUp := true
    if ibBreakDown
        hasIBBreakDown := true

ibConditionMet = useIBFilter ? (ibFormed and (ibBreakUp or ibBreakDown)) : true
// Volume filter calculation
avgVolume = ta.sma(volume, 20)
volumeCondition = not useVolumeFilter or volume >= avgVolume * volumeThresholdEff


// Higher timeframe trend filter
htfEma = request.security(syminfo.tickerid, "5", ta.ema(close, htfTrendLength))
htfClose = request.security(syminfo.tickerid, "5", close)
htfTrendBullish = not useHTFTrendFilter or (htfClose > htfEma)
htfTrendBearish = not useHTFTrendFilter or (htfClose < htfEma)

// Get market trend
marketClose = request.security(marketETF, timeframe.period, close)
marketEma = request.security(marketETF, timeframe.period, ta.ema(close, marketTrendLength))
marketBullish = not useMarketRegimeFilter or (marketClose > marketEma)
marketBearish = not useMarketRegimeFilter or (marketClose < marketEma)

vwapValue = ta.vwap(hlc3)

// ════════════════════════════════════════════════════════════════════════════
// SSL HYBRID with SMOOTHING - NOW USING sslBaselineLengthEff (FIXED!)
// ════════════════════════════════════════════════════════════════════════════

// Calculate raw baseline - USING PRESET VALUE
baselineRaw = ma(close, sslBaselineLengthEff, sslBaseline)  // FIXED: was sslBaselineLength

// Apply smoothing if enabled
baseline = applySmoother(baselineRaw, sslSmoothingEnabled, sslSmoothingMethod, sslSmoothingFactor)

// SSL bands with potential smoothing - USING PRESET VALUE
sslUpRaw = ma(high, sslLengthEff, sslType)    // FIXED: was sslLength
sslDownRaw = ma(low, sslLengthEff, sslType)   // FIXED: was sslLength

// Optionally smooth the SSL bands too (lighter smoothing)
sslUp = applySmoother(sslUpRaw, sslSmoothingEnabled and sslSmoothingMethod != "Super Smoother", "EMA Post-Smooth", sslSmoothingFactor * 0.5)
sslDown = applySmoother(sslDownRaw, sslSmoothingEnabled and sslSmoothingMethod != "Super Smoother", "EMA Post-Smooth", sslSmoothingFactor * 0.5)

// Exit MA with smoothing - USING PRESET VALUE
exitHighRaw = ma(high, exitLengthEff, exitType)  // FIXED: was exitLength
exitLowRaw = ma(low, exitLengthEff, exitType)    // FIXED: was exitLength

// Apply smoothing to the exit bands
exitHigh = applySmoother(exitHighRaw, sslSmoothingEnabled, "EMA Post-Smooth", sslSmoothingFactor * 0.3)
exitLow = applySmoother(exitLowRaw, sslSmoothingEnabled, "EMA Post-Smooth", sslSmoothingFactor * 0.3)

// Keep the original SSL switching logic
var int exitDirection = 0
exitDirection := close > exitHigh ? 1 : close < exitLow ? -1 : exitDirection
sslExit = exitDirection < 0 ? exitHigh : exitLow

var int sslDirection = 0
sslDirection := close > sslUp ? 1 : close < sslDown ? -1 : sslDirection

sslBullishSimple = close > baseline
sslBearishSimple = close < baseline
sslBullish = sslBullishSimple and not sslBullishSimple[1]
sslBearish = sslBearishSimple and not sslBearishSimple[1]

// SSL Gap Widening Detection (NA-safe)
// For longs: gap above baseline must be growing
// For shorts: gap below baseline must be growing
sslGapBull = close - baseline
sslGapBear = baseline - close

sslAccelBull = nz(sslGapBull) > nz(sslGapBull[1])
sslAccelBear = nz(sslGapBear) > nz(sslGapBear[1])

// SSL Score Calculation with Gap Widening Filter
var float sslScoreBull = 0.0
var float sslScoreBear = 0.0

// Reset scores explicitly each bar
sslScoreBull := 0.0
sslScoreBear := 0.0

if useSSLMomentumFilter
    // Bullish: must be above baseline AND gap widening
    if sslBullishSimple and sslAccelBull
        sslScoreBull := 1.0
    
    // Bearish: must be below baseline AND gap widening
    if sslBearishSimple and sslAccelBear
        sslScoreBear := 1.0
else
    // Original behavior if filter is off
    sslScoreBull := sslBullishSimple ? 1.0 : 0.0
    sslScoreBear := sslBearishSimple ? 1.0 : 0.0

sslExitLong = ta.crossover(close, sslExit)
sslExitShort = ta.crossunder(close, sslExit)

// Calculate EMAs for exit logic (synced with ORB)
ema9 = ta.ema(close, emaPeriod)
ema20 = ta.ema(close, ema20Period)

// Track SSL breach state
var bool sslBreachedLong = false
var bool sslBreachedShort = false

// SSL breach detection - EARLY WARNING when price crosses SSL2 bands
// This triggers "start watching for EMA exit" - not the exit itself
if inLongPosition and ta.crossunder(close, sslDown)
    sslBreachedLong := true
if inShortPosition and ta.crossover(close, sslUp)
    sslBreachedShort := true

// Reset breach flags when position closes
if not inLongPosition
    sslBreachedLong := false
if not inShortPosition
    sslBreachedShort := false

// EMA exit conditions - now require confirmation bars (synced with ORB)
// Track bars under/over EMA for confirmation
if inLongPosition and close < ema9
    barsUnderEma := barsUnderEma + 1
else
    barsUnderEma := 0

if inShortPosition and close > ema9
    barsOverEma := barsOverEma + 1
else
    barsOverEma := 0

// EMA body percentage check (synced with ORB)
float bodySize = math.abs(close - open)
float bodyBeyondEmaLong = open > ema9 ? 0.0 : math.min(bodySize, ema9 - close) / bodySize * 100
float bodyBeyondEmaShort = open < ema9 ? 0.0 : math.min(bodySize, close - ema9) / bodySize * 100

// Primary EMA exit (after SSL breach + BE achieved, with confirmation)
emaExitLong = inLongPosition and sslBreachedLong and breakEvenActivated and
              barsUnderEma >= emaConfirmationBars and bodyBeyondEmaLong >= emaBodyPercentage
emaExitShort = inShortPosition and sslBreachedShort and breakEvenActivated and
               barsOverEma >= emaConfirmationBars and bodyBeyondEmaShort >= emaBodyPercentage

// Alternative 9/20 EMA cross exit (synced with ORB)
emaCrossExitLong = inLongPosition and not useEmaCrossExitEff and useEmaCrossExit920 and ta.crossunder(ema9, ema20)
emaCrossExitShort = inShortPosition and not useEmaCrossExitEff and useEmaCrossExit920 and ta.crossover(ema9, ema20)

// WADDAH ATTAR EXPLOSION
fastMA = ta.ema(close, waeFastEMAEff)
slowMA = ta.ema(close, waeSlowEMAEff)
macd = fastMA - slowMA
macdPrev = fastMA[1] - slowMA[1]
t1 = (macd - macdPrev) * waeSensitivityEff

basis = ta.sma(close, waeBBLengthEff)
dev = waeBBMultiplierEff * ta.stdev(close, waeBBLengthEff)
bbUpper = basis + dev
bbLower = basis - dev
explosionLine = bbUpper - bbLower

trendUp = t1 >= 0 ? t1 : 0
trendDown = t1 < 0 ? -1 * t1 : 0

// WAE confirmation states (synced with ORB)
waeBullConfirmation = trendUp > explosionLine
waeBearConfirmation = trendDown > explosionLine

// WAE Acceleration Detection - includes explosion line check (synced with ORB)
bool waeAccelBull = trendUp > nz(trendUp[1]) and trendUp > explosionLine
bool waeAccelBear = trendDown > nz(trendDown[1]) and trendDown > explosionLine

// WAE Score with Acceleration Filter (synced with ORB)
var float waeScoreBull = 0.0
var float waeScoreBear = 0.0
waeScoreBull := 0.0
waeScoreBear := 0.0

if useWAEAcceleration
    if waeBullConfirmation and waeAccelBull
        waeScoreBull := 1.0
    if waeBearConfirmation and waeAccelBear
        waeScoreBear := 1.0
else
    waeScoreBull := waeBullConfirmation ? 1.0 : 0.0
    waeScoreBear := waeBearConfirmation ? 1.0 : 0.0

// QQE MOD
calculateQQE(rsiLength, smoothingFactor, qqeFactor, source) =>
    wildersLength = rsiLength * 2 - 1
    rsi = ta.rsi(source, rsiLength)
    smoothedRsi = ta.ema(rsi, smoothingFactor)
    atrRsi = math.abs(smoothedRsi[1] - smoothedRsi)
    smoothedAtrRsi = ta.ema(atrRsi, wildersLength)
    dynamicAtrRsi = smoothedAtrRsi * qqeFactor

    var float longBand = 0.0
    var float shortBand = 0.0
    var int trendDirection = 0

    atrDelta = dynamicAtrRsi
    newShortBand = smoothedRsi + atrDelta
    newLongBand = smoothedRsi - atrDelta
    longBand := smoothedRsi[1] > longBand[1] and smoothedRsi > longBand[1] ? math.max(longBand[1], newLongBand) : newLongBand
    shortBand := smoothedRsi[1] < shortBand[1] and smoothedRsi < shortBand[1] ? math.min(shortBand[1], newShortBand) : newShortBand
    
    crossUp = ta.cross(smoothedRsi, shortBand[1])
    crossDown = ta.cross(longBand[1], smoothedRsi)
    
    if crossUp
        trendDirection := 1
    else if crossDown
        trendDirection := -1
    else
        trendDirection := trendDirection[1]

    qqeTrendLine = trendDirection == 1 ? longBand : shortBand
    [qqeTrendLine, smoothedRsi, trendDirection]

[primaryQQETrendLine, primaryRSI, primaryTrend] = calculateQQE(qqeRSI1LengthEff, qqeRSI1SmoothingEff, qqeFactor1Eff, close)
[secondaryQQETrendLine, secondaryRSI, secondaryTrend] = calculateQQE(qqeRSI2LengthEff, qqeRSI2SmoothingEff, qqeFactor2Eff, close)

bollingerBasis     = ta.sma(primaryQQETrendLine - 50, qqeBBLengthEff)
bollingerDeviation = qqeBBMultiplierEff * ta.stdev(primaryQQETrendLine - 50, qqeBBLengthEff)

bollingerUpper = bollingerBasis + bollingerDeviation
bollingerLower = bollingerBasis - bollingerDeviation

// Raw QQE conditions using thresholdSecondary input (synced with ORB)
rawQQEBullCondition = secondaryRSI - 50 > thresholdSecondary and primaryRSI - 50 > bollingerUpper
rawQQEBearCondition = secondaryRSI - 50 < -thresholdSecondary and primaryRSI - 50 < bollingerLower

// Signal strength calculation (synced with ORB)
bullSignalStrength = math.min(secondaryRSI - 50 - thresholdSecondary, primaryRSI - 50 - bollingerUpper)
bearSignalStrength = math.min(-thresholdSecondary - (secondaryRSI - 50), bollingerLower - (primaryRSI - 50))

// Track consecutive increasing bars (synced with ORB)
if rawQQEBullCondition
    if bullSignalStrength > prevBullSignalStrength
        bullQQEIncreasingCount := bullQQEIncreasingCount + 1
    else
        bullQQEIncreasingCount := 0
else
    bullQQEIncreasingCount := 0

if rawQQEBearCondition
    if bearSignalStrength > prevBearSignalStrength
        bearQQEIncreasingCount := bearQQEIncreasingCount + 1
    else
        bearQQEIncreasingCount := 0
else
    bearQQEIncreasingCount := 0

prevBullSignalStrength := rawQQEBullCondition ? bullSignalStrength : 0.0
prevBearSignalStrength := rawQQEBearCondition ? bearSignalStrength : 0.0

// QQE signal requires N consecutive increasing bars (synced with ORB)
qqeBullSignal := bullQQEIncreasingCount >= consecutiveIncreasingBars - 1 and rawQQEBullCondition
qqeBearSignal := bearQQEIncreasingCount >= consecutiveIncreasingBars - 1 and rawQQEBearCondition

// QQE Momentum Direction Detection (NA-safe)
// For longs: momentum must be rising (RSI increasing)
// For shorts: momentum must be falling (RSI decreasing)
bool qqeMomentumRising = nz(primaryRSI) > nz(primaryRSI[1])
bool qqeMomentumFalling = nz(primaryRSI) < nz(primaryRSI[1])

// QQE Score with Momentum Direction Filter (synced with ORB)
var float qqeScoreBull = 0.0
var float qqeScoreBear = 0.0
qqeScoreBull := 0.0
qqeScoreBear := 0.0

if useQQEMomentumFilter
    // Bullish: must be in bullish state AND momentum rising
    if qqeBullSignal and qqeMomentumRising
        qqeScoreBull := 1.0
    // Bearish: must be in bearish state AND momentum falling
    if qqeBearSignal and qqeMomentumFalling
        qqeScoreBear := 1.0
else
    // Original behavior if filter is off
    qqeScoreBull := qqeBullSignal ? 1.0 : 0.0
    qqeScoreBear := qqeBearSignal ? 1.0 : 0.0

// VOLUME ANALYSIS (Z-Score Normalized - synced with ORB)
volMean = ta.sma(volume, volLookback)
volStd = ta.stdev(volume, volLookback)
volZ = volStd > 0 ? (volume - volMean) / volStd : 0.0

volScore := 0.0
if volZ >= 1.0
    volScore := 1.0      // 1+ stdev above normal = Strong (+1 confluence)
else if volZ >= 0.2
    volScore := 0.5      // Slightly above normal = Avg (+0 confluence)
else
    volScore := 0.0      // Below normal = Low (+0 confluence)

volBullConfirmation := volScore >= 0.25
volBearConfirmation := volScore >= 0.25

// IB SCORING
ibBullScore = 0.0
ibBearScore = 0.0
if includeIBInConfluence and ibFormed
    ibBullScore := ibBreakUp ? 1.0 : 0.0
    ibBearScore := ibBreakDown ? 1.0 : 0.0

// CONFLUENCE SCORING (synced with ORB - includes volume)
bullScore = sslScoreBull + waeScoreBull + qqeScoreBull + ibBullScore + (enableVolume ? int(math.round(volScore)) : 0)
bearScore = sslScoreBear + waeScoreBear + qqeScoreBear + ibBearScore + (enableVolume ? int(math.round(volScore)) : 0)
// Adjust max score for "require all" logic
maxScore = (includeIBInConfluence ? 4 : 3) + (enableVolume ? 1 : 0)

// ══════════════════════════════════════════════════════════════════════════
// PRE-SIGNAL FEASIBILITY ENGINE (ORB Architecture)
// Compute feasibility BEFORE signal definition so SKIPs never become signals
// ══════════════════════════════════════════════════════════════════════════

// Step 1: Compute adaptive R:R based on current volatility state
float rrDesiredComputed = riskRewardRatio
if useAdaptiveVolatility
    if volState == "LOW"
        rrDesiredComputed := riskRewardRatio + 0.5
    else if volState == "NORMAL"
        rrDesiredComputed := riskRewardRatio
    else if volState == "HIGH"
        rrDesiredComputed := math.max(1.2, riskRewardRatio - 0.5)
    else  // EXTREME
        rrDesiredComputed := math.max(1.0, riskRewardRatio - 0.8)

// Step 2: Evaluate all stop options for BOTH directions using current close
float preEntry = close
[preBestStopL, preBestTypeL, preBestRRL, preAtrRRL, preSwingRRL, preVwapRRL, preHybridRRL] = evaluateBestStop(true, preEntry, atr, vwapValue, rrDesiredComputed, maxTargetATREff, minAcceptableRREff)
[preBestStopS, preBestTypeS, preBestRRS, preAtrRRS, preSwingRRS, preVwapRRS, preHybridRRS] = evaluateBestStop(false, preEntry, atr, vwapValue, rrDesiredComputed, maxTargetATREff, minAcceptableRREff)

// Step 3: Determine which R:R would be used based on auto/manual stop selection
float preCandRRL = na
float preCandRRS = na
float preCandStopL = na
float preCandStopS = na

if autoSelectStop and useAdaptiveVolatility
    // Auto mode: use best R:R
    preCandRRL := preBestRRL
    preCandRRS := preBestRRS
    preCandStopL := preBestStopL
    preCandStopS := preBestStopS
else
    // Manual mode: determine which stop type would be used
    string stopTypeForCalc = stopLossType
    if useAdaptiveVolatility and (volState == "HIGH" or volState == "EXTREME")
        stopTypeForCalc := stopLossType == "ATR" ? "Hybrid" : stopLossType
    
    if stopTypeForCalc == "ATR"
        preCandRRL := preAtrRRL
        preCandRRS := preAtrRRS
        preCandStopL := preEntry - (atr * atrStopMultiplierEff)
        preCandStopS := preEntry + (atr * atrStopMultiplierEff)
    else if stopTypeForCalc == "Swing"
        preCandRRL := preSwingRRL
        preCandRRS := preSwingRRS
        float swingLowPre = findSwingLowRegularHours(swingLookback)
        float swingHighPre = findSwingHighRegularHours(swingLookback)
        float swingStopLCalc = swingLowPre - (atr * swingBufferEff)
        float swingStopSCalc = swingHighPre + (atr * swingBufferEff)
        preCandStopL := swingStopLCalc < preEntry - (atr * 0.15) ? swingStopLCalc : preEntry - (atr * atrStopMultiplierEff)
        preCandStopS := swingStopSCalc > preEntry + (atr * 0.15) ? swingStopSCalc : preEntry + (atr * atrStopMultiplierEff)
    else if stopTypeForCalc == "VWAP"
        preCandRRL := preVwapRRL
        preCandRRS := preVwapRRS
        float vwapStopLCalc = vwapValue - (atr * vwapStopDistanceEff)
        float vwapStopSCalc = vwapValue + (atr * vwapStopDistanceEff)
        bool vwapLongOK = vwapValue < preEntry and vwapStopLCalc < preEntry - (atr * 0.15)
        bool vwapShortOK = vwapValue > preEntry and vwapStopSCalc > preEntry + (atr * 0.15)
        preCandStopL := vwapLongOK ? vwapStopLCalc : preEntry - (atr * atrStopMultiplierEff)
        preCandStopS := vwapShortOK ? vwapStopSCalc : preEntry + (atr * atrStopMultiplierEff)
    else if stopTypeForCalc == "Manual"
        // Manual: fixed point distance from entry
        preCandStopL := preEntry - manualStopPoints
        preCandStopS := preEntry + manualStopPoints
        // Calculate R:R for manual stops
        float manualRiskL = math.abs(preEntry - preCandStopL)
        float manualRiskS = math.abs(preEntry - preCandStopS)
        float manualTargetATRsL = manualRiskL > 0 ? (manualRiskL * rrDesiredComputed) / atr : 999
        float manualTargetATRsS = manualRiskS > 0 ? (manualRiskS * rrDesiredComputed) / atr : 999
        preCandRRL := manualTargetATRsL <= maxTargetATREff ? rrDesiredComputed : (manualRiskL > 0 ? (maxTargetATREff * atr) / manualRiskL : 0)
        preCandRRS := manualTargetATRsS <= maxTargetATREff ? rrDesiredComputed : (manualRiskS > 0 ? (maxTargetATREff * atr) / manualRiskS : 0)
    else  // Hybrid
        preCandRRL := preHybridRRL
        preCandRRS := preHybridRRS
        // Hybrid LONG
        float atrStopLPre = preEntry - (atr * atrStopMultiplierEff)
        float swingLowPre = findSwingLowRegularHours(swingLookback)
        float swingStopLPre = swingLowPre - (atr * swingBufferEff)
        float vwapStopLPre = vwapValue - (atr * vwapStopDistanceEff)
        swingStopLPre := swingStopLPre < preEntry - (atr * 0.15) ? swingStopLPre : atrStopLPre
        vwapStopLPre := (vwapValue < preEntry and vwapStopLPre < preEntry - (atr * 0.15)) ? vwapStopLPre : atrStopLPre
        preCandStopL := hybridExcludeVwap ? math.max(atrStopLPre, swingStopLPre) : math.max(atrStopLPre, math.max(swingStopLPre, vwapStopLPre))
        // Hybrid SHORT
        float atrStopSPre = preEntry + (atr * atrStopMultiplierEff)
        float swingHighPre = findSwingHighRegularHours(swingLookback)
        float swingStopSPre = swingHighPre + (atr * swingBufferEff)
        float vwapStopSPre = vwapValue + (atr * vwapStopDistanceEff)
        swingStopSPre := swingStopSPre > preEntry + (atr * 0.15) ? swingStopSPre : atrStopSPre
        vwapStopSPre := (vwapValue > preEntry and vwapStopSPre > preEntry + (atr * 0.15)) ? vwapStopSPre : atrStopSPre
        preCandStopS := hybridExcludeVwap ? math.min(atrStopSPre, swingStopSPre) : math.min(atrStopSPre, math.min(swingStopSPre, vwapStopSPre))

// Step 4: Calculate derived values for feasibility checks
float preCandRiskL = math.abs(preEntry - preCandStopL)
float preCandRiskS = math.abs(preEntry - preCandStopS)
float preCandTargetL = preEntry + (preCandRiskL * nz(preCandRRL, 0))
float preCandTargetS = preEntry - (preCandRiskS * nz(preCandRRS, 0))
float preCandTargetATRsL = preCandRiskL > 0 ? math.abs(preCandTargetL - preEntry) / atr : 0
float preCandTargetATRsS = preCandRiskS > 0 ? math.abs(preCandTargetS - preEntry) / atr : 0

// Step 5: Apply ALL feasibility checks for LONG
bool longTradeFeasible = true
string skipReasonLong = ""

if nz(preCandRRL, 0) < minAcceptableRREff
    longTradeFeasible := false
    skipReasonLong := "RR " + str.tostring(nz(preCandRRL, 0), "#.#") + " < min " + str.tostring(minAcceptableRREff, "#.#")

if longTradeFeasible and skipLowVolCGradesEff and volState == "LOW" and nz(preCandRRL, 0) < lowVolMinRREff
    longTradeFeasible := false
    skipReasonLong := "LOW vol RR " + str.tostring(nz(preCandRRL, 0), "#.#") + " < " + str.tostring(lowVolMinRREff, "#.#")

if longTradeFeasible and preCandTargetATRsL > maxTargetATREff
    longTradeFeasible := false
    skipReasonLong := "Target " + str.tostring(preCandTargetATRsL, "#.#") + " ATR > max " + str.tostring(maxTargetATREff, "#.#")

if longTradeFeasible and preCandStopL >= preEntry
    longTradeFeasible := false
    skipReasonLong := "Invalid stop >= entry"

// Step 6: Apply ALL feasibility checks for SHORT
bool shortTradeFeasible = true
string skipReasonShort = ""

if nz(preCandRRS, 0) < minAcceptableRREff
    shortTradeFeasible := false
    skipReasonShort := "RR " + str.tostring(nz(preCandRRS, 0), "#.#") + " < min " + str.tostring(minAcceptableRREff, "#.#")

if shortTradeFeasible and skipLowVolCGradesEff and volState == "LOW" and nz(preCandRRS, 0) < lowVolMinRREff
    shortTradeFeasible := false
    skipReasonShort := "LOW vol RR " + str.tostring(nz(preCandRRS, 0), "#.#") + " < " + str.tostring(lowVolMinRREff, "#.#")

if shortTradeFeasible and preCandTargetATRsS > maxTargetATREff
    shortTradeFeasible := false
    skipReasonShort := "Target " + str.tostring(preCandTargetATRsS, "#.#") + " ATR > max " + str.tostring(maxTargetATREff, "#.#")

if shortTradeFeasible and preCandStopS <= preEntry
    shortTradeFeasible := false
    skipReasonShort := "Invalid stop <= entry"

// ══════════════════════════════════════════════════════════════════════════
// END PRE-SIGNAL FEASIBILITY ENGINE
// ══════════════════════════════════════════════════════════════════════════

// ENHANCED SIGNAL GENERATION WITH QUALITY FILTERS
baseConditionsMet = inMarketHours and inEntryWindow and not inLunchHour and volatilityCondition and ibConditionMet
longConditionsMet = baseConditionsMet and htfTrendBullish and marketBullish and bullScore >= minConfluenceScore
shortConditionsMet = baseConditionsMet and htfTrendBearish and marketBearish and bearScore >= minConfluenceScore

bool canEnter = not inLongPosition and not inShortPosition and (bar_index - nz(lastEntryBar, 0) > minBarsBetweenEntries)

longSignal_prev = longSignal[1]
shortSignal_prev = shortSignal[1]

// ══════════════════════════════════════════════════════════════════════════
// CRITICAL: Feasibility is NOW part of the signal definition
// A SKIP trade is NEVER a signal - alerts cannot escape
// ══════════════════════════════════════════════════════════════════════════
longSignal := longConditionsMet and canEnter and longTradeFeasible and barstate.isconfirmed
shortSignal := shortConditionsMet and canEnter and shortTradeFeasible and barstate.isconfirmed

// Detect NEW signals (first bar only) - these are ALWAYS feasible trades
newLongSignal = longSignal and not longSignal[1]
newShortSignal = shortSignal and not shortSignal[1]

// ══════════════════════════════════════════════════════════════════════════
// SKIP DETECTION - Conditions met but feasibility failed
// These generate SKIP labels but NEVER fire alerts
// ══════════════════════════════════════════════════════════════════════════
bool longSkipCondition = longConditionsMet and canEnter and not longTradeFeasible and barstate.isconfirmed
bool shortSkipCondition = shortConditionsMet and canEnter and not shortTradeFeasible and barstate.isconfirmed
bool newLongSkip = longSkipCondition and not longSkipCondition[1]
bool newShortSkip = shortSkipCondition and not shortSkipCondition[1]


// ========================================
// POSITION MANAGEMENT
// ========================================

labelOffsetDynamic = getLabelOffset()

// EOD EXIT SIGNALS - Close all positions at market close
eodExitLong = isMarketClose and inLongPosition
eodExitShort = isMarketClose and inShortPosition

// ══════════════════════════════════════════════════════════════════════════
// EARLY CAM LEVEL CALCULATION (for composite grade)
// Uses request.security to get previous day's data
// ══════════════════════════════════════════════════════════════════════════
[earlyCamHigh, earlyCamLow, earlyCamClose] = request.security(syminfo.tickerid, "D", [high[1], low[1], close[1]], barmerge.gaps_off, barmerge.lookahead_on)
earlyCamRange = earlyCamHigh - earlyCamLow
earlyCamR3 = earlyCamClose + earlyCamRange * 1.1 / 4
earlyCamR4 = earlyCamClose + earlyCamRange * 1.1 / 2
earlyCamS3 = earlyCamClose - earlyCamRange * 1.1 / 4
earlyCamS4 = earlyCamClose - earlyCamRange * 1.1 / 2

// ══════════════════════════════════════════════════════════════════════════
// COMPOSITE TRADE GRADE CALCULATION
// Single grade combining: RR (35%) + Confluence (35%) + Vol (15%) + CAM (15%)
// ══════════════════════════════════════════════════════════════════════════

// Helper function: Map RR to 0-100 score (single line to minimize scopes)
f_rrScore(float rr) => rr < 1.5 ? 0.0 : rr >= 3.0 ? 100.0 : rr >= 2.5 ? 85.0 : rr >= 2.0 ? 70.0 : 50.0

// Helper function: Map confluence (0-4) to 0-100 score
f_confScore(float conf) => conf >= 4.0 ? 100.0 : conf >= 3.0 ? 75.0 : conf >= 2.0 ? 50.0 : conf >= 1.0 ? 25.0 : 0.0

// Helper function: Map vol state to 0-100 score (for momentum/breakout trades)
f_volScore(string vol) => vol == "LOW" ? 40.0 : vol == "NORMAL" ? 75.0 : vol == "HIGH" ? 90.0 : vol == "EXTREME" ? 65.0 : 50.0

// Helper function: Map CAM alignment to 0-100 score
// camStateR4/S4: 1=TREND_BREAK (breaks through), 2=EXHAUSTION (reverses), 3=CONFLICT
f_camScore(bool isLong, float priceNow) =>
    float score = 60.0
    inR4Zone = not na(earlyCamR3) and priceNow >= earlyCamR3
    inS4Zone = not na(earlyCamS3) and priceNow <= earlyCamS3
    score := isLong ? (inS4Zone ? (camStateS4 == 2 ? 90.0 : camStateS4 == 1 ? 40.0 : 50.0) : inR4Zone ? (camStateR4 == 1 ? 80.0 : camStateR4 == 2 ? 30.0 : 50.0) : 60.0) : (inR4Zone ? (camStateR4 == 2 ? 90.0 : camStateR4 == 1 ? 40.0 : 50.0) : inS4Zone ? (camStateS4 == 1 ? 80.0 : camStateS4 == 2 ? 30.0 : 50.0) : 60.0)
    score

// Helper function: Calculate final composite grade (flattened to minimize scopes)
f_compositeGrade(float rr, float confluence, string vol, bool isLong, float price) =>
    float totalScore = rr < 1.5 ? 0.0 : (f_rrScore(rr) * 0.35) + (f_confScore(confluence) * 0.35) + (f_volScore(vol) * 0.15) + (f_camScore(isLong, price) * 0.15)
    totalScore >= 90 ? "A+" : totalScore >= 80 ? "A" : totalScore >= 70 ? "B+" : totalScore >= 60 ? "B" : totalScore >= 50 ? "C" : "D"


// ══════════════════════════════════════════════════════════════════════════
// LONG ENTRY BLOCK - ORB Architecture (signal guarantees feasibility)
// ══════════════════════════════════════════════════════════════════════════
if barstate.isconfirmed and newLongSignal
    // Signal fired = trade IS feasible (checked in signal definition)
    // STEP 1: CALCULATE DESIRED R:R BASED ON VOLATILITY
    float rrDesired = riskRewardRatio
    if useAdaptiveVolatility
        if volState == "LOW"
            rrDesired := riskRewardRatio + 0.5
        else if volState == "NORMAL"
            rrDesired := riskRewardRatio
        else if volState == "HIGH"
            rrDesired := math.max(1.2, riskRewardRatio - 0.5)
        else  // EXTREME
            rrDesired := math.max(1.0, riskRewardRatio - 0.8)

    // STEP 2: GET ALL STOP OPTIONS FROM SINGLE ENGINE
    float candEntry = close
    [bestStop, bestType, bestRR, atrBestRR, swingBestRR, vwapBestRR, hybridBestRR] = evaluateBestStop(true, candEntry, atr, vwapValue, rrDesired, maxTargetATREff, minAcceptableRREff)
    
    // STEP 3: SELECT STOP (auto or manual) - ALL USE evaluateBestStop R:Rs
    float candStop = na
    string candStopType = ""
    float candRR = na
    
    if autoSelectStop and useAdaptiveVolatility
        candStop := bestStop
        candStopType := bestType
        candRR := bestRR
    else
        string stopTypeForThisTrade = stopLossType
        if useAdaptiveVolatility and (volState == "HIGH" or volState == "EXTREME")
            stopTypeForThisTrade := stopLossType == "ATR" ? "Hybrid" : stopLossType
        
        if stopTypeForThisTrade == "ATR"
            candStop := candEntry - (atr * atrStopMultiplierEff)
            candStopType := "ATR"
            candRR := atrBestRR
        else if stopTypeForThisTrade == "Swing"
            float swingLow = findSwingLowRegularHours(swingLookback)
            float swingStopCalc = swingLow - (atr * swingBufferEff)
            bool swingOK = swingStopCalc < candEntry - (atr * 0.15)
            candStop := swingOK ? swingStopCalc : candEntry - (atr * atrStopMultiplierEff)
            candStopType := swingOK ? "Swing" : "ATR-Fallback"
            candRR := swingOK and swingBestRR > 0 ? swingBestRR : atrBestRR
        else if stopTypeForThisTrade == "VWAP"
            float vwapStopCalc = vwapValue - (atr * vwapStopDistanceEff)
            bool vwapOK = vwapValue < candEntry and vwapStopCalc < candEntry - (atr * 0.15)
            candStop := vwapOK ? vwapStopCalc : candEntry - (atr * atrStopMultiplierEff)
            candStopType := vwapOK ? "VWAP" : "ATR-Fallback"
            candRR := vwapOK and vwapBestRR > 0 ? vwapBestRR : atrBestRR
        else if stopTypeForThisTrade == "Manual"
            candStop := candEntry - manualStopPoints
            candStopType := "Manual"
            float manualRisk = math.abs(candEntry - candStop)
            float manualTargetATRs = manualRisk > 0 ? (manualRisk * rrDesired) / atr : 999
            candRR := manualTargetATRs <= maxTargetATREff ? rrDesired : (manualRisk > 0 ? (maxTargetATREff * atr) / manualRisk : 0)
        else  // Hybrid
            float atrStopL = candEntry - (atr * atrStopMultiplierEff)
            float swingLow = findSwingLowRegularHours(swingLookback)
            float swingStopL = swingLow - (atr * swingBufferEff)
            float vwapStopL = vwapValue - (atr * vwapStopDistanceEff)
            bool swingOK = swingStopL < candEntry - (atr * 0.15)
            bool vwapOK = vwapValue < candEntry and vwapStopL < candEntry - (atr * 0.15)
            swingStopL := swingOK ? swingStopL : atrStopL
            vwapStopL := vwapOK ? vwapStopL : atrStopL
            candStop := hybridExcludeVwap ? math.max(atrStopL, swingStopL) : math.max(atrStopL, math.max(swingStopL, vwapStopL))
            candStopType := "Hybrid"
            candRR := hybridBestRR > 0 ? hybridBestRR : atrBestRR

    // Calculate derived values
    float candRiskPerShare = math.abs(candEntry - candStop)
    float candTarget = candEntry + (candRiskPerShare * candRR)
    float candTargetATRs = math.abs(candTarget - candEntry) / atr
    
    // COMPOSITE TRADE GRADE - Single grade for instant decision making
    string candGrade = f_compositeGrade(candRR, bullScore, volState, true, close)
    
    // ENTRY EXECUTION - No inner gate needed (signal guarantees feasibility)
    float entryFinal = math.round(candEntry / syminfo.mintick) * syminfo.mintick
    float stopFinal = math.round(candStop / syminfo.mintick) * syminfo.mintick
    float targetFinal = math.round(candTarget / syminfo.mintick) * syminfo.mintick
    
    string entryStr = str.tostring(entryFinal, "#.##")
    string stopStr = str.tostring(stopFinal, "#.##")
    string targetStr = str.tostring(targetFinal, "#.##")
    
    tradeState := 1
    lastEntryBar := bar_index
    entryPrice := entryFinal
    stopPrice := stopFinal
    initialStopPrice := stopFinal  // Store for trailing stop risk calc
    targetPrice := targetFinal
    // Reset trailing/EMA exit state
    trailingStopActivated := false
    trailingStopLevel := na
    barsUnderEma := 0
    barsOverEma := 0

    float beThresholdAdj = breakEvenRREff
    if useAdaptiveBEEff
        if volState == "LOW"
            beThresholdAdj := breakEvenRREff + 0.2
        else if volState == "HIGH"
            beThresholdAdj := breakEvenRREff - 0.1
        else if volState == "EXTREME"
            beThresholdAdj := breakEvenRREff - 0.2

    breakEvenPrice := entryPrice + ((entryPrice - stopPrice) * beThresholdAdj)
    entryBar := bar_index
    
    lastRRUsed := candRR
    lastTargetATRs := candTargetATRs
    lastVolState := volState
    lastAtrRR := atrBestRR
    lastSwingRR := swingBestRR
    lastVwapRR := vwapBestRR
    lastHybridRR := hybridBestRR
    lastStopTypeUsed := candStopType
    
    positionSize := candRiskPerShare > 0 ? fixedRisk / candRiskPerShare : 0
    breakEvenActivated := false
    targetGrade := candGrade
    
    color labelColor = f_trafficLightColor(bullScore, candGrade, volState)
    color textCol = labelColor == color.new(#00FF00, 0) ? color.black : color.white
    
    addManagedLabel(bar_index, low - labelOffsetDynamic, 
         "▲ LONG @ " + entryStr + " [" + volState + "]\n" +
         str.tostring(int(positionSize)) + " shares | " + candStopType + " Stop: " + stopStr + "\n" +
         str.tostring(candRR, "#.#") + ":1 (" + candGrade + ") [min:" + str.tostring(minAcceptableRREff, "#.#") + "]",
         labelColor,
         label.style_label_up, 
         textCol, 
         getLabelSize())
    
    // ═══════════════════════════════════════════════════════════════
    // TRADE BOX VISUALIZER - Create risk/reward boxes on entry
    // ═══════════════════════════════════════════════════════════════
    if showTradeBoxes
        // Delete any existing boxes from previous trade (safe on na)
        box.delete(riskBox)
        box.delete(rewardBox)
        line.delete(entryLine)
        line.delete(stopLine)
        line.delete(targetLine)
        label.delete(rrLabel)
        
        // Create risk box (entry to stop) - RED
        riskBox := box.new(
             left=bar_index, right=bar_index + 1,
             top=entryFinal, bottom=stopFinal,
             bgcolor=color.new(color.red, 85),
             border_color=color.new(color.red, 60),
             border_width=1)
        
        // Create reward box (entry to target) - GREEN
        rewardBox := box.new(
             left=bar_index, right=bar_index + 1,
             top=targetFinal, bottom=entryFinal,
             bgcolor=color.new(color.green, 85),
             border_color=color.new(color.green, 60),
             border_width=1)
        
        // Create horizontal lines
        entryLine := line.new(bar_index, entryFinal, bar_index + 1, entryFinal,
             color=color.white, width=2, style=line.style_solid)
        stopLine := line.new(bar_index, stopFinal, bar_index + 1, stopFinal,
             color=color.red, width=1, style=line.style_dashed)
        targetLine := line.new(bar_index, targetFinal, bar_index + 1, targetFinal,
             color=color.green, width=1, style=line.style_dashed)
        
        // R:R label at target
        rrLabel := label.new(bar_index, targetFinal,
             str.tostring(candRR, "#.#") + "R",
             color=color.new(color.green, 80),
             textcolor=color.white,
             style=label.style_label_down,
             size=size.small)
    
    float swingLowVal = findSwingLowRegularHours(swingLookback)
    
    tradeCounter += 1
    string tradeId = syminfo.ticker + "_" + str.tostring(tradeCounter)
    
    string symtf = syminfo.ticker + " " + timeframe.period
    int shares = int(positionSize)
    
    string longEntryMsg = "HMM|" + symtf + " | LONG"
    longEntryMsg += " | EstEntry=" + entryStr
    longEntryMsg += " | EstStop=" + stopStr
    longEntryMsg += " | Target=" + targetStr
    longEntryMsg += " | Shares=" + str.tostring(shares, "#")
    longEntryMsg += " | StopType=" + candStopType
    longEntryMsg += " | ATR=" + str.tostring(atr, "#.####")
    longEntryMsg += " | ATRMult=" + str.tostring(atrStopMultiplierEff, "#.#")
    longEntryMsg += " | SwingLevel=" + str.tostring(swingLowVal, "#.##")
    longEntryMsg += " | SwingBuffer=" + str.tostring(swingBufferEff, "#.##")
    longEntryMsg += " | VWAP=" + str.tostring(vwapValue, "#.##")
    longEntryMsg += " | VWAPDist=" + str.tostring(vwapStopDistanceEff, "#.#")
    longEntryMsg += " | RRUsed=" + str.tostring(candRR, "#.#")
    longEntryMsg += " | TargetATR=" + str.tostring(candTargetATRs, "#.##")
    longEntryMsg += " | VolState=" + volState
    longEntryMsg += " | TradeID=" + tradeId
    longEntryMsg += " | TradeGrade=" + candGrade
    longEntryMsg += " | CandleTime=" + str.format("{0,date,yyyy-MM-dd HH:mm}", time_close)
    longEntryMsg += " | Bar=" + str.tostring(bar_index)
    
    // ALERT FIRES UNCONDITIONALLY - signal guarantees feasibility
    alert(longEntryMsg, alert.freq_once_per_bar_close)

// ══════════════════════════════════════════════════════════════════════════
// LONG SKIP LABEL - Conditions met but feasibility failed (NO ALERT)
// ══════════════════════════════════════════════════════════════════════════
if barstate.isconfirmed and newLongSkip and showEntrySignals
    addManagedLabel(bar_index, low - labelOffsetDynamic, 
             "SKIP: " + str.tostring(nz(preCandRRL, 0), "#.#") + ":1 @ bar " + str.tostring(bar_index) + "\n" + skipReasonLong, 
             color.new(color.gray, 10), 
             label.style_label_up, 
             color.white, 
             size.small)

// ══════════════════════════════════════════════════════════════════════════
// SHORT ENTRY BLOCK - ORB Architecture (signal guarantees feasibility)
// ══════════════════════════════════════════════════════════════════════════
if barstate.isconfirmed and newShortSignal
    // Signal fired = trade IS feasible (checked in signal definition)
    // STEP 1: CALCULATE DESIRED R:R BASED ON VOLATILITY
    float rrDesired = riskRewardRatio
    if useAdaptiveVolatility
        if volState == "LOW"
            rrDesired := riskRewardRatio + 0.5
        else if volState == "NORMAL"
            rrDesired := riskRewardRatio
        else if volState == "HIGH"
            rrDesired := math.max(1.2, riskRewardRatio - 0.5)
        else  // EXTREME
            rrDesired := math.max(1.0, riskRewardRatio - 0.8)

    // STEP 2: GET ALL STOP OPTIONS FROM SINGLE ENGINE
    float candEntry = close
    [bestStop, bestType, bestRR, atrBestRR, swingBestRR, vwapBestRR, hybridBestRR] = evaluateBestStop(false, candEntry, atr, vwapValue, rrDesired, maxTargetATREff, minAcceptableRREff)
    
    // STEP 3: SELECT STOP (auto or manual) - ALL USE evaluateBestStop R:Rs
    float candStop = na
    string candStopType = ""
    float candRR = na
    
    if autoSelectStop and useAdaptiveVolatility
        candStop := bestStop
        candStopType := bestType
        candRR := bestRR
    else
        string stopTypeForThisTrade = stopLossType
        if useAdaptiveVolatility and (volState == "HIGH" or volState == "EXTREME")
            stopTypeForThisTrade := stopLossType == "ATR" ? "Hybrid" : stopLossType
        
        if stopTypeForThisTrade == "ATR"
            candStop := candEntry + (atr * atrStopMultiplierEff)
            candStopType := "ATR"
            candRR := atrBestRR
        else if stopTypeForThisTrade == "Swing"
            float swingHigh = findSwingHighRegularHours(swingLookback)
            float swingStopCalc = swingHigh + (atr * swingBufferEff)
            bool swingOK = swingStopCalc > candEntry + (atr * 0.15)
            candStop := swingOK ? swingStopCalc : candEntry + (atr * atrStopMultiplierEff)
            candStopType := swingOK ? "Swing" : "ATR-Fallback"
            candRR := swingOK and swingBestRR > 0 ? swingBestRR : atrBestRR
        else if stopTypeForThisTrade == "VWAP"
            float vwapStopCalc = vwapValue + (atr * vwapStopDistanceEff)
            bool vwapOK = vwapValue > candEntry and vwapStopCalc > candEntry + (atr * 0.15)
            candStop := vwapOK ? vwapStopCalc : candEntry + (atr * atrStopMultiplierEff)
            candStopType := vwapOK ? "VWAP" : "ATR-Fallback"
            candRR := vwapOK and vwapBestRR > 0 ? vwapBestRR : atrBestRR
        else if stopTypeForThisTrade == "Manual"
            candStop := candEntry + manualStopPoints
            candStopType := "Manual"
            float manualRisk = math.abs(candEntry - candStop)
            float manualTargetATRs = manualRisk > 0 ? (manualRisk * rrDesired) / atr : 999
            candRR := manualTargetATRs <= maxTargetATREff ? rrDesired : (manualRisk > 0 ? (maxTargetATREff * atr) / manualRisk : 0)
        else  // Hybrid
            float atrStopS = candEntry + (atr * atrStopMultiplierEff)
            float swingHigh = findSwingHighRegularHours(swingLookback)
            float swingStopS = swingHigh + (atr * swingBufferEff)
            float vwapStopS = vwapValue + (atr * vwapStopDistanceEff)
            bool swingOK = swingStopS > candEntry + (atr * 0.15)
            bool vwapOK = vwapValue > candEntry and vwapStopS > candEntry + (atr * 0.15)
            swingStopS := swingOK ? swingStopS : atrStopS
            vwapStopS := vwapOK ? vwapStopS : atrStopS
            candStop := hybridExcludeVwap ? math.min(atrStopS, swingStopS) : math.min(atrStopS, math.min(swingStopS, vwapStopS))
            candStopType := "Hybrid"
            candRR := hybridBestRR > 0 ? hybridBestRR : atrBestRR
    
    // Calculate derived values
    float candRiskPerShare = math.abs(candStop - candEntry)
    float candTarget = candEntry - (candRiskPerShare * candRR)
    float candTargetATRs = math.abs(candEntry - candTarget) / atr
    
    // COMPOSITE TRADE GRADE - Single grade for instant decision making
    string candGrade = f_compositeGrade(candRR, bearScore, volState, false, close)
    
    // ENTRY EXECUTION - No inner gate needed (signal guarantees feasibility)
    float entryFinal = math.round(candEntry / syminfo.mintick) * syminfo.mintick
    float stopFinal = math.round(candStop / syminfo.mintick) * syminfo.mintick
    float targetFinal = math.round(candTarget / syminfo.mintick) * syminfo.mintick
    
    string entryStr = str.tostring(entryFinal, "#.##")
    string stopStr = str.tostring(stopFinal, "#.##")
    string targetStr = str.tostring(targetFinal, "#.##")
    
    tradeState := -1
    lastEntryBar := bar_index
    entryPrice := entryFinal
    stopPrice := stopFinal
    initialStopPrice := stopFinal  // Store for trailing stop risk calc
    targetPrice := targetFinal
    // Reset trailing/EMA exit state
    trailingStopActivated := false
    trailingStopLevel := na
    barsUnderEma := 0
    barsOverEma := 0

    float beThresholdAdj = breakEvenRREff
    if useAdaptiveBEEff
        if volState == "LOW"
            beThresholdAdj := breakEvenRREff + 0.2
        else if volState == "HIGH"
            beThresholdAdj := breakEvenRREff - 0.1
        else if volState == "EXTREME"
            beThresholdAdj := breakEvenRREff - 0.2

    breakEvenPrice := entryPrice - ((stopPrice - entryPrice) * beThresholdAdj)
    entryBar := bar_index
    
    lastRRUsed := candRR
    lastTargetATRs := candTargetATRs
    lastVolState := volState
    lastAtrRR := atrBestRR
    lastSwingRR := swingBestRR
    lastVwapRR := vwapBestRR
    lastHybridRR := hybridBestRR
    lastStopTypeUsed := candStopType
    
    positionSize := candRiskPerShare > 0 ? fixedRisk / candRiskPerShare : 0
    breakEvenActivated := false
    targetGrade := candGrade
    
    color labelColor = f_trafficLightColor(bearScore, candGrade, volState)
    color textCol = labelColor == color.new(#00FF00, 0) ? color.black : color.white
    
    addManagedLabel(bar_index, high + labelOffsetDynamic, 
         "▼ SHORT @ " + entryStr + " [" + volState + "]\n" +
         str.tostring(int(positionSize)) + " shares | " + candStopType + " Stop: " + stopStr + "\n" +
         str.tostring(candRR, "#.#") + ":1 (" + candGrade + ") [min:" + str.tostring(minAcceptableRREff, "#.#") + "]",
         labelColor,
         label.style_label_down, 
         textCol, 
         getLabelSize())
    
    // ═══════════════════════════════════════════════════════════════
    // TRADE BOX VISUALIZER - Create risk/reward boxes on entry
    // ═══════════════════════════════════════════════════════════════
    if showTradeBoxes
        // Delete any existing boxes from previous trade (safe on na)
        box.delete(riskBox)
        box.delete(rewardBox)
        line.delete(entryLine)
        line.delete(stopLine)
        line.delete(targetLine)
        label.delete(rrLabel)
        
        // Create risk box (entry to stop) - RED (stop is ABOVE entry for shorts)
        riskBox := box.new(
             left=bar_index, right=bar_index + 1,
             top=stopFinal, bottom=entryFinal,
             bgcolor=color.new(color.red, 85),
             border_color=color.new(color.red, 60),
             border_width=1)
        
        // Create reward box (entry to target) - GREEN (target is BELOW entry for shorts)
        rewardBox := box.new(
             left=bar_index, right=bar_index + 1,
             top=entryFinal, bottom=targetFinal,
             bgcolor=color.new(color.green, 85),
             border_color=color.new(color.green, 60),
             border_width=1)
        
        // Create horizontal lines
        entryLine := line.new(bar_index, entryFinal, bar_index + 1, entryFinal,
             color=color.white, width=2, style=line.style_solid)
        stopLine := line.new(bar_index, stopFinal, bar_index + 1, stopFinal,
             color=color.red, width=1, style=line.style_dashed)
        targetLine := line.new(bar_index, targetFinal, bar_index + 1, targetFinal,
             color=color.green, width=1, style=line.style_dashed)
        
        // R:R label at target
        rrLabel := label.new(bar_index, targetFinal,
             str.tostring(candRR, "#.#") + "R",
             color=color.new(color.green, 80),
             textcolor=color.white,
             style=label.style_label_up,
             size=size.small)
    
    float swingHighVal = findSwingHighRegularHours(swingLookback)
    
    tradeCounter += 1
    string tradeId = syminfo.ticker + "_" + str.tostring(tradeCounter)
    
    string symtf = syminfo.ticker + " " + timeframe.period
    int shares = int(positionSize)
    
    string shortEntryMsg = "HMM|" + symtf + " | SHORT"
    shortEntryMsg += " | EstEntry=" + entryStr
    shortEntryMsg += " | EstStop=" + stopStr
    shortEntryMsg += " | Target=" + targetStr
    shortEntryMsg += " | Shares=" + str.tostring(shares, "#")
    shortEntryMsg += " | StopType=" + candStopType
    shortEntryMsg += " | ATR=" + str.tostring(atr, "#.####")
    shortEntryMsg += " | ATRMult=" + str.tostring(atrStopMultiplierEff, "#.#")
    shortEntryMsg += " | SwingLevel=" + str.tostring(swingHighVal, "#.##")
    shortEntryMsg += " | SwingBuffer=" + str.tostring(swingBufferEff, "#.##")
    shortEntryMsg += " | VWAP=" + str.tostring(vwapValue, "#.##")
    shortEntryMsg += " | VWAPDist=" + str.tostring(vwapStopDistanceEff, "#.#")
    shortEntryMsg += " | RRUsed=" + str.tostring(candRR, "#.#")
    shortEntryMsg += " | TargetATR=" + str.tostring(candTargetATRs, "#.##")
    shortEntryMsg += " | VolState=" + volState
    shortEntryMsg += " | TradeID=" + tradeId
    shortEntryMsg += " | TradeGrade=" + candGrade
    shortEntryMsg += " | CandleTime=" + str.format("{0,date,yyyy-MM-dd HH:mm}", time_close)
    shortEntryMsg += " | Bar=" + str.tostring(bar_index)
    
    // ALERT FIRES UNCONDITIONALLY - signal guarantees feasibility
    alert(shortEntryMsg, alert.freq_once_per_bar_close)

// ══════════════════════════════════════════════════════════════════════════
// SHORT SKIP LABEL - Conditions met but feasibility failed (NO ALERT)
// ══════════════════════════════════════════════════════════════════════════
if barstate.isconfirmed and newShortSkip and showEntrySignals
    addManagedLabel(bar_index, high + labelOffsetDynamic, 
             "SKIP: " + str.tostring(nz(preCandRRS, 0), "#.#") + ":1 @ bar " + str.tostring(bar_index) + "\n" + skipReasonShort, 
             color.new(color.gray, 10), 
             label.style_label_down, 
             color.white, 
             size.small)


// POSITION MANAGEMENT (Break-Even Logic)
// ========================================

// Check and activate break-even for LONG positions
// ═══════════════════════════════════════════════════════════════════════════
// STOP LOSS CHECK - Must happen BEFORE break-even activation
// This ensures original stop is honored even if BE threshold hit on same bar
// ═══════════════════════════════════════════════════════════════════════════

// LONG stop loss check (BEFORE BE moves the stop)
if inLongPosition and low <= stopPrice and bar_index > entryBar
    exitPrice = stopPrice
    tradeProfit = (exitPrice - entryPrice) * positionSize
    totalPnL += tradeProfit
    lastTradePnL := tradeProfit
    winCount := tradeProfit > 0 ? winCount + 1 : winCount
    lossCount := tradeProfit < 0 ? lossCount + 1 : lossCount
    maxWin := tradeProfit > 0 ? math.max(maxWin, tradeProfit) : maxWin
    maxLoss := tradeProfit < 0 ? math.min(maxLoss, tradeProfit) : maxLoss
    if showEntrySignals
        addManagedLabel(bar_index, low - (labelOffsetDynamic * 0.5), trailingStopActivated ? "TRAIL STOP" : (breakEvenActivated ? "BE STOP" : "STOP LOSS"), color.new(color.red, 10), label.style_label_up, color.white, size.tiny)
    tradeState := 0
    hasIBBreakUp := false
    trailingStopActivated := false
    trailingStopLevel := na
    initialStopPrice := na
    line.delete(entryLine)
    line.delete(stopLine)
    line.delete(targetLine)
    box.delete(riskBox)
    box.delete(rewardBox)
    label.delete(rrLabel)
    entryLine := na
    stopLine := na
    targetLine := na
    riskBox := na
    rewardBox := na
    rrLabel := na

// SHORT stop loss check (BEFORE BE moves the stop)
if inShortPosition and high >= stopPrice and bar_index > entryBar
    exitPrice = stopPrice
    tradeProfit = (entryPrice - exitPrice) * positionSize
    totalPnL += tradeProfit
    lastTradePnL := tradeProfit
    winCount := tradeProfit > 0 ? winCount + 1 : winCount
    lossCount := tradeProfit < 0 ? lossCount + 1 : lossCount
    maxWin := tradeProfit > 0 ? math.max(maxWin, tradeProfit) : maxWin
    maxLoss := tradeProfit < 0 ? math.min(maxLoss, tradeProfit) : maxLoss
    if showEntrySignals
        addManagedLabel(bar_index, high + (labelOffsetDynamic * 0.5), trailingStopActivated ? "TRAIL STOP" : (breakEvenActivated ? "BE STOP" : "STOP LOSS"), color.new(color.red, 10), label.style_label_down, color.white, size.tiny)
    tradeState := 0
    hasIBBreakDown := false
    trailingStopActivated := false
    trailingStopLevel := na
    initialStopPrice := na
    line.delete(entryLine)
    line.delete(stopLine)
    line.delete(targetLine)
    box.delete(riskBox)
    box.delete(rewardBox)
    label.delete(rrLabel)
    entryLine := na
    stopLine := na
    targetLine := na
    riskBox := na
    rewardBox := na
    rrLabel := na

// ═══════════════════════════════════════════════════════════════════════════
// BREAK-EVEN ACTIVATION - Only runs if stop wasn't hit
// ═══════════════════════════════════════════════════════════════════════════

// Check and activate break-even for LONG positions
if inLongPosition and useBreakEven and not breakEvenActivated
    if high >= breakEvenPrice
        stopPrice := entryPrice  // Move stop to entry (break-even)
        breakEvenActivated := true
        if showEntrySignals
            addManagedLabel(bar_index, low - labelOffsetDynamic, 
                     "BE STOP", 
                     color.new(color.purple, 50), 
                     label.style_label_up, 
                     color.white, 
                     size.small)

// Check and activate break-even for SHORT positions
if inShortPosition and useBreakEven and not breakEvenActivated
    if low <= breakEvenPrice
        stopPrice := entryPrice  // Move stop to entry (break-even)
        breakEvenActivated := true
        if showEntrySignals
            addManagedLabel(bar_index, high + labelOffsetDynamic,
                     "BE STOP",
                     color.new(color.purple, 50),
                     label.style_label_down,
                     color.white,
                     size.small)

// ═══════════════════════════════════════════════════════════════════════════
// TRAILING STOP LOGIC (synced with ORB)
// ═══════════════════════════════════════════════════════════════════════════

// LONG Trailing Stop
if inLongPosition and breakEvenActivated and useTrailingStop and not na(entryPrice) and not na(initialStopPrice)
    float longRisk = math.abs(entryPrice - initialStopPrice)
    float profitTargetPrice = entryPrice + (longRisk * profitTargetRREff)

    // Activate trailing when profit target reached
    if not trailingStopActivated and close >= profitTargetPrice
        trailingStopActivated := true
        trailingStopLevel := close - (atr * trailingStopDistanceEff)
        if showEntrySignals
            addManagedLabel(bar_index, high + labelOffsetDynamic,
                     "TRAIL",
                     color.new(color.blue, 50),
                     label.style_label_down,
                     color.white,
                     size.small)

    // Update trailing stop (ratchet up, never down)
    if trailingStopActivated
        float currentTrailDist = trailingStopDistanceEff
        if aggressiveTrailingEff
            float distToEma = math.abs(close - ema9)
            if distToEma <= (atr * emaTightenZoneEff)
                currentTrailDist := tightenedTrailDistanceEff

        float newTrailLevel = close - (atr * currentTrailDist)
        if newTrailLevel > trailingStopLevel
            trailingStopLevel := newTrailLevel

        // Trailing stop supersedes BE stop
        stopPrice := math.max(trailingStopLevel, entryPrice)

// SHORT Trailing Stop
if inShortPosition and breakEvenActivated and useTrailingStop and not na(entryPrice) and not na(initialStopPrice)
    float shortRisk = math.abs(entryPrice - initialStopPrice)
    float profitTargetPrice = entryPrice - (shortRisk * profitTargetRREff)

    // Activate trailing when profit target reached
    if not trailingStopActivated and close <= profitTargetPrice
        trailingStopActivated := true
        trailingStopLevel := close + (atr * trailingStopDistanceEff)
        if showEntrySignals
            addManagedLabel(bar_index, low - labelOffsetDynamic,
                     "TRAIL",
                     color.new(color.blue, 50),
                     label.style_label_up,
                     color.white,
                     size.small)

    // Update trailing stop (ratchet down, never up)
    if trailingStopActivated
        float currentTrailDist = trailingStopDistanceEff
        if aggressiveTrailingEff
            float distToEma = math.abs(close - ema9)
            if distToEma <= (atr * emaTightenZoneEff)
                currentTrailDist := tightenedTrailDistanceEff

        float newTrailLevel = close + (atr * currentTrailDist)
        if newTrailLevel < trailingStopLevel
            trailingStopLevel := newTrailLevel

        // Trailing stop supersedes BE stop
        stopPrice := math.min(trailingStopLevel, entryPrice)

// ═══════════════════════════════════════════════════════════════════════════
// TRADE BOX VISUALIZER - Update boxes every bar while in position
// ═══════════════════════════════════════════════════════════════════════════
if showTradeBoxes and (inLongPosition or inShortPosition)
    // Extend boxes to current bar
    if not na(riskBox)
        box.set_right(riskBox, bar_index + 1)
        // Update stop level if it changed (trailing stop or BE)
        if inLongPosition
            box.set_bottom(riskBox, stopPrice)
        else
            box.set_top(riskBox, stopPrice)
    
    if not na(rewardBox)
        box.set_right(rewardBox, bar_index + 1)
    
    if not na(entryLine)
        line.set_x2(entryLine, bar_index + 1)
    
    if not na(stopLine)
        line.set_x2(stopLine, bar_index + 1)
        line.set_y1(stopLine, stopPrice)
        line.set_y2(stopLine, stopPrice)
    
    if not na(targetLine)
        line.set_x2(targetLine, bar_index + 1)
    
    // Update R:R label position and value (recalculate current R:R)
    if not na(rrLabel)
        float currentRisk = math.abs(entryPrice - stopPrice)
        float currentReward = math.abs(targetPrice - entryPrice)
        float currentRR = currentRisk > 0 ? currentReward / currentRisk : 0
        label.set_x(rrLabel, bar_index)
        label.set_text(rrLabel, str.tostring(currentRR, "#.#") + "R")
        
        // Change color based on BE status
        if breakEvenActivated
            label.set_color(rrLabel, color.new(color.blue, 80))

// Note: Stop loss checks moved BEFORE break-even activation (see earlier in code)
// This ensures original stop is honored even if BE threshold hit on same bar

// SSL WARNING SIGNALS (informative only)
if inLongPosition and sslExitShort
    if showEntrySignals
        addManagedLabel(bar_index, high + labelOffsetDynamic, 
                 "SSL", 
                 color.new(color.orange, 10), 
                 label.style_label_down, 
                 color.white, 
                 getLabelSize())

if inShortPosition and sslExitLong
    if showEntrySignals
        addManagedLabel(bar_index, low - labelOffsetDynamic, 
                 "SSL", 
                 color.new(color.orange, 10), 
                 label.style_label_up, 
                 color.white, 
                 getLabelSize())

// EMA EXIT SIGNALS (synced with ORB - after SSL breach + BE, with confirmation)
// Only trigger if useEmaCrossExitEff is enabled and NOT trailing
if useEmaCrossExitEff and emaExitLong and inLongPosition and not trailingStopActivated and (breakEvenActivated or close > entryPrice)
    tradeProfit = (close - entryPrice) * positionSize
    totalPnL += tradeProfit
    lastTradePnL := tradeProfit
    winCount := tradeProfit > 0 ? winCount + 1 : winCount
    lossCount := tradeProfit < 0 ? lossCount + 1 : lossCount
    maxWin := tradeProfit > 0 ? math.max(maxWin, tradeProfit) : maxWin
    maxLoss := tradeProfit < 0 ? math.min(maxLoss, tradeProfit) : maxLoss
    if showEntrySignals
        addManagedLabel(bar_index, high + labelOffsetDynamic, "EMA EXIT", color.new(color.red, 10), label.style_label_down, color.white, getLabelSize())
    tradeState := 0
    hasIBBreakUp := false
    entryPrice := na
    stopPrice := na
    initialStopPrice := na
    targetPrice := na
    entryBar := na
    positionSize := na
    breakEvenActivated := false
    trailingStopActivated := false
    trailingStopLevel := na
    sslBreachedLong := false
    line.delete(entryLine)
    line.delete(stopLine)
    line.delete(targetLine)
    box.delete(riskBox)
    box.delete(rewardBox)
    label.delete(rrLabel)
    entryLine := na
    stopLine := na
    targetLine := na
    riskBox := na
    rewardBox := na
    rrLabel := na

// 9/20 EMA Cross Exit LONG - Alternative (handled via combined condition above)
// Merged into emaExitLong block - emaCrossExitLong triggers same cleanup

if emaCrossExitLong and inLongPosition
    tradeProfit = (close - entryPrice) * positionSize
    totalPnL += tradeProfit
    lastTradePnL := tradeProfit
    winCount := tradeProfit > 0 ? winCount + 1 : winCount
    lossCount := tradeProfit < 0 ? lossCount + 1 : lossCount
    maxWin := tradeProfit > 0 ? math.max(maxWin, tradeProfit) : maxWin
    maxLoss := tradeProfit < 0 ? math.min(maxLoss, tradeProfit) : maxLoss
    if showEntrySignals
        addManagedLabel(bar_index, high + labelOffsetDynamic, "9/20 EXIT", color.new(color.orange, 10), label.style_label_down, color.white, getLabelSize())
    tradeState := 0
    hasIBBreakUp := false
    entryPrice := na
    stopPrice := na
    initialStopPrice := na
    targetPrice := na
    entryBar := na
    positionSize := na
    breakEvenActivated := false
    trailingStopActivated := false
    trailingStopLevel := na
    sslBreachedLong := false
    line.delete(entryLine)
    line.delete(stopLine)
    line.delete(targetLine)
    box.delete(riskBox)
    box.delete(rewardBox)
    label.delete(rrLabel)
    entryLine := na
    stopLine := na
    targetLine := na
    riskBox := na
    rewardBox := na
    rrLabel := na

// EMA EXIT SHORT (synced with ORB)
if useEmaCrossExitEff and emaExitShort and inShortPosition and not trailingStopActivated and (breakEvenActivated or close < entryPrice)
    tradeProfit = (entryPrice - close) * positionSize
    totalPnL += tradeProfit
    lastTradePnL := tradeProfit
    winCount := tradeProfit > 0 ? winCount + 1 : winCount
    lossCount := tradeProfit < 0 ? lossCount + 1 : lossCount
    maxWin := tradeProfit > 0 ? math.max(maxWin, tradeProfit) : maxWin
    maxLoss := tradeProfit < 0 ? math.min(maxLoss, tradeProfit) : maxLoss
    if showEntrySignals
        addManagedLabel(bar_index, low - labelOffsetDynamic, "EMA EXIT", color.new(color.red, 10), label.style_label_up, color.white, getLabelSize())
    tradeState := 0
    hasIBBreakDown := false
    entryPrice := na
    stopPrice := na
    initialStopPrice := na
    targetPrice := na
    entryBar := na
    positionSize := na
    breakEvenActivated := false
    trailingStopActivated := false
    trailingStopLevel := na
    sslBreachedShort := false
    line.delete(entryLine)
    line.delete(stopLine)
    line.delete(targetLine)
    box.delete(riskBox)
    box.delete(rewardBox)
    label.delete(rrLabel)
    entryLine := na
    stopLine := na
    targetLine := na
    riskBox := na
    rewardBox := na
    rrLabel := na

// 9/20 EMA Cross Exit SHORT - Alternative (synced with ORB)
if emaCrossExitShort and inShortPosition
    tradeProfit = (entryPrice - close) * positionSize
    totalPnL += tradeProfit
    lastTradePnL := tradeProfit
    winCount := tradeProfit > 0 ? winCount + 1 : winCount
    lossCount := tradeProfit < 0 ? lossCount + 1 : lossCount
    maxWin := tradeProfit > 0 ? math.max(maxWin, tradeProfit) : maxWin
    maxLoss := tradeProfit < 0 ? math.min(maxLoss, tradeProfit) : maxLoss
    if showEntrySignals
        addManagedLabel(bar_index, low - labelOffsetDynamic, "9/20 EXIT", color.new(color.orange, 10), label.style_label_up, color.white, getLabelSize())
    tradeState := 0
    hasIBBreakDown := false
    entryPrice := na
    stopPrice := na
    initialStopPrice := na
    targetPrice := na
    entryBar := na
    positionSize := na
    breakEvenActivated := false
    trailingStopActivated := false
    trailingStopLevel := na
    sslBreachedShort := false
    line.delete(entryLine)
    line.delete(stopLine)
    line.delete(targetLine)
    box.delete(riskBox)
    box.delete(rewardBox)
    label.delete(rrLabel)
    entryLine := na
    stopLine := na
    targetLine := na
    riskBox := na
    rewardBox := na
    rrLabel := na
// ========================================
// ========================================
// END-OF-DAY EXIT - Close All Positions at Market Close
// ========================================

// EOD EXIT LONG
if eodExitLong
    tradeProfit = (close - entryPrice) * positionSize
    totalPnL += tradeProfit
    lastTradePnL := tradeProfit
    winCount := tradeProfit > 0 ? winCount + 1 : winCount
    lossCount := tradeProfit < 0 ? lossCount + 1 : lossCount
    maxWin := tradeProfit > 0 ? math.max(maxWin, tradeProfit) : maxWin
    maxLoss := tradeProfit < 0 ? math.min(maxLoss, tradeProfit) : maxLoss
    if showEntrySignals
        addManagedLabel(bar_index, high + labelOffsetDynamic, "EOD EXIT", color.new(color.purple, 10), label.style_label_down, color.white, getLabelSize())
    tradeState := 0
    hasIBBreakUp := false
    entryPrice := na
    stopPrice := na
    initialStopPrice := na
    targetPrice := na
    entryBar := na
    positionSize := na
    breakEvenActivated := false
    trailingStopActivated := false
    trailingStopLevel := na
    sslBreachedLong := false
    line.delete(entryLine)
    line.delete(stopLine)
    line.delete(targetLine)
    box.delete(riskBox)
    box.delete(rewardBox)
    label.delete(rrLabel)
    entryLine := na
    stopLine := na
    targetLine := na
    riskBox := na
    rewardBox := na
    rrLabel := na

// EOD EXIT SHORT
if eodExitShort
    tradeProfit = (entryPrice - close) * positionSize
    totalPnL += tradeProfit
    lastTradePnL := tradeProfit
    winCount := tradeProfit > 0 ? winCount + 1 : winCount
    lossCount := tradeProfit < 0 ? lossCount + 1 : lossCount
    maxWin := tradeProfit > 0 ? math.max(maxWin, tradeProfit) : maxWin
    maxLoss := tradeProfit < 0 ? math.min(maxLoss, tradeProfit) : maxLoss
    if showEntrySignals
        addManagedLabel(bar_index, low - labelOffsetDynamic, "EOD EXIT", color.new(color.purple, 10), label.style_label_up, color.white, getLabelSize())
    tradeState := 0
    hasIBBreakDown := false
    entryPrice := na
    stopPrice := na
    initialStopPrice := na
    targetPrice := na
    entryBar := na
    positionSize := na
    breakEvenActivated := false
    trailingStopActivated := false
    trailingStopLevel := na
    sslBreachedShort := false
    // Delete risk/reward lines and trade boxes
    line.delete(entryLine)
    entryLine := na
    line.delete(stopLine)
    stopLine := na
    line.delete(targetLine)
    targetLine := na
    box.delete(riskBox)
    riskBox := na
    box.delete(rewardBox)
    rewardBox := na
    label.delete(rrLabel)
    rrLabel := na

// P/L CALCULATION
// ========================================

// Calculate P/L in dollars for current positions
if inLongPosition and not na(entryPrice) and not na(positionSize)
    longPnlDollars := (close - entryPrice) * positionSize
else
    longPnlDollars := na

if inShortPosition and not na(entryPrice) and not na(positionSize)
    shortPnlDollars := (entryPrice - close) * positionSize
else
    shortPnlDollars := na
// ========================================
// ALERT CONDITIONS
// ========================================



// ========================================
// PLOTTING
// ========================================

// SSL plots with smoother lines
baselineColor = sslBullishSimple ? color.new(color.green, 40) : color.new(color.red, 40)
plot(showSSL ? baseline : na, "SSL Baseline", color=baselineColor, linewidth=2, style=plot.style_line)

// Add a subtle gradient fill between price and baseline for visual clarity
baselinePlot = plot(showSSL ? baseline : na, display=display.none)
pricePlot = plot(showSSL ? close : na, display=display.none)
fill(pricePlot, baselinePlot, color=sslBullishSimple ? color.new(color.green, 95) : color.new(color.red, 95))

plot(showSSL ? sslExit : na, "SSL Exit Line", color=color.new(color.purple, 70), linewidth=1)

// Plot 9 EMA for reference
plot(ta.ema(close, 9), "9 EMA", color=color.new(color.yellow, 50), linewidth=1)

// Entry Arrows - only show when trade ACTUALLY executes (state change)
plotshape(showEntrySignals and tradeState == 1 and tradeState[1] != 1, title="Long Entry", location=location.belowbar, color=color.green, style=shape.arrowup, size=size.normal)
plotshape(showEntrySignals and tradeState == -1 and tradeState[1] != -1, title="Short Entry", location=location.abovebar, color=color.red, style=shape.arrowdown, size=size.normal)

// SSL Exit Arrows (only show when in position)
plotshape(showEntrySignals and inLongPosition and sslExitLong, title="SSL Warning Long", location=location.belowbar, color=color.orange, style=shape.arrowup, size=size.small)
plotshape(showEntrySignals and inShortPosition and sslExitShort, title="SSL Warning Short", location=location.abovebar, color=color.orange, style=shape.arrowdown, size=size.small)

// Risk/reward lines
if showRiskLines and (inLongPosition or inShortPosition)
    // Delete old lines before creating new ones
    if not na(entryLine)
        line.delete(entryLine)
    if not na(stopLine)
        line.delete(stopLine)
    if not na(targetLine)
        line.delete(targetLine)
    
    // Create new lines
    entryLine := line.new(entryBar, entryPrice, bar_index + 10, entryPrice, color=color.blue, width=1, style=line.style_solid)
    stopLine := line.new(entryBar, stopPrice, bar_index + 10, stopPrice, color=color.red, width=1, style=line.style_dashed)
    targetLine := line.new(entryBar, targetPrice, bar_index + 10, targetPrice, color=color.green, width=1, style=line.style_dashed)

// Background coloring (more subtle)
bgcolor(sslBullishSimple ? color.new(color.green, 97) : sslBearishSimple ? color.new(color.red, 97) : na)

// Squeeze zone shading
sqzColor = sqzBullish ? color.new(color.aqua, sqzTransparency) : color.new(color.fuchsia, sqzTransparency)
bgcolor(showSqueeze and sqzOn ? sqzColor : na, title="Squeeze Zone")

// =====================================================
// CAM STATE BADGE (PHASE 2 – STEP 1)
// =====================================================
showCamStateBadge = input.bool(true, "Show CAM State Badge", group="Display Settings")


// =====================================================
// CAM LEVEL CALCULATIONS (PHASE 2 – STEP 1.5)
// Auto RTH/ETH to match Bruz's logic
// =====================================================

// =====================================================
// DAILY TIMEFRAME DATA (request.security method)
// More accurate - uses official exchange daily OHLC
// =====================================================
// Get previous day's RTH data from daily timeframe
[dailyPrevHigh, dailyPrevLow, dailyPrevClose] = request.security(syminfo.tickerid, "D", [high[1], low[1], close[1]], barmerge.gaps_off, barmerge.lookahead_on)

// RTH session: 9:30 AM - 4:00 PM ET
rthSession = "0930-1600:23456"
inRTH = not na(time(timeframe.period, rthSession, "America/New_York"))

// Pre-market: 4:00 AM - 9:30 AM ET
preSession = "0400-0930:23456"
inPre = not na(time(timeframe.period, preSession, "America/New_York"))

// Post-market: 4:00 PM - 8:00 PM ET
postSession = "1600-2000:23456"
inPost = not na(time(timeframe.period, postSession, "America/New_York"))

// Track RTH high/low/close
var float rthHigh = na
var float rthLow = na
var float rthClose = na
var float prevRthHigh = na
var float prevRthLow = na
var float prevRthClose = na

// Track ETH (full day) high/low/close
var float ethHigh = na
var float ethLow = na
var float ethClose = na
var float prevEthHigh = na
var float prevEthLow = na
var float prevEthClose = na

// Track pre-market high/low
var float preHigh = na
var float preLow = na

// Track post-market high/low (previous day's post)
var float postHigh = na
var float postLow = na
var float prevPostHigh = na
var float prevPostLow = na

// Detect new RTH day (RTH open)
newRthDay = inRTH and not inRTH[1]

// Detect new ETH day (pre-market open ~4 AM)
newEthDay = inPre and not inPre[1]

// Reset on new ETH day (start of pre-market)
if newEthDay
    prevEthHigh := ethHigh
    prevEthLow := ethLow
    prevEthClose := ethClose
    ethHigh := high
    ethLow := low
    preHigh := high
    preLow := low
    prevPostHigh := postHigh
    prevPostLow := postLow

// Reset RTH values on new RTH day
if newRthDay
    prevRthHigh := rthHigh
    prevRthLow := rthLow
    prevRthClose := rthClose
    rthHigh := high
    rthLow := low

// Track RTH high/low/close during RTH
if inRTH
    rthHigh := na(rthHigh) ? high : math.max(rthHigh, high)
    rthLow := na(rthLow) ? low : math.min(rthLow, low)
    rthClose := close

// Track ETH high/low/close all day
ethHigh := na(ethHigh) ? high : math.max(ethHigh, high)
ethLow := na(ethLow) ? low : math.min(ethLow, low)
ethClose := close

// Track pre-market high/low
if inPre
    preHigh := na(preHigh) ? high : math.max(preHigh, high)
    preLow := na(preLow) ? low : math.min(preLow, low)

// Track post-market high/low
if inPost
    postHigh := na(postHigh) ? high : math.max(postHigh, high)
    postLow := na(postLow) ? low : math.min(postLow, low)

// =====================================================
// CAM RANGE & CLOSE SELECTION (Bruz-compatible)
// Key insight: Range and Close are INDEPENDENT
// Bruz uses "Higher Range" (max of RTH/ETH) but anchors to RTH Close
// =====================================================
prevRthRange = prevRthHigh - prevRthLow
prevEthRange = prevEthHigh - prevEthLow

// For Auto mode: calculate pre/post ranges to match Bruz's switching logic
preRange = preHigh - preLow
postRange = prevPostHigh - prevPostLow

// Bruz's auto-switch: use ETH if overnight range exceeds RTH range
autoUseETH = false
if not na(preRange) and not na(prevRthRange) and preRange > prevRthRange
    autoUseETH := true
if not na(postRange) and not na(prevRthRange) and postRange > prevRthRange
    autoUseETH := true

// Select RANGE based on mode
float camRange = na
if camRangeMode == "RTH Only"
    camRange := prevRthRange
else if camRangeMode == "Higher Range"
    // Bruz's "Higher Range" mode - use the LARGER of RTH or ETH range
    camRange := math.max(nz(prevRthRange), nz(prevEthRange))
else if camRangeMode == "Lower Range"
    // "Narrow Pivots" - use the SMALLER of RTH or ETH range (tighter levels)
    // Only use min if both ranges exist, otherwise use whichever is available
    if not na(prevRthRange) and not na(prevEthRange) and prevRthRange > 0 and prevEthRange > 0
        camRange := math.min(prevRthRange, prevEthRange)
    else
        camRange := nz(prevRthRange, prevEthRange)
else if camRangeMode == "Auto"
    // Match Bruz's auto-switch: use ETH range if overnight range > RTH range
    camRange := autoUseETH ? prevEthRange : prevRthRange
else  // "ETH Only"
    camRange := prevEthRange

// Select CLOSE anchor (independent of range!)
float camClose = na
if camCloseAnchor == "RTH Close"
    // Anchor to RTH close - Bruz default when using RTH data
    camClose := useDailyTF ? dailyPrevClose : prevRthClose
else if camCloseAnchor == "ETH Close"
    // Anchor to ETH close - use when Bruz shows "Using ETH Data"
    camClose := prevEthClose
else if camCloseAnchor == "Auto"
    // Match Bruz's auto-switch: ETH close if overnight range > RTH range
    camClose := autoUseETH ? prevEthClose : prevRthClose
else  // "Daily Close"
    // Use official daily close from request.security
    camClose := dailyPrevClose

// Calculate Cam levels using independent RANGE + CLOSE
camLevelR3 = camClose + camRange * 1.1 / 4
camLevelR4 = camClose + camRange * 1.1 / 2
camLevelS3 = camClose - camRange * 1.1 / 4
camLevelS4 = camClose - camRange * 1.1 / 2


// =====================================================
// CAM STATE SELECTION (PHASE 2 – STEP 2)
// Determines which zone we're in and which state applies
// =====================================================
int camStateActive = 3  // default CONFLICT (no edge)
string camZoneName = "NEUTRAL"
float camBreakProb = na
float camRevProb = na
float camExtATR = na

if close >= camLevelR3
    // Price in R4 zone - use R4 stats
    camStateActive := camStateR4
    camZoneName := "R4 ZONE"
    camBreakProb := camBreakR4
    camRevProb := camRevR4
    camExtATR := camExtR4
else if close <= camLevelS3
    // Price in S4 zone - use S4 stats
    camStateActive := camStateS4
    camZoneName := "S4 ZONE"
    camBreakProb := camBreakS4
    camRevProb := camRevS4
    camExtATR := camExtS4
else
    // Price between S3 and R3 - TRAVERSE zone
    camStateActive := 0  // TRAVERSE
    camZoneName := "TRAVERSE"

// =====================================================
// CAM STATE BADGE (PHASE 2 – STEP 1 ENHANCED)
// =====================================================
var label camStateLabel = na

if showCamStateBadge and barstate.islast
    string camStateText = "NO EDGE"
    color camStateColor = color.new(color.gray, 0)
    
    if camStateActive == 1
        camStateText := "TREND BREAK"
        camStateColor := color.new(color.green, 0)
    else if camStateActive == 2
        camStateText := "EXHAUSTION"
        camStateColor := color.new(color.red, 0)
    else if camStateActive == 0
        camStateText := "TRAVERSE"
        camStateColor := color.new(color.yellow, 0)
    
    // Build stats string if available
    string statsLine = ""
    if not na(camBreakProb) and not na(camRevProb)
        statsLine := "\n↑" + str.tostring(camBreakProb * 100, "#") + "%  ↓" + str.tostring(camRevProb * 100, "#") + "%"
    
    // Delete old label
    if not na(camStateLabel)
        label.delete(camStateLabel)
    
    // Create new badge with zone + state + stats
    camTextColor = camStateColor == color.yellow ? color.black : color.white

    camStateLabel := label.new(bar_index + 20, ta.highest(high, 50), "CAM: " + camZoneName + "\n" + camStateText + statsLine, style=label.style_label_lower_left, textcolor=camTextColor, color=camStateColor, size=size.normal)
// =====================================================
// CAM LEVEL HALOS (PHASE 2 – STEP 4)
// Colored bands behind R4/S4 showing historical bias
// =====================================================
showCamHalos = input.bool(true, "Show CAM Level Halos", group="Display Settings")
camHaloWidth = input.int(10, "CAM Halo Width", minval=1, maxval=20, group="Display Settings", tooltip="Line thickness for R4/S4 halos")
camHaloTransparency = input.int(65, "CAM Halo Transparency", minval=0, maxval=95, group="Display Settings", tooltip="0=solid, 95=nearly invisible")

// Determine halo colors based on state
// R4 halo
color haloColorR4 = color.new(color.gray, camHaloTransparency)  // default: no edge
if camStateR4 == 1
    haloColorR4 := color.new(color.green, camHaloTransparency)   // TREND BREAK - green glow
else if camStateR4 == 2
    haloColorR4 := color.new(color.red, camHaloTransparency)     // EXHAUSTION - red glow
else if camStateR4 == 0
    haloColorR4 := color.new(color.yellow, camHaloTransparency)  // TRAVERSE - yellow glow

// S4 halo
color haloColorS4 = color.new(color.gray, camHaloTransparency)  // default: no edge
if camStateS4 == 1
    haloColorS4 := color.new(color.green, camHaloTransparency)   // TREND BREAK - green glow
else if camStateS4 == 2
    haloColorS4 := color.new(color.red, camHaloTransparency)     // EXHAUSTION - red glow
else if camStateS4 == 0
    haloColorS4 := color.new(color.yellow, camHaloTransparency)  // TRAVERSE - yellow glow

// Plot the halos as thick bands behind the levels
// Use already-calculated cam levels (respects new Bruz-compatible settings)
plot(showCamHalos ? camLevelR4 : na, "R4 Halo", color=haloColorR4, linewidth=camHaloWidth, style=plot.style_line)
plot(showCamHalos ? camLevelS4 : na, "S4 Halo", color=haloColorS4, linewidth=camHaloWidth, style=plot.style_line)
// Plot the actual Cam levels as thinner lines on top (optional - your proprietary indicator already shows these)
// Uncomment if you want HMM to also draw the levels:
// plot(showCamHalos ? camLevelR4 : na, "R4 Level", color=color.new(color.white, 50), linewidth=1, style=plot.style_line)
// plot(showCamHalos ? camLevelS4 : na, "S4 Level", color=color.new(color.white, 50), linewidth=1, style=plot.style_line)
// plot(showCamHalos ? camLevelR3 : na, "R3 Level", color=color.new(color.white, 70), linewidth=1, style=plot.style_line)
// plot(showCamHalos ? camLevelS3 : na, "S3 Level", color=color.new(color.white, 70), linewidth=1, style=plot.style_line)

// =====================================================
// INLINE MINI-BADGES (PHASE 2 – STEP 5)
// Small probability labels next to R4/S4 levels
// Green = Break (GO), Red = Reversal (STOP)
// =====================================================
showCamMiniBadges = input.bool(true, "Show CAM Mini-Badges", group="Display Settings")

var label miniBadgeR4Break = na
var label miniBadgeR4Rev = na
var label miniBadgeS4Break = na
var label miniBadgeS4Rev = na

if showCamMiniBadges and barstate.islast
    // Clean up old labels
    if not na(miniBadgeR4Break)
        label.delete(miniBadgeR4Break)
    if not na(miniBadgeR4Rev)
        label.delete(miniBadgeR4Rev)
    if not na(miniBadgeS4Break)
        label.delete(miniBadgeS4Break)
    if not na(miniBadgeS4Rev)
        label.delete(miniBadgeS4Rev)
    
    // R4 mini-badges: ↑ break (green), ↓ reversal (red)
    if not na(camBreakR4)
        miniBadgeR4Break := label.new(bar_index + 20, camLevelR4, "↑" + str.tostring(camBreakR4 * 100, "#") + "%", style=label.style_label_left, color=color.new(color.black, 80), textcolor=color.green, size=size.large)
        miniBadgeR4Rev := label.new(bar_index + 28, camLevelR4, "↓" + str.tostring(camRevR4 * 100, "#") + "%", style=label.style_label_left, color=color.new(color.black, 80), textcolor=color.red, size=size.large)

// S4 mini-badges: ↓ break (green), ↑ reversal (red)
    if not na(camBreakS4)
        miniBadgeS4Break := label.new(bar_index + 20, camLevelS4, "↓" + str.tostring(camBreakS4 * 100, "#") + "%", style=label.style_label_left, color=color.new(color.black, 80), textcolor=color.green, size=size.large)
        miniBadgeS4Rev := label.new(bar_index + 28, camLevelS4, "↑" + str.tostring(camRevS4 * 100, "#") + "%", style=label.style_label_left, color=color.new(color.black, 80), textcolor=color.red, size=size.large)
// =====================================================
// CAM PERSONALITY CARD (PHASE 2 – STEP 3)
// Green = Break (GO), Red = Reversal (STOP)
// Arrows match direction based on zone (R4 vs S4)
// =====================================================
showCamCard = input.bool(true, "Show CAM Personality Card", group="Display Settings")

var table camCardTable = na

if showCamCard and barstate.islast
    // Clean up old table
    if not na(camCardTable)
        table.delete(camCardTable)
    
    // Determine state text and color
    string stateText = "NO EDGE"
    color stateColor = color.gray
    
    if camStateActive == 1
        stateText := "TREND BREAK"
        stateColor := color.green
    else if camStateActive == 2
        stateText := "EXHAUSTION"
        stateColor := color.red
    else if camStateActive == 0
        stateText := "TRAVERSE"
        stateColor := color.yellow
    
    // Determine arrows based on zone (R4 = up break, S4 = down break)
    string breakArrow = "↑"
    string revArrow = "↓"
    if camZoneName == "S4 ZONE"
        breakArrow := "↓"
        revArrow := "↑"
    
    // Create table - positioned above HMM table (bottom_right, but we'll use middle_right to sit above)
    camCardTable := table.new(position.bottom_center, 2, 6, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)
    
    // Header row
    color headerTextColor = stateColor == color.yellow ? color.black : color.white
    table.cell(camCardTable, 0, 0, "CAM PROFILE", bgcolor=color.gray, text_color=color.white, text_size=size.normal, text_halign=text.align_center)
    table.cell(camCardTable, 1, 0, syminfo.ticker, bgcolor=stateColor, text_color=headerTextColor, text_size=size.normal, text_halign=text.align_center)
    
    // Zone row
    table.cell(camCardTable, 0, 1, "Zone:", text_color=color.white, text_size=size.normal)
    table.cell(camCardTable, 1, 1, camZoneName, text_color=stateColor, text_size=size.normal)
    
    // Break probability row (GREEN with directional arrow)
    string breakText = na(camBreakProb) ? "–" : breakArrow + str.tostring(camBreakProb * 100, "#.#") + "%"
    table.cell(camCardTable, 0, 2, "Break ≥1 ATR:", text_color=color.white, text_size=size.normal)
    table.cell(camCardTable, 1, 2, breakText, text_color=color.green, text_size=size.normal)
    
    // Reversal probability row (RED with directional arrow)
    string revText = na(camRevProb) ? "–" : revArrow + str.tostring(camRevProb * 100, "#.#") + "%"
    table.cell(camCardTable, 0, 3, "Reversal ≥0.5:", text_color=color.white, text_size=size.normal)
    table.cell(camCardTable, 1, 3, revText, text_color=color.red, text_size=size.normal)
    
    // Median extension row
    string extText = na(camExtATR) ? "–" : str.tostring(camExtATR, "#.##") + " ATR"
    table.cell(camCardTable, 0, 4, "Median Ext:", text_color=color.white, text_size=size.normal)
    table.cell(camCardTable, 1, 4, extText, text_color=color.yellow, text_size=size.normal)
    
    // State row
    table.cell(camCardTable, 0, 5, "State:", text_color=color.white, text_size=size.normal)
    table.cell(camCardTable, 1, 5, stateText, text_color=stateColor, text_size=size.normal)

// ========================================
// PRESET STATUS TABLE (WHAT'S ACTUALLY IN USE)
// ========================================
if barstate.islast and showPresetStatus
    var table presetTable = table.new(position.middle_right, 2, 8, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)

    // Show PRESET or MANUAL status
    string statusText = hasPreset ? "PRESET" : "MANUAL"
    color statusColor = hasPreset ? color.green : color.orange

    table.cell(presetTable, 0, 0, "PRESET STATUS", bgcolor=color.gray, text_color=color.white, text_size=size.normal, text_halign=text.align_center)
    table.cell(presetTable, 1, 0, autoSymbol + " [" + statusText + "]", bgcolor=statusColor, text_color=color.white, text_size=size.normal, text_halign=text.align_center)

    table.cell(presetTable, 0, 1, "SSL Base:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 1, str.tostring(sslBaselineLengthEff), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 2, "SSL Len:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 2, str.tostring(sslLengthEff), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 3, "Exit Len:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 3, str.tostring(exitLengthEff), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 4, "WAE Sens:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 4, str.tostring(waeSensitivityEff), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 5, "Vol Low:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 5, str.tostring(lowVolThresholdEff, "#.##"), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 6, "Vol High:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 6, str.tostring(highVolThresholdEff, "#.##"), text_color=color.yellow, text_size=size.small)

    table.cell(presetTable, 0, 7, "Mode:", text_color=color.white, text_size=size.small)
    table.cell(presetTable, 1, 7, presetComparisonMode ? "COMPARISON" : "PRESET", text_color=presetComparisonMode ? color.orange : color.green, text_size=size.small)




if showConfluenceTable
    var table confluenceTable = table.new(position.top_center, 5, 7, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)
    
    table.cell(confluenceTable, 0, 0, "Signal", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
    table.cell(confluenceTable, 1, 0, "Bull", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
    table.cell(confluenceTable, 2, 0, "Bear", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
    table.cell(confluenceTable, 3, 0, "Score", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
    table.cell(confluenceTable, 4, 0, "Quality", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
    
    // SSL row (synced with ORB: ✓=scored, ◐=confirmation only, ✗=none)
    table.cell(confluenceTable, 0, 1, "SSL", text_color=color.white, text_size=size.normal)
    string sslDisplayBull = sslScoreBull >= 1.0 ? "✓" : (sslBullishSimple ? "◐" : "✗")
    string sslDisplayBear = sslScoreBear >= 1.0 ? "✓" : (sslBearishSimple ? "◐" : "✗")
    color sslBullColor = sslScoreBull >= 1.0 ? color.green : (sslBullishSimple ? color.yellow : color.gray)
    color sslBearColor = sslScoreBear >= 1.0 ? color.green : (sslBearishSimple ? color.yellow : color.gray)
    table.cell(confluenceTable, 1, 1, sslDisplayBull, text_color=sslBullColor, text_size=size.normal)
    table.cell(confluenceTable, 2, 1, sslDisplayBear, text_color=sslBearColor, text_size=size.normal)
    
    // WAE row (synced with ORB: ✓=scored, ◐=confirmation only, ✗=none)
    table.cell(confluenceTable, 0, 2, "WAE", text_color=color.white, text_size=size.normal)
    string waeDisplayBull = waeScoreBull >= 1.0 ? "✓" : (waeBullConfirmation ? "◐" : "✗")
    string waeDisplayBear = waeScoreBear >= 1.0 ? "✓" : (waeBearConfirmation ? "◐" : "✗")
    color waeBullColor = waeScoreBull >= 1.0 ? color.green : (waeBullConfirmation ? color.yellow : color.gray)
    color waeBearColor = waeScoreBear >= 1.0 ? color.green : (waeBearConfirmation ? color.yellow : color.gray)
    table.cell(confluenceTable, 1, 2, waeDisplayBull, text_color=waeBullColor, text_size=size.normal)
    table.cell(confluenceTable, 2, 2, waeDisplayBear, text_color=waeBearColor, text_size=size.normal)
    
    // QQE row (synced with ORB: ✓=scored, ◐=signal only, ✗=none)
    table.cell(confluenceTable, 0, 3, "QQE", text_color=color.white, text_size=size.normal)
    string qqeDisplayBull = qqeScoreBull >= 1.0 ? "✓" : (qqeBullSignal ? "◐" : "✗")
    string qqeDisplayBear = qqeScoreBear >= 1.0 ? "✓" : (qqeBearSignal ? "◐" : "✗")
    color qqeBullColor = qqeScoreBull >= 1.0 ? color.green : (qqeBullSignal ? color.yellow : color.gray)
    color qqeBearColor = qqeScoreBear >= 1.0 ? color.green : (qqeBearSignal ? color.yellow : color.gray)
    table.cell(confluenceTable, 1, 3, qqeDisplayBull, text_color=qqeBullColor, text_size=size.normal)
    table.cell(confluenceTable, 2, 3, qqeDisplayBear, text_color=qqeBearColor, text_size=size.normal)
    
    // VOL row (synced with ORB - shows Z-score with σ)
    table.cell(confluenceTable, 0, 4, "VOL", text_color=color.white, text_size=size.normal)
    string volDisplay = enableVolume ? str.tostring(volZ, "#.#") + "σ" : "–"
    color volDisplayColor = volZ >= 1.0 ? color.green : volZ >= 0.2 ? color.yellow : color.red
    table.cell(confluenceTable, 1, 4, volDisplay, text_color=enableVolume ? volDisplayColor : color.gray, text_size=size.normal)
    table.cell(confluenceTable, 2, 4, volDisplay, text_color=enableVolume ? volDisplayColor : color.gray, text_size=size.normal)
    
    // IB row
    table.cell(confluenceTable, 0, 5, "IB", text_color=color.white, text_size=size.normal)
    table.cell(confluenceTable, 1, 5, ibFormed ? (ibBreakUp ? "↑" : "–") : "◷", text_color=ibBreakUp ? color.green : ibFormed ? color.gray : color.orange, text_size=size.normal)
    table.cell(confluenceTable, 2, 5, ibFormed ? (ibBreakDown ? "↓" : "–") : "◷", text_color=ibBreakDown ? color.green : ibFormed ? color.gray : color.orange, text_size=size.normal)
    
    // Total row (synced with ORB - includes volume in max)
    table.cell(confluenceTable, 0, 6, "Total", bgcolor=color.new(color.gray, 50), text_color=color.white, text_size=size.normal)
    scoreMax = str.tostring((includeIBInConfluence ? 4 : 3) + (enableVolume ? 1 : 0))
    table.cell(confluenceTable, 1, 6, str.tostring(bullScore) + "/" + scoreMax, bgcolor=color.new(color.gray, 50), text_color=bullScore >= minConfluenceScore ? color.green : color.gray, text_size=size.normal)
    table.cell(confluenceTable, 2, 6, str.tostring(bearScore) + "/" + scoreMax, bgcolor=color.new(color.gray, 50), text_color=bearScore >= minConfluenceScore ? color.red : color.gray, text_size=size.normal)
    
    // Quality status column
    qualityStatus = "✓"
    qualityColor = color.green
    if inLunchHour
        qualityStatus := "LUNCH"
        qualityColor := color.orange
    else if not volumeCondition
        qualityStatus := "LOW VOL"
        qualityColor := color.gray
    else if not volatilityCondition
        qualityStatus := "LOW Vx"
        qualityColor := color.gray
    else if not htfTrendBullish and not htfTrendBearish
        qualityStatus := "NO HTF"
        qualityColor := color.gray
    else if not marketBullish and not marketBearish
        qualityStatus := "MKT FLAT"
        qualityColor := color.gray
    
    table.cell(confluenceTable, 4, 1, qualityStatus, text_color=qualityColor, text_size=size.normal)
    table.cell(confluenceTable, 4, 2, "Vol: " + str.tostring(volume/avgVolume, "#.##") + "x", text_color=volumeCondition ? color.green : color.gray, text_size=size.normal)
    table.cell(confluenceTable, 4, 3, "ATR: " + str.tostring(atrPct/atrPctAvg, "#.##") + "x", text_color=volatilityCondition ? color.green : color.gray, text_size=size.normal)

// Volatility regime display
    vfText = na(volFactor) ? "n/a" : str.tostring(volFactor, "#.##")
    vfColor = volState == "LOW" ? color.blue : volState == "NORMAL" ? color.green : volState == "HIGH" ? color.orange : color.red
    table.cell(confluenceTable, 4, 5, "VF: " + vfText, text_color=vfColor, text_size=size.normal)
    table.cell(confluenceTable, 4, 6, volState, text_color=vfColor, text_size=size.normal)
    
    // Status in Score column
    string statusText2 = inLongPosition ? "LONG" : inShortPosition ? "SHORT" : "FLAT"
    if not inMarketHours
        statusText2 := "CLOSED"
    else if not inEntryWindow
        statusText2 := "IB WATCH"
    else if inLunchHour
        statusText2 := "LUNCH"
    else if longConditionsMet and not (inLongPosition or inShortPosition)
        statusText2 := "LONG READY"
    else if shortConditionsMet and not (inLongPosition or inShortPosition)
        statusText2 := "SHORT READY"
    
    table.cell(confluenceTable, 3, 4, statusText2, bgcolor=color.new(color.gray, 50), text_color=inLongPosition ? color.green : inShortPosition ? color.red : not inEntryWindow ? color.yellow : longConditionsMet ? color.lime : shortConditionsMet ? color.orange : inLunchHour ? color.orange : not inMarketHours ? color.gray : color.gray, text_size=size.normal)

// POSITION TABLE WITH CLEANUP
if showPositionInfo and (inLongPosition or inShortPosition)
    // Delete old table if it exists
    if not na(positionTable)
        table.delete(positionTable)
    
    // Create new table
    positionTable := table.new(position.top_center, 2, 8, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)
    
    table.cell(positionTable, 0, 0, "POSITION", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
    table.cell(positionTable, 1, 0, "", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
    
    table.cell(positionTable, 0, 1, "Entry:", text_color=color.white, text_size=size.normal)
    table.cell(positionTable, 1, 1, str.tostring(entryPrice, "#.##"), text_color=color.white, text_size=size.normal)
    
    table.cell(positionTable, 0, 2, "Stop:", text_color=color.white, text_size=size.normal)
    table.cell(positionTable, 1, 2, str.tostring(stopPrice, "#.##"), text_color=color.red, text_size=size.normal)
    
    table.cell(positionTable, 0, 3, "Target:", text_color=color.white, text_size=size.normal)
    table.cell(positionTable, 1, 3, str.tostring(targetPrice, "#.##"), text_color=color.green, text_size=size.normal)
    
    table.cell(positionTable, 0, 4, "Shares:", text_color=color.white, text_size=size.normal)
    table.cell(positionTable, 1, 4, str.tostring(positionSize, "#.#"), text_color=color.white, text_size=size.normal)
    
    // RR Used row
    rrText = na(lastRRUsed) ? "–" : str.tostring(lastRRUsed, "#.#") + ":1"
    table.cell(positionTable, 0, 5, "RR Used:", text_color=color.white, text_size=size.normal)
    table.cell(positionTable, 1, 5, rrText, text_color=color.white, text_size=size.normal)
    
    // Target ATR row
    string targetGradeDisplay = "–"
    color targetGradeColor = color.gray
    if not na(lastTargetATRs)
        if lastTargetATRs < 1.2
            targetGradeDisplay := "A"
            targetGradeColor := color.green
        else if lastTargetATRs < 1.8
            targetGradeDisplay := "B"
            targetGradeColor := color.lime
        else if lastTargetATRs < 2.5
            targetGradeDisplay := "C"
            targetGradeColor := color.orange
        else
            targetGradeDisplay := "D"
            targetGradeColor := color.red
    
    targetATRText = na(lastTargetATRs) ? "–" : str.tostring(lastTargetATRs, "#.#") + " ATR (" + targetGradeDisplay + ")"
    table.cell(positionTable, 0, 6, "Target:", text_color=color.white, text_size=size.normal)
    table.cell(positionTable, 1, 6, targetATRText, text_color=targetGradeColor, text_size=size.normal)
    
    // P/L row
    string plText = "–"
    color plColor = color.gray
    
    if inLongPosition and not na(longPnlDollars)
        plText := "$" + str.tostring(math.abs(longPnlDollars), "#.##")
        plColor := longPnlDollars >= 0 ? color.green : color.red
    else if inShortPosition and not na(shortPnlDollars)
        plText := "$" + str.tostring(math.abs(shortPnlDollars), "#.##")
        plColor := shortPnlDollars >= 0 ? color.green : color.red
    
    table.cell(positionTable, 0, 7, "P/L:", text_color=color.white, text_size=size.normal)
    table.cell(positionTable, 1, 7, plText, text_color=plColor, text_size=size.normal)

// Explicitly delete table when no position
else if not na(positionTable)
    table.delete(positionTable)
    positionTable := na

// ========================================
// STOP OPTIONS TABLE
// ========================================
var table stopOptionsTable = na

if showStopOptionsTable and (inLongPosition or inShortPosition) and autoSelectStop
    // Delete old table if exists
    if not na(stopOptionsTable)
        table.delete(stopOptionsTable)
    
    stopOptionsTable := table.new(position.middle_left, 2, 5, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)
    
    // Header
    table.cell(stopOptionsTable, 0, 0, "STOP OPTIONS", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
    table.cell(stopOptionsTable, 1, 0, "R:R", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
    
    // ATR row
    atrWinner = lastStopTypeUsed == "ATR" or lastStopTypeUsed == "ATR-Fallback"
    atrText = na(lastAtrRR) ? "–" : str.tostring(lastAtrRR, "#.#") + ":1" + (atrWinner ? " ←" : "")
    table.cell(stopOptionsTable, 0, 1, "ATR", text_color=color.white, text_size=size.normal)
    table.cell(stopOptionsTable, 1, 1, atrText, text_color=atrWinner ? color.green : color.gray, text_size=size.normal)
    
    // Swing row
    swingWinner = str.contains(lastStopTypeUsed, "Swing")
    swingText = na(lastSwingRR) or lastSwingRR < 0 ? "invalid" : str.tostring(lastSwingRR, "#.#") + ":1" + (swingWinner ? " ←" : "")
    swingColor = na(lastSwingRR) or lastSwingRR < 0 ? color.red : (swingWinner ? color.green : color.gray)
    table.cell(stopOptionsTable, 0, 2, "Swing", text_color=color.white, text_size=size.normal)
    table.cell(stopOptionsTable, 1, 2, swingText, text_color=swingColor, text_size=size.normal)
    
    // VWAP row
    vwapWinner = lastStopTypeUsed == "VWAP"
    vwapText = na(lastVwapRR) or lastVwapRR < 0 ? "invalid" : str.tostring(lastVwapRR, "#.#") + ":1" + (vwapWinner ? " ←" : "")
    vwapColor = na(lastVwapRR) or lastVwapRR < 0 ? color.red : (vwapWinner ? color.green : color.gray)
    table.cell(stopOptionsTable, 0, 3, "VWAP", text_color=color.white, text_size=size.normal)
    table.cell(stopOptionsTable, 1, 3, vwapText, text_color=vwapColor, text_size=size.normal)
    
    // Hybrid row
    hybridWinner = str.contains(lastStopTypeUsed, "Hybrid")
    hybridText = na(lastHybridRR) or lastHybridRR < 0 ? "invalid" : str.tostring(lastHybridRR, "#.#") + ":1" + (hybridWinner ? " ←" : "")
    hybridColor = na(lastHybridRR) or lastHybridRR < 0 ? color.red : (hybridWinner ? color.green : color.gray)
    table.cell(stopOptionsTable, 0, 4, "Hybrid", text_color=color.white, text_size=size.normal)
    table.cell(stopOptionsTable, 1, 4, hybridText, text_color=hybridColor, text_size=size.normal)

else if not na(stopOptionsTable)
    table.delete(stopOptionsTable)
    stopOptionsTable := na

// ========================================
// PROFIT TRACKING TABLE
// ========================================
if showChartStats and barstate.islast
    if not na(profitTable)
        table.delete(profitTable)
    
    profitTable := table.new(position.middle_left, 2, 9, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.gray)
    
    // Header
    table.cell(profitTable, 0, 0, "CHART STATS", bgcolor=color.gray, text_color=color.white, text_size=size.normal)
    table.cell(profitTable, 1, 0, syminfo.ticker, bgcolor=color.gray, text_color=color.yellow, text_size=size.normal)
    
    // Current Position Info (rows 1-2)
    float openPnL = 0.0
    string positionText = "FLAT"
    color positionColor = color.gray
    
    if inLongPosition and not na(entryPrice)
        openPnL := (close - entryPrice) * positionSize
        positionText := str.tostring(positionSize, "#") + " @ " + str.tostring(entryPrice, "#.##")
        positionColor := color.green
    else if inShortPosition and not na(entryPrice)
        openPnL := (entryPrice - close) * positionSize
        positionText := str.tostring(positionSize, "#") + " @ " + str.tostring(entryPrice, "#.##")
        positionColor := color.red
    
    // Open P&L
    table.cell(profitTable, 0, 1, "Open P&L:", text_color=color.white, text_size=size.normal)
    openPnLText = (inLongPosition or inShortPosition) ? "$" + str.tostring(openPnL, "#.##") : "–"
    openPnLColor = openPnL >= 0 ? color.green : color.red
    table.cell(profitTable, 1, 1, openPnLText, text_color=(inLongPosition or inShortPosition) ? openPnLColor : color.gray, text_size=size.normal)
    
    // Position
    table.cell(profitTable, 0, 2, "Position:", text_color=color.white, text_size=size.normal)
    table.cell(profitTable, 1, 2, positionText, text_color=positionColor, text_size=size.normal)
    
    // Total P&L (closed trades)
    table.cell(profitTable, 0, 3, "Total P&L:", text_color=color.white, text_size=size.normal)
    table.cell(profitTable, 1, 3, "$" + str.tostring(totalPnL, "#.##"), text_color=totalPnL >= 0 ? color.green : color.red, text_size=size.normal)
    
    // Last Trade
    table.cell(profitTable, 0, 4, "Last Trade:", text_color=color.white, text_size=size.normal)
    table.cell(profitTable, 1, 4, "$" + str.tostring(lastTradePnL, "#.##"), text_color=lastTradePnL >= 0 ? color.green : color.red, text_size=size.normal)
    
    // Wins
    table.cell(profitTable, 0, 5, "Wins:", text_color=color.white, text_size=size.normal)
    table.cell(profitTable, 1, 5, str.tostring(winCount), text_color=color.green, text_size=size.normal)
    
    // Losses
    table.cell(profitTable, 0, 6, "Losses:", text_color=color.white, text_size=size.normal)
    table.cell(profitTable, 1, 6, str.tostring(lossCount), text_color=color.red, text_size=size.normal)
    
    // Win Rate
    totalTrades = winCount + lossCount
    winRate = totalTrades > 0 ? (winCount / totalTrades) * 100 : 0
    table.cell(profitTable, 0, 7, "Win Rate:", text_color=color.white, text_size=size.normal)
    table.cell(profitTable, 1, 7, str.tostring(winRate, "#.#") + "%", text_color=winRate >= 50 ? color.green : color.red, text_size=size.normal)
    
    // Best/Worst
    table.cell(profitTable, 0, 8, "Best/Worst:", text_color=color.white, text_size=size.normal)
    bestWorstText = "$" + str.tostring(maxWin, "#") + " / $" + str.tostring(math.abs(maxLoss), "#")
    table.cell(profitTable, 1, 8, bestWorstText, text_color=color.white, text_size=size.normal)
