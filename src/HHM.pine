waeFastEMA = input.int(15, "Fast EMA", minval=5, maxval=50, group=grpWAE)  // Changed from 20 to 15
waeSlowEMA = input.int(30, "Slow EMA", minval=20, maxval=100, group=grpWAE)  // Changed from 40 to 30
waeBBLength = input.int(20, "BB Length", minval=10, maxval=50, group=grpWAE)  // Changed from 20 to 20
waeBBMultiplier = input.float(2.0, "BB StDev Multiplier", minval=1.0, maxval=3.0, step=0.5, group=grpWAE)
// WAE Acceleration Filter - requires momentum to be INCREASING (synced with ORB)
useWAEAcceleration = input.bool(true, "Require WAE Acceleration", group=grpWAE, tooltip="WAE bars must be growing (accelerating), not dying. Filters out weak/fading momentum.")

// ========================================
// SQUEEZE DETECTION
// ========================================

// Squeeze parameters
sqzBBLength = 20
sqzBBMult = 2.0
sqzKCLength = 20
sqzKCMult = 1.5

// Calculate Bollinger Bands
sqzBasis = ta.sma(close, sqzBBLength)
sqzDev = sqzBBMult * ta.stdev(close, sqzBBLength)
sqzUpperBB = sqzBasis + sqzDev
sqzLowerBB = sqzBasis - sqzDev

// Calculate Keltner Channels
sqzKCBasis = ta.sma(close, sqzKCLength)
sqzKCRange = ta.atr(sqzKCLength)
sqzUpperKC = sqzKCBasis + (sqzKCRange * sqzKCMult)
sqzLowerKC = sqzKCBasis - (sqzKCRange * sqzKCMult)

// Squeeze is ON when BB is inside KC
sqzOn = (sqzLowerBB > sqzLowerKC) and (sqzUpperBB < sqzUpperKC)

// Momentum direction (same method as TTM Squeeze)
sqzMomSrc = close - math.avg(math.avg(ta.highest(high, sqzBBLength), ta.lowest(low, sqzBBLength)), sqzBasis)
sqzMom = ta.linreg(sqzMomSrc, sqzBBLength, 0)

// Directional bias during squeeze
sqzBullish = sqzMom > 0
sqzBearish = sqzMom <= 0

// QQE MOD SETTINGS
var grpQQE = "QQE Mod Settings"
qqeRSI1Length = input.int(9, "Primary RSI Length", minval=2, maxval=30, group=grpQQE)
